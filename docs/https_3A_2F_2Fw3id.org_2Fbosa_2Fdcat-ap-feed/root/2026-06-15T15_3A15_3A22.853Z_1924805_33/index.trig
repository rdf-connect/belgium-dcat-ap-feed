<#0da52f4569c9a8fa1770dab7e6bf1903> {
<https://opendata.vlaanderen.be/dataset/773fcfe9-65e5-409f-a7eb-8f174ae046f5/resource/d7ab5499-3128-4f16-858c-65bf1fdccda6> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/NLD>;
    <http://purl.org/dc/terms/identifier> "30e845a4-316c-4090-a3c2-b51e85036be9";
    <http://purl.org/dc/terms/title> "Aantal dagen met zware neerslag (= 20,0 mm per dag) te Ukkel (vanaf 1951)"@nl;
    <http://purl.org/dc/terms/description> "De laatste decennia nemen de atmosferische concentraties van broeikasgassen en aerosolen toe hoofdzakelijk ten gevolge van menselijke activiteiten. Die toename leidt tot verhoogde temperaturen op aarde, wat verstoring van het klimaat met zich meebrengt. Die verstoring kan bestaan uit wijzigende neerslagpatronen.Deze indicator gaat na in hoeverre er in België wijzigingen optreden in het voorkomen van periodes met extreme neerslag. Periodes met extreem veel neerslag kunnen immers leiden tot overstromingen, terwijl lange droge periodes leiden tot verdroging van ecosystemen en aantasting van de waterreserves."@nl;
    <http://www.w3.org/ns/dcat#mediaType> <https://www.iana.org/assignments/media-types/text/csv>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/CSV>;
    <http://www.w3.org/ns/dcat#accessURL> <https://metadata.vlaanderen.be/srv/dut/catalog.search#/metadata/69dc54b8-3057-31ea-91c3-d4095e807ae3>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://vmm.vlaanderen.be/feiten-cijfers/klimaat/klimaatthemas/wateroverlast-door-hevige-regenval/indicator-neerslagextremen/zware-neerslag/@@download/csv>;
    <http://purl.org/dc/terms/license> <http://data.vlaanderen.be/id/licentie/modellicentie-gratis-hergebruik/v1.0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>
}
