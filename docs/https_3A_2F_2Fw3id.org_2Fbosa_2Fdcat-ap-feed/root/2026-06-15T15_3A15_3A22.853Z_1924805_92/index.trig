    <http://purl.org/dc/terms/rights> <http://data.gov.be/.well-known/genid/e32d7fc3e84f4f2093cf4aca98a69781320-46b6e6e4e0f1455a>;
    <http://www.w3.org/ns/dcat#keyword> "DIV"@nl, "BOSA"@nl, "Mobiliteit"@nl, "MAGDA"@nl;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TRAN>;
