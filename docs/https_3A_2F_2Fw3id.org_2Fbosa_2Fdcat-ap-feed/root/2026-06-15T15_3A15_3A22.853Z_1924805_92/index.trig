    <http://purl.org/dc/terms/creator> <https://org.belgif.be/id/CbeEstablishmentUnit/2256180804>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg/2022/868/oj>;
    <http://www.w3.org/ns/dcat#keyword> "RAD-register"@nl, "Persoon"@nl, "Kruispuntbank Sociale Zekerheid"@nl, "BIS-register"@nl, "MAGDA"@nl, "Rijksregister"@nl;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/GOVE>;
    <http://www.w3.org/ns/dcat#landingPage> <https://vlaamseoverheid.atlassian.net/wiki/spaces/MG/pages/1074791921/Persoon.PubliceerMutatiePersoon-02.02>;
