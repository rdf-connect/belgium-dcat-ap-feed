<#d7fc604a4fa1078b05accc57b7e9c290> {
<https://metadata.vlaanderen.be/srv/resources/services/9c03e4ba-3692-402a-9837-2eea5a276d8e> a <http://www.w3.org/ns/dcat#DataService>;
    <http://purl.org/dc/terms/identifier> "9c03e4ba-3692-402a-9837-2eea5a276d8e";
    <http://purl.org/dc/terms/title> "Wrakken, obstructiezone, 3- en 12-mijlszone in het Belgisch Continentaal Plat (WMS)"@nl, "Épaves, zone d'obstruction, zone de 3 et 12 milles dans le plateau continental belge (WMS)"@fr-t-nl, "Wracks, Sperrzone, 3- und 12-Meilen-Zone im belgischen Festlandsockel (WMS)"@de-t-nl, "Wrecks, obstruction zone, 3 and 12-mile zone in the Belgian Continental Shelf (WMS)"@en-t-nl;
    <http://purl.org/dc/terms/description> "Database met gegevens over wrakken en andere obstructies (ongeveer 240 items) in het Belgisch Continentaal Plat. Opmetingen startten in 1992 en worden continu verder gezet.Georeferentie-informatie:- Alle data is horizontaal gerefereerd in ETRS89/WGS84. INSPIRE Annex III thema Gebiedsbeheer en gebieden waar beperking gelden."@nl, "Base de données contenant des données sur les épaves et autres obstacles (environ 240 articles) sur le plateau continental belge. Informations de géoréférence:- Toutes les données sont référencées horizontalement dans ETRS89/WGS84. INSPIRE Annexe III Thème Gestion des zones et zones réglementées."@fr-t-nl, "Datenbank mit Daten über Wracks und andere Hindernisse (ca. 240 Objekte) im belgischen Festlandsockel. Georeferenzinformationen: Alle Daten werden in ETRS89/WGS84 horizontal referenziert. INSPIRE Anhang III Thema Gebietsverwaltung und Sperrgebiete."@de-t-nl, "Database with data on wrecks and other obstructions (approximately 240 items) in the Belgian Continental Shelf. Georeference information:- All data is horizontally referenced in ETRS89/WGS84. INSPIRE Annex III theme Area management and restricted areas."@en-t-nl;
    <http://purl.org/dc/terms/issued> "2020-11-09"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/adms#identifier> _:b278890_b278889_b278888_df_12_70472;
    <http://www.w3.org/ns/dcat#version> "1.3.0";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeEstablishmentUnit/2199336725>;
    <http://purl.org/dc/terms/conformsTo> <https://data.vlaanderen.be/id/concept/dataserviceprotocol/OGC:WMS-1.3.0-http-get-capabilities>, <https://data.vlaanderen.be/id/concept/dataserviceprotocol/OGC:WMS-1.3.0-http-get-map>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg/2010/1089/oj>;
    <http://www.w3.org/ns/dcat#keyword> "VLAAMSE OVERHEID, ZEEGEBIEDEN, NOORDZEE, BAGGERWERKEN, DIEPTEN, HYDROGRAFIE, BAGGERGRONDEN, BAGGERSPECIE, DIEPTEGEGEVENS, BAGGERWERK, BATHYMETRIE, VOOROEVER, VLAAMSE KUST, DIEPTEGEBIED, HOOGTEREFERENTIESYSTEEM, NAUTISCH, OBSTRUCTIES, TOEGANGSGEULEN, WRAKKEN, VLAAMSE HYDROGRAFIE, DIEPTECIJFERS, DIEPTEZONES, ELECTRONICAL NAVIGATION CHART, ELECTRONISCHE ZEEKAART VLAAMSE BANKEN, ENC, ENC VLAAMSE BANKEN, ZEEKAART"@nl, "Wrakken en andere obstructies (ongeveer 240 items) en 3- en 12-mijlszone in het Belgisch Continentaal Plat"@nl;
    <http://purl.org/dc/terms/subject> <http://inspire.ec.europa.eu/metadata-codelist/SpatialDataServiceCategory/infoMapAccessService>, <https://metadata.vlaanderen.be/id/GDI-Vlaanderen-Service-Types/OGCWMS>, <http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/regional>;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/REGI>;
    <http://www.w3.org/ns/dcat#landingPage> <https://www.vlaanderen.be/DataCatalogRecord/037df782-50d8-4a99-a0dd-162fcecc99f6>;
    <http://www.w3.org/ns/dcat#servesDataset> <https://metadata.vlaanderen.be/srv/resources/datasets/882D57A6-FE6F-428D-9C38-9463B0D7C43D>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b278890_b278889_b278888_df_12_70473;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337388/>.
_:b278890_b278889_b278888_df_12_70472 a <http://www.w3.org/ns/adms#Identifier>;
    <http://www.w3.org/2004/02/skos/core#notation> "https://metadata.vlaanderen.be/srv/resources/services/9c03e4ba-3692-402a-9837-2eea5a276d8e".
