    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg/2022/868/oj>;
    <http://www.w3.org/ns/dcat#keyword> "Integrator"@nl, "Dossier"@nl, "DOSIS"@nl, "MAGDA"@nl;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/GOVE>;
    <http://www.w3.org/ns/dcat#landingPage> <https://vlaamseoverheid.atlassian.net/wiki/spaces/MG/pages/1209827809/Dossier.RegistreerDossier-02.00>;
