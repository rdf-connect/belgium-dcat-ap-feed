<#a629f4b3da975c92713a906492796366> {
<https://metadata.vlaanderen.be/srv/resources/services/dd1b6f2c-c72e-44dd-94e7-40df1f40c543> a <http://www.w3.org/ns/dcat#DataService>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/NLD>;
    <http://purl.org/dc/terms/identifier> "dd1b6f2c-c72e-44dd-94e7-40df1f40c543";
    <http://purl.org/dc/terms/title> "Capakey REST Service"@nl, "service REST Capakey"@fr-t-nl, "Capakey REST Service"@de-t-nl, "Capakey REST Service"@en-t-nl;
    <http://purl.org/dc/terms/description> "De Capakey REST Service laat aan ontwikkelaars toe om kadastrale (plan)perceelsinformatie trapsgewijs en hiërarchisch te bevragen. Zo kunnen lijsten of detailinformatie van gemeenten, kadastrale afdelingen, kadastrale secties en kadastrale (plan)percelen opgevraagd worden."@nl, "Le service REST de Capakey permet aux développeurs d'interroger les informations de colis cadastraux (plan) étape par étape et de manière hiérarchique. Par exemple, des listes ou des informations détaillées sur les municipalités, les départements cadastraux, les sections cadastrales et les parcelles cadastrales (plan) peuvent être demandées."@fr-t-nl, "Der Capakey REST Service ermöglicht es Entwicklern, Kataster- (Plan-)Paketinformationen Schritt für Schritt und hierarchisch abzufragen. So können z.B. Listen oder Detailinformationen zu Gemeinden, Katasterabteilungen, Katasterabschnitten und Kataster (Plan)parzellen angefordert werden."@de-t-nl, "The Capakey REST Service allows developers to query cadastral (plan) parcel information step by step and hierarchically. For example, lists or detailed information of municipalities, cadastral departments, cadastral sections and cadastral (plan) plots can be requested."@en-t-nl;
    <http://www.w3.org/ns/adms#identifier> _:b278023_b278022_b278021_df_12_69848;
    <http://www.w3.org/ns/dcat#version> "2";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeEstablishmentUnit/2256180804>;
    <http://purl.org/dc/terms/creator> <https://org.belgif.be/id/CbeEstablishmentUnit/2256180804>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://www.w3.org/ns/dcat#keyword> "Kadastrale percelen"@nl, "Actueel"@nl, "Kadaster"@nl, "Recht van voorkoop"@nl, "Administratieve percelen"@nl, "Perceel"@nl, "Fiscaal"@nl;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ECON>, <http://publications.europa.eu/resource/authority/data-theme/GOVE>;
    <http://www.w3.org/ns/dcat#landingPage> <https://www.vlaanderen.be/digitaal-vlaanderen/onze-oplossingen/geografische-webdiensten/ons-api-aanbod/capakey-rest-service>;
    <http://www.w3.org/ns/dcat#endpointURL> <https://geo.api.vlaanderen.be/capakey/v2/>;
