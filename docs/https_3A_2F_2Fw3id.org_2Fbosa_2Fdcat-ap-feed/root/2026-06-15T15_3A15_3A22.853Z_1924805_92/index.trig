    <https://www.w3.org/ns/activitystreams#object> <http://data.gov.be/.well-known/genid/dataset/brussels/d6b2001b-b0a7-4c7b-b80e-39fb8e8a2221>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:38:07.057Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#da26c7faba575d50b4bbbf03283f3fe7> {
<http://data.gov.be/.well-known/genid/dataset/brussels/d6b2001b-b0a7-4c7b-b80e-39fb8e8a2221> a <http://www.w3.org/ns/dcat#DataService>;
    <http://purl.org/dc/terms/identifier> "d6b2001b-b0a7-4c7b-b80e-39fb8e8a2221";
