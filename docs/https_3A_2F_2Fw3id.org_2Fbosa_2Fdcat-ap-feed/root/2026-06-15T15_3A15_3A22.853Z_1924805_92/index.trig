<#1bb49f5cae04912c63f13458e25780c2> {
<https://metadata.vlaanderen.be/srv/resources/services/33491f0d-b900-4701-8241-a101601b2877> a <http://www.w3.org/ns/dcat#DataService>;
    <http://purl.org/dc/terms/identifier> "33491f0d-b900-4701-8241-a101601b2877";
    <http://purl.org/dc/terms/title> "WFS - Publieke Download Service voor jeugdinfrastructuur"@nl, "WFS - Service public de téléchargement pour les infrastructures pour les jeunes"@fr-t-nl, "WFS - Öffentlicher Downloaddienst für Jugendinfrastruktur"@de-t-nl, "WFS - Public Download Service for Youth Infrastructure"@en-t-nl;
    <http://purl.org/dc/terms/description> "Publieke download service voor jeugdinfrastructuur. Gebruik deze Web service om kaartlagen toe te voegen in een GIS viewer zoals QGIS, leaflet of OpenLayers."@nl, "Service public de téléchargement pour les infrastructures pour les jeunes. Utilisez ce service Web pour ajouter des calques de carte dans un visualiseur SIG tel que QGIS, un dépliant ou OpenLayers."@fr-t-nl, "Öffentlicher Download-Service für die Jugendinfrastruktur. Verwenden Sie diesen Webdienst, um Kartenebenen in einem GIS-Viewer wie QGIS, Flyer oder OpenLayers hinzuzufügen."@de-t-nl, "Public download service for youth infrastructure. Use this Web service to add map layers in a GIS viewer such as QGIS, leaflet or OpenLayers."@en-t-nl;
    <http://purl.org/dc/terms/modified> "2024-12-04"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/adms#identifier> _:b278578_b278577_b278576_df_12_70253;
