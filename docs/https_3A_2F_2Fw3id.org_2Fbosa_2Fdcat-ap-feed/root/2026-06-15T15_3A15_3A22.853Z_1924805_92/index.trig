    <http://www.w3.org/ns/dcat#keyword> "gebouw"@nl, "gebouweenheid"@nl, "identificatie"@nl, "levensloop"@nl, "geometrie"@nl, "actueel"@nl, "volledig"@nl, "kwaliteit"@nl, "authentieke bron"@nl, "integratie"@nl;
    <http://purl.org/dc/terms/subject> <http://inspire.ec.europa.eu/metadata-codelist/SpatialDataServiceCategory/infoMapAccessService>, <https://metadata.vlaanderen.be/id/GDI-Vlaanderen-Service-Types/OGCWMS>;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>;
    <http://www.w3.org/ns/dcat#landingPage> <https://www.vlaanderen.be/DataCatalogRecord/2c0a3d6a-59c8-00fa-14a6-08ce-8270-5329-a7db3c8e>;
    <http://www.w3.org/ns/dcat#endpointURL> <https://geo.api.vlaanderen.be/Gebouwenregister/wms>;
