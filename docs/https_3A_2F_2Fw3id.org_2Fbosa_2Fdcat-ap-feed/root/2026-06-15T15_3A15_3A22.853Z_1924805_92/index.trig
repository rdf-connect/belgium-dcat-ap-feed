    <http://www.w3.org/ns/dcat#keyword> "gebouw"@nl, "gebouweenheid"@nl, "identificatie"@nl, "levensloop"@nl, "geometrie"@nl, "actueel"@nl, "volledig"@nl, "kwaliteit"@nl, "authentieke bron"@nl, "integratie"@nl;
    <http://purl.org/dc/terms/subject> <http://inspire.ec.europa.eu/metadata-codelist/SpatialDataServiceCategory/infoFeatureAccessService>, <https://metadata.vlaanderen.be/id/GDI-Vlaanderen-Service-Types/OGCWFS>;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>;
    <http://www.w3.org/ns/dcat#landingPage> <https://www.vlaanderen.be/DataCatalogRecord/9c25f594-bd7a-8095-3d54-172d-6231-0389-b1585302>;
    <http://www.w3.org/ns/dcat#endpointURL> <https://geo.api.vlaanderen.be/Gebouwenregister/wfs>;
