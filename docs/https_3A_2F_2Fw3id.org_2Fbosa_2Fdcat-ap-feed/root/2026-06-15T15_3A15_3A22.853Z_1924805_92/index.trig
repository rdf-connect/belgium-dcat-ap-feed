    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg/2022/868/oj>;
    <http://www.w3.org/ns/dcat#keyword> "Persoon"@nl, "Kruispuntbank Sociale Zekerheid"@nl, "Rijksregister"@nl, "MAGDA"@nl;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/GOVE>;
