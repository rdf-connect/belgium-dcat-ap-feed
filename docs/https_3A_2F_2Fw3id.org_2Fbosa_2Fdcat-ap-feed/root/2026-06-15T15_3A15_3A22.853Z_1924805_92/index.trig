    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/IRREG>;
    <http://www.w3.org/ns/dcat#distribution> <http://data.gov.be/.well-known/genid/dist/brussels/9aa428db86c6b12595617707786a845f3c3df5df/2d4198a32e13b3c737fa85a10ae42921b518d4f9>, <http://data.gov.be/.well-known/genid/dist/brussels/9aa428db86c6b12595617707786a845f3c3df5df/1a22d89506fb1e1ad45cd88e3ed64d38fb39e03f>.
