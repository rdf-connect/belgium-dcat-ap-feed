<../../../index.trig> <https://w3id.org/tree#member> <#f083e5af9153630f04b33ab461b394ea>.
<#f083e5af9153630f04b33ab461b394ea> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://metadata.vlaanderen.be/srv/resources/services/ae6bd6c8-e6af-44e6-bc24-ff96437b6e75>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:38:07.752Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#f083e5af9153630f04b33ab461b394ea> {
<https://metadata.vlaanderen.be/srv/resources/services/ae6bd6c8-e6af-44e6-bc24-ff96437b6e75> a <http://www.w3.org/ns/dcat#DataService>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/NLD>;
    <http://purl.org/dc/terms/identifier> "ae6bd6c8-e6af-44e6-bc24-ff96437b6e75";
    <http://purl.org/dc/terms/title> "GIPOD Geplande Mobiliteitshinder - Publieke Informatie - LDES"@nl, "GIPOD Mobilité Prévue Pollution - Information Publique - LDES"@fr-t-nl, "GIPOD Planned Mobility Pollution - Öffentliche Informationen - LDES"@de-t-nl, "GIPOD Planned Mobility Pollution - Public Information - LDES"@en-t-nl;
    <http://purl.org/dc/terms/description> "GIPOD (Publieke Informatie) geeft een overzicht van alle concreet geplande en in uitvoering zijnde (grond)werken en evenementen op het openbaar domein met hun bijhorende omleidingen en verwachte mobiliteitshinder. Deze service bevat de geplande mobiliteitshinder en volgt de LDES specificatie."@nl, "GIPOD (Public Information) donne un aperçu de tous les travaux et événements concrets (terrestres) planifiés et en cours sur le domaine public avec leurs détournements associés et les nuisances de mobilité attendues. Ce service inclut les nuisances de mobilité prévues et suit la spécification LDES."@fr-t-nl, "GIPOD (Public Information) gibt einen Überblick über alle konkreten geplanten und laufenden (Boden-)Arbeiten und Veranstaltungen im öffentlichen Bereich mit den damit verbundenen Umleitungen und erwarteten Mobilitätsbeeinträchtigungen. Dieser Service beinhaltet die geplante Mobilitätsbelästigung und folgt der LDES-Spezifikation."@de-t-nl, "GIPOD (Public Information) gives an overview of all concrete planned and ongoing (ground)works and events on the public domain with their associated diversions and expected mobility nuisance. This service includes the planned mobility nuisance and follows the LDES specification."@en-t-nl;
    <http://www.w3.org/ns/dcat#version> "v1";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeEstablishmentUnit/2256180804>;
    <http://purl.org/dc/terms/conformsTo> <https://data.vlaanderen.be/id/concept/dataserviceprotocol/LDES>, <https://gipod.api.vlaanderen.be/api/v1/ldes/mobility-hindrances/shape>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://www.w3.org/ns/dcat#keyword> "LDES"@nl, "GIPOD"@nl, "Mobiliteitshinder"@nl, "Openbaar domein"@nl;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TRAN>, <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/REGI>;
    <http://www.w3.org/ns/dcat#landingPage> <https://www.vlaanderen.be/digitaal-vlaanderen/onze-oplossingen/generiek-informatieplatform-openbaar-domein-gipod>;
    <http://www.w3.org/ns/dcat#endpointURL> <https://gipod.api.vlaanderen.be/api/v1/ldes/mobility-hindrances>;
    <http://www.w3.org/ns/dcat#endpointDescription> <https://gipod.api.vlaanderen.be/swagger/index.html>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b278197_b278196_b278195_df_12_69972;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337388/>.
_:b278197_b278196_b278195_df_12_69972 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Agentschap Digitaal Vlaanderen";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:digitaal.vlaanderen@vlaanderen.be>;
    <http://www.w3.org/2006/vcard/ns#hasTelephone> <tel:+3292761500>
}
