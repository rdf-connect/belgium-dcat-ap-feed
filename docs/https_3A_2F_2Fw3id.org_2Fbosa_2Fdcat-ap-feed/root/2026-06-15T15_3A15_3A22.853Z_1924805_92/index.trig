    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg/2022/868/oj>;
    <http://www.w3.org/ns/dcat#keyword> "MAGDA"@nl, "kruispuntbank sociale zekerheid"@nl, "Rijksdienst voor Sociale Zekerheid"@nl, "werk"@nl;
