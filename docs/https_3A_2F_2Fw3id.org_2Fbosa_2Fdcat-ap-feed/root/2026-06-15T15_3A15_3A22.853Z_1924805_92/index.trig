<../../../index.trig> <https://w3id.org/tree#member> <#6fabb21828c8ead564a76847b63c41f0>.
<#6fabb21828c8ead564a76847b63c41f0> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://metadata.vlaanderen.be/srv/resources/services/643f8ab9-6701-4b8d-962f-c76a1f829254>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:38:08.508Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#6fabb21828c8ead564a76847b63c41f0> {
<https://metadata.vlaanderen.be/srv/resources/services/643f8ab9-6701-4b8d-962f-c76a1f829254> a <http://www.w3.org/ns/dcat#DataService>;
    <http://purl.org/dc/terms/identifier> "643f8ab9-6701-4b8d-962f-c76a1f829254";
    <http://purl.org/dc/terms/title> "Beschermde gebieden - Belgische Continentaal Plat Noordzee (WMS)"@nl, "Aires protégées - Plateau continental belge de la mer du Nord (WMS)"@fr-t-nl, "Schutzgebiete - Belgisches Nordsee-Kontinentalschelf (WMS)"@de-t-nl, "Protected areas - Belgian North Sea Continental Shelf (WMS)"@en-t-nl;
    <http://purl.org/dc/terms/description> "Drie speciale beschermingszones voor vogels: * een zone voor Koksijde, genaamd \"SBZ 1\" * een zone voor Oostende, genaamd \"SBZ 2\" * een zone voor Zeebrugge, genaamd \"SBZ 3\"Een speciale zone voor natuurbehoud: * een zone genaamd \"Trapegeer-Stroombankgebied\" * de zone «Trapegeer-Stroombank» is uitgebreid tot een nieuwe zone \"Vlaamse Banken\"Een gericht marien reservaat: * in de zeegebieden wordt een gericht marien reservaat ingesteldGeoreferentie-informatie:- Alle data is horizontaal gerefereerd in ETRS89/WGS84.INSPIRE Annex I thema Beschermingsgebieden"@nl, "Trois zones de protection spéciale pour les oiseaux: * une zone pour Koksijde, appelée \"SBZ 1\" * une zone pour Ostende, appelée \"SBZ 2\" * une zone pour Zeebrugge, appelée \"SBZ 3\" Une zone spéciale pour la conservation de la nature: * une zone appelée \"Trapegeer-Stroombankgebied\" * la zone \"Trapegeer-Stroombank\" a été étendue à une nouvelle zone \"Vlaamse Banken\"Une réserve marine ciblée: * une réserve marine ciblée est établie dans les zones maritimesInformations de référence:- Toutes les données sont référencées horizontalement dans ETRS89/WGS84.INSPIRE Annexe I Thème Zones de protection"@fr-t-nl, "Drei besondere Schutzgebiete für Vögel: * eine Zone für Koksijde, genannt \"SBZ 1\" * eine Zone für Ostende, genannt \"SBZ 2\" * eine Zone für Zeebrugge, genannt \"SBZ 3\" Eine Sonderzone für den Naturschutz: * eine Zone namens \"Trapegeer-Stroombankgebied\" * die Zone \"Trapegeer-Stroombank\" wurde um eine neue Zone \"Vlaamse Banken\" erweitertEin gezieltes Meeresschutzgebiet: * In den Meeresgebieten wird ein gezieltes Meeresschutzgebiet eingerichtetGeoreferenzinformationen:- Alle Daten werden horizontal in ETRS89/WGS84.INSPIRE Anhang I Themenschutzgebiete referenziert"@de-t-nl, "Three Special Protection Areas for birds: * a zone for Koksijde, called \"SBZ 1\" * a zone for Ostend, called \"SBZ 2\" * a zone for Zeebrugge, called \"SBZ 3\" A special zone for nature conservation: * a zone called \"Trapegeer-Stroombankgebied\" * the zone «Trapegeer-Stroombank» has been extended to a new zone \"Vlaamse Banken\"A targeted marine reserve: * a targeted marine reserve is established in the sea areasGeoreference information:- All data is horizontally referenced in ETRS89/WGS84.INSPIRE Annex I Theme Protection Areas"@en-t-nl;
    <http://purl.org/dc/terms/created> "2017-05-01"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/issued> "2017-05-08"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/adms#identifier> _:b278617_b278616_b278615_df_12_70279;
    <http://www.w3.org/ns/dcat#version> "1.3.0";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeEstablishmentUnit/2199336725>;
    <http://purl.org/dc/terms/conformsTo> <https://data.vlaanderen.be/id/concept/dataserviceprotocol/OGC:WMS-1.3.0-http-get-capabilities>, <https://data.vlaanderen.be/id/concept/dataserviceprotocol/OGC:WMS-1.3.0-http-get-map>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg/2010/1089/oj>;
    <http://www.w3.org/ns/dcat#keyword> "VLAAMSE OVERHEID, ZEEGEBIEDEN, NOORDZEE, BAGGERWERKEN, DIEPTEN, HYDROGRAFIE, BAGGERGRONDEN, BAGGERSPECIE, DIEPTEGEGEVENS, BAGGERWERK, BATHYMETRIE, VOOROEVER, VLAAMSE KUST, DIEPTEGEBIED, HOOGTEREFERENTIESYSTEEM, NAUTISCH, OBSTRUCTIES, TOEGANGSGEULEN, WRAKKEN, VLAAMSE HYDROGRAFIE, DIEPTECIJFERS, DIEPTEZONES, ELECTRONICAL NAVIGATION CHART, ELECTRONISCHE ZEEKAART VLAAMSE BANKEN, ENC, ENC VLAAMSE BANKEN, ZEEKAART, NATUURGEBIED"@nl, "Beschermde gebieden in het Belgisch Continentaal Plat (WMS)"@nl;
    <http://purl.org/dc/terms/subject> <http://inspire.ec.europa.eu/metadata-codelist/SpatialDataServiceCategory/infoMapAccessService>, <https://metadata.vlaanderen.be/id/GDI-Vlaanderen-Service-Types/OGCWMS>, <http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/regional>;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/REGI>;
    <http://www.w3.org/ns/dcat#landingPage> <https://www.vlaanderen.be/DataCatalogRecord/a2fa0123-c6ea-4c47-9501-35dba3dc864e>;
    <http://www.w3.org/ns/dcat#servesDataset> <https://metadata.vlaanderen.be/srv/resources/datasets/0b72ea96-3f9c-431e-be1e-24d7e7e28fde>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b278617_b278616_b278615_df_12_70280;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337388/>.
_:b278617_b278616_b278615_df_12_70279 a <http://www.w3.org/ns/adms#Identifier>;
    <http://www.w3.org/2004/02/skos/core#notation> "https://metadata.vlaanderen.be/srv/resources/services/643f8ab9-6701-4b8d-962f-c76a1f829254".
_:b278617_b278616_b278615_df_12_70280 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Marc Roesbeke"@nl, "Agentschap voor Maritieme Dienstverlening en Kust, Vlaamse Hydrografie"@nl, "Marc Roesbeke, Christiaan Schaep"@nl, "MDK - afdeling Kust"@nl;
    <http://www.w3.org/2006/vcard/ns#hasURL> <https://www.agentschapmdk.be/nl/vlaamse-hydrografie>;
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:ict.afdelingkust.mdk@mow.vlaanderen.be>
}
