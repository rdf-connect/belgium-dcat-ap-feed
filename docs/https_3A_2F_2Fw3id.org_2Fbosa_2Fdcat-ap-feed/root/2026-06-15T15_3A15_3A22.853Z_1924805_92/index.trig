<#c5b2d87f90cafbd5e1d76d30d74e1d81> {
<https://metadata.vlaanderen.be/srv/resources/services/efdf7f6d-23ea-4916-b254-ee57845e1f11> a <http://www.w3.org/ns/dcat#DataService>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/NLD>;
    <http://purl.org/dc/terms/identifier> "efdf7f6d-23ea-4916-b254-ee57845e1f11";
    <http://purl.org/dc/terms/title> "Werk - PubliceerDmfaVoorWerkneme - Versie 02.02"@nl, "Travail - PublishDmfaVoorWerkneme - Version 02.02"@fr-t-nl, "Arbeit - PublishDmfaVoorWerkneme - Version 02.02"@de-t-nl, "Work - PublishDmfaVoorWerkneme - Version 02.02"@en-t-nl;
    <http://purl.org/dc/terms/description> "Door middel van deze publicatie kunnen loon- en arbeidstijdgegevens van werknemers geraadpleegd worden. Deze publicatie is het resultaat van een semi-online opvraging via de webservice Werk.GeefDmfaVoorWerknemer-03.00."@nl, "Grâce à cette publication, les données sur les salaires et le temps de travail des employés peuvent être consultées. Cette publication est le résultat d'une recherche semi-en ligne via le service Web Werk.GeefDmfaVoorWerknemer-03.00."@fr-t-nl, "Mit dieser Veröffentlichung können Lohn- und Arbeitszeitdaten der Beschäftigten eingesehen werden. Diese Publikation ist das Ergebnis eines semi-online Abrufs über den Webservice Werk.GeefDmfaVoorWerknemer-03.00."@de-t-nl, "By means of this publication, wage and working time data of employees can be consulted. This publication is the result of a semi-online retrieval via the web service Werk.GeefDmfaVoorWerknemer-03.00."@en-t-nl;
    <http://www.w3.org/ns/adms#identifier> _:b278332_b278331_b278330_df_12_70069, _:b278332_b278331_b278330_df_12_70070;
    <http://www.w3.org/ns/dcat#version> "02.02";
