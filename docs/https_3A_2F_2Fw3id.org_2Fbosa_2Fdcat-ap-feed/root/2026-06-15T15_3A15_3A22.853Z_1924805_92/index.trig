<../../../index.trig> <https://w3id.org/tree#member> <#cbb8e02fe02ce711a0e6ecc0d970769f>.
<#cbb8e02fe02ce711a0e6ecc0d970769f> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://metadata.vlaanderen.be/srv/resources/services/aff9d815-361e-392f-9461-8d6b3a278e48>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:38:08.284Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#cbb8e02fe02ce711a0e6ecc0d970769f> {
<https://metadata.vlaanderen.be/srv/resources/services/aff9d815-361e-392f-9461-8d6b3a278e48> a <http://www.w3.org/ns/dcat#DataService>;
    <http://purl.org/dc/terms/identifier> "aff9d815-361e-392f-9461-8d6b3a278e48";
    <http://purl.org/dc/terms/title> "Atlas van de onbevaarbare waterlopen, editie 1950, Provincie Vlaams-Brabant (WMS)"@nl, "Atlas des cours d'eau non navigables, édition 1950, Province du Brabant flamand (WMS)"@fr-t-nl, "Atlas der unbefahrbaren Wasserläufe, Ausgabe 1950, Provinz Flämisch-Brabant (WMS)"@de-t-nl, "Atlas of the unnavigable watercourses, edition 1950, Province of Flemish Brabant (WMS)"@en-t-nl;
    <http://purl.org/dc/terms/description> "De Atlas van de onbevaarbare waterlopen is een boek met overzichts- en detailplannen die de juiste ligging weergeven van de waterlopen. Bij de atlas horen ook beschrijvende tabellen, waarin men per waterloop de naam, het nummer, de categorie, de opgemeten en de wettelijke afmetingen en een overzicht van de kunstwerken (bruggen, duikers, ...) kan vinden. Om de atlas gemakkelijker raadpleegbaar te maken, werd hij ingescand (2008) en werden de atlaspunten gedigitaliseerd."@nl, "L'Atlas des cours d'eau non navigables est un livre avec des plans d'ensemble et de détail qui montrent l'emplacement correct des cours d'eau. L'atlas comprend également des tableaux descriptifs, dans lesquels le nom, le nombre, la catégorie, les dimensions mesurées et légales et un aperçu des œuvres d'art (ponts, plongeurs, ...) peuvent être trouvés par cours d'eau. Pour faciliter la consultation de l'atlas, il a été scanné (2008) et les points de l'atlas ont été numérisés."@fr-t-nl, "Der Atlas der unbefahrbaren Wasserläufe ist ein Buch mit Übersichts- und Detailplänen, die die korrekte Lage der Wasserläufe zeigen. Der Atlas enthält auch beschreibende Tabellen, in denen Name, Anzahl, Kategorie, gemessene und rechtliche Abmessungen sowie ein Überblick über die Kunstwerke (Brücken, Taucher, ...) pro Wasserlauf zu finden sind. Um den Atlas leichter einsehbar zu machen, wurde er (2008) gescannt und die Atlaspunkte digitalisiert."@de-t-nl, "The Atlas of the Unnavigable Watercourses is a book with overview and detail plans that show the correct location of the watercourses. The atlas also includes descriptive tables, in which the name, number, category, measured and legal dimensions and an overview of the works of art (bridges, divers, ...) can be found per watercourse. To make the atlas easier to consult, it was scanned (2008) and the atlas points were digitised."@en-t-nl;
    <http://purl.org/dc/terms/modified> "2015-02-16"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/adms#identifier> _:b278497_b278496_b278495_df_12_70192;
    <http://www.w3.org/ns/dcat#version> "1.0";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeRegisteredEntity/0253973219>;
    <http://purl.org/dc/terms/conformsTo> <https://data.vlaanderen.be/id/concept/dataserviceprotocol/OGC:WMS>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg/2022/868/oj>;
    <http://purl.org/dc/terms/rights> <http://data.gov.be/.well-known/genid/rights/42099b4af021e53fd8fd4e056c2568d7c2e3ffa8>;
    <http://www.w3.org/ns/dcat#keyword> "Atlas der Waterlopen 1950 (WMS)"@nl;
    <http://purl.org/dc/terms/subject> <https://metadata.vlaanderen.be/id/GDI-Vlaanderen-Vlaamse-Administratieve-Eenheden/VlaamsBrabant>;
    <http://www.w3.org/ns/dcat#landingPage> <https://www.vlaanderen.be/DataCatalogRecord/11e2d9d1-8be3-45e6-af45-c4d9e89b1247>;
    <http://www.w3.org/ns/dcat#endpointURL> <https://geoservices.vlaamsbrabant.be/AtlasWaterlopen/MapServer/WMSServer>;
    <http://www.w3.org/ns/dcat#endpointDescription> <https://geoservices.vlaamsbrabant.be/AtlasWaterlopen/MapServer/WMSServer?>;
    <http://www.w3.org/ns/dcat#servesDataset> <https://metadata.vlaanderen.be/srv/resources/datasets/73b692bd-4a5e-4d78-9df5-0ca8475b0454>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b278497_b278496_b278495_df_12_70193;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3333250/>.
_:b278497_b278496_b278495_df_12_70192 a <http://www.w3.org/ns/adms#Identifier>;
    <http://www.w3.org/2004/02/skos/core#notation> "https://metadata.vlaanderen.be/srv/resources/services/aff9d815-361e-392f-9461-8d6b3a278e48".
_:b278497_b278496_b278495_df_12_70193 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Provincie Vlaams-Brabant"@nl, "Ireen Librecht"@nl;
    <http://www.w3.org/2006/vcard/ns#hasURL> <https://www.vlaamsbrabant.be>;
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:gis@vlaamsbrabant.be>
}
<../../../index.trig> <https://w3id.org/tree#member> <#051a23a3eb0563fea6b6072489081d2b>.
<#051a23a3eb0563fea6b6072489081d2b> a <https://www.w3.org/ns/activitystreams#Create>;
