<../../../index.trig> <https://w3id.org/tree#member> <#555bff8a4ca5fe2dbbd9d7d595f1ea37>.
<#555bff8a4ca5fe2dbbd9d7d595f1ea37> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://metadata.vlaanderen.be/srv/resources/services/e1953b7c-47b9-4de7-89bd-6565dc30526d>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:38:08.429Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#555bff8a4ca5fe2dbbd9d7d595f1ea37> {
<https://metadata.vlaanderen.be/srv/resources/services/e1953b7c-47b9-4de7-89bd-6565dc30526d> a <http://www.w3.org/ns/dcat#DataService>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/NLD>, <http://data.gov.be/.well-known/genid/e32d7fc3e84f4f2093cf4aca98a69781566-46b6e6e4e0f1e12e>;
    <http://purl.org/dc/terms/identifier> "e1953b7c-47b9-4de7-89bd-6565dc30526d";
    <http://purl.org/dc/terms/title> "DOSIS - DossierLaatsteImportResultaat"@nl, "DOSIS - DossierLaatsteImportResult"@fr-t-nl, "DOSIS - DossierLaatsteImportErgebnis"@de-t-nl, "DOSIS - DossierLaatsteImportResult"@en-t-nl;
    <http://purl.org/dc/terms/description> "DOSIS is een generieke bouwsteen dat de burger of onderneming op ieder moment een minimum status-overzicht geeft van zijn lopende dossiers bij een Vlaamse of lokale overheidsdienst. Van daaruit voorziet DOSIS de mogelijkheid om door te klikken naar het eigenlijke elektronische dossier op een digitaal loket van de bevoegde overheidsdienst. Via het Resultaat_GetLastImportResultaatByDossierIdentificatieAsync endpoint kan een dossierbeheerder binnen de eigen informatiebron het resultaat van de laatste verwerking in DOSIS opvragen voor het gekozen dossier (via dossiernummer)."@nl, "DOSIS est un bloc de construction générique qui donne au citoyen ou à l'entreprise à tout moment une vue d'ensemble minimale de ses dossiers actuels auprès d'un service gouvernemental flamand ou local. De là, DOSIS offre la possibilité de cliquer sur le fichier électronique réel sur un compteur numérique de l'administration publique compétente. Via le point de terminaison Result_GetLastImportResultByDossierIdentificationAsync, un gestionnaire de fichiers peut demander le résultat du dernier traitement dans DOSIS pour le fichier choisi (via le numéro de fichier) au sein de sa propre source d'informations."@fr-t-nl, "DOSIS ist ein allgemeiner Baustein, der dem Bürger oder Unternehmen jederzeit einen Mindeststatusüberblick über seine aktuellen Dateien bei einem flämischen oder kommunalen Dienst gibt. Von dort aus bietet DOSIS die Möglichkeit, sich auf einem digitalen Zähler der zuständigen öffentlichen Verwaltung in die eigentliche elektronische Akte durchzuklicken. Über den Endpunkt Result_GetLastImportResultByDossierIdentificationAsync kann ein Dateimanager das Ergebnis der letzten Verarbeitung in DOSIS für die gewählte Datei (über Dateinummer) innerhalb seiner eigenen Informationsquelle anfordern."@de-t-nl, "DOSIS is a generic building block that gives the citizen or company at any time a minimum status overview of his current files at a Flemish or local government service. From there, DOSIS provides the possibility to click through to the actual electronic file on a digital counter of the competent public administration. Via the Result_GetLastImportResultByDossierIdentificationAsync endpoint, a file manager can request the result of the last processing in DOSIS for the chosen file (via file number) within his own information source."@en-t-nl;
    <http://www.w3.org/ns/dcat#version> "V1";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeEstablishmentUnit/2256180804>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg/2022/868/oj>;
    <http://purl.org/dc/terms/rights> <http://data.gov.be/.well-known/genid/e32d7fc3e84f4f2093cf4aca98a69781566-46b6e6e4e0f1e130>;
    <http://www.w3.org/ns/dcat#keyword> "DOSIS"@nl, "Dossier"@nl, "Status"@nl, "Dossierbeheerder"@nl, "Notificatie"@nl, "IPDC"@nl, "Dossiernummer"@nl, "Wijzigingsdatum"@nl, "Doorverwijzing"@nl, "Mijn burgerProfiel"@nl, "Vlaio"@nl, "e-loket ondernemers"@nl, "Importresultaat"@nl;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/SOCI>;
    <http://www.w3.org/ns/dcat#landingPage> <https://prod.dosis-burgers.vlaanderen.be/>;
    <http://www.w3.org/ns/dcat#endpointURL> <https://prod.dosis-burgers.vlaanderen.be/api/swagger/index#!/Dossier/Dossier_Search>;
    <http://www.w3.org/ns/dcat#endpointDescription> <https://prod.dosis-burgers.vlaanderen.be/api>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b278572_b278571_b278570_df_12_70249;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337388/>.
_:b278572_b278571_b278570_df_12_70249 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "agentschap Digitaal Vlaanderen"@nl;
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "agentschap Digitaal Vlaanderen"@nl;
    <http://www.w3.org/2006/vcard/ns#hasURL> <https://www.vlaanderen.be/digitaal-vlaanderen>;
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:digitaal.vlaanderen@vlaanderen.be>;
    <http://www.w3.org/2006/vcard/ns#hasTelephone> <tel:+3292761500>
}
