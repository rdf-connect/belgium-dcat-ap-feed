<#0012c2f17caaba1e7748bfaf83907fc3> {
<https://metadata.vlaanderen.be/srv/resources/services/0601825a-1967-4281-8265-be0c5bbca78b> a <http://www.w3.org/ns/dcat#DataService>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/NLD>;
    <http://purl.org/dc/terms/identifier> "0601825a-1967-4281-8265-be0c5bbca78b";
    <http://purl.org/dc/terms/title> "Onderneming - ZoekOnderneming - Versie 02.00"@nl, "Entreprise - SearchCompany - Version 02.00"@fr-t-nl, "Unternehmen - SearchCompany - Version 02.00"@de-t-nl, "Company - SearchCompany - Version 02.00"@en-t-nl;
    <http://purl.org/dc/terms/description> "De webservice ZoekOnderneming-02.00 laat de gebruiker toe rechtstreeks bij KBO ondernemingen en vestigingen op te zoeken op basis van naam of adres."@nl, "Le service Web SearchCompany-02.00 permet à l'utilisateur de rechercher des entreprises et des succursales directement chez KBO en fonction du nom ou de l'adresse."@fr-t-nl, "Der Webdienst SearchCompany-02.00 ermöglicht es dem Benutzer, Unternehmen und Filialen direkt bei KBO nach Name oder Adresse zu suchen."@de-t-nl, "The web service SearchCompany-02.00 allows the user to search companies and branches directly at KBO based on name or address."@en-t-nl;
    <http://www.w3.org/ns/adms#identifier> _:b279028_b279027_b279026_df_12_70573, _:b279028_b279027_b279026_df_12_70574;
