    <http://purl.org/dc/terms/rights> <http://data.gov.be/.well-known/genid/e32d7fc3e84f4f2093cf4aca98a69781908-46b6e6e4e0f2cdf9>;
    <http://www.w3.org/ns/dcat#keyword> "AAPD"@nl, "FOD FIN"@nl, "kadaster"@nl, "MAGDA"@nl;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/REGI>, <http://publications.europa.eu/resource/authority/data-theme/GOVE>;
    <http://www.w3.org/ns/dcat#landingPage> <https://vlaamseoverheid.atlassian.net/wiki/spaces/MG/pages/1206583418/Kadaster.ZoekVerkoopprijzen-03.00>;
