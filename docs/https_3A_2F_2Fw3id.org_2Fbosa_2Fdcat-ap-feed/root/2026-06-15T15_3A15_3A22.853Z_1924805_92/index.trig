    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://www.w3.org/ns/dcat#keyword> "adressen"@nl, "geolocatie"@nl;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>;
    <http://www.w3.org/ns/dcat#landingPage> <https://www.vlaanderen.be/digitaal-vlaanderen/onze-oplossingen/geografische-webdiensten/ons-api-aanbod/geolocation-service>;
    <http://www.w3.org/ns/dcat#endpointURL> <https://geo.api.vlaanderen.be/Geolocation>;
    <http://www.w3.org/ns/dcat#endpointDescription> <https://www.vlaanderen.be/digitaal-vlaanderen/onze-oplossingen/geografische-webdiensten/ons-api-aanbod/geolocation-service>;
    <http://www.w3.org/ns/dcat#servesDataset> <https://metadata.vlaanderen.be/srv/resources/datasets/a8389246-ceed-45b7-a956-030e48b4a52c>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b278893_b278892_b278891_df_12_70475;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337388/>.
_:b278893_b278892_b278891_df_12_70474 a <http://www.w3.org/ns/adms#Identifier>;
