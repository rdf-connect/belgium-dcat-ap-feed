    <http://www.w3.org/ns/dcat#keyword> "kleurenorthofotomozaïek"@nl, "kleurenorthofoto's"@nl, "kleurenortho's"@nl, "luchtopnamen"@nl, "ortho"@nl, "orthofoto"@nl, "orthofotomozaïek"@nl, "orthofoto's"@nl, "ortho's"@nl, "Vlaams Gewest"@nl, "vliegdagcontour"@nl, "luchtfoto"@nl, "luchtfoto's"@nl, "middenschalig"@nl, "zomer"@nl, "open data"@nl, "kleur"@nl, "grijswaarden"@nl, "panchromatisch"@nl, "kleur-infrarood"@nl, "tijdreeks"@nl, "2021"@nl, "2018"@nl, "2015"@nl, "2012"@nl, "2009"@nl;
