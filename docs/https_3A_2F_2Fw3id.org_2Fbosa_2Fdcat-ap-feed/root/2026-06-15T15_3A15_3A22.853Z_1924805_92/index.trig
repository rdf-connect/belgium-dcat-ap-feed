<#db7dfa37f1ddbc5b85cd2d1f98522abb> {
<http://data.gov.be/.well-known/genid/dataset/brussels/ddec077a-3285-11f1-afcf-00090ffe0001> a <http://www.w3.org/ns/dcat#DataService>;
    <http://purl.org/dc/terms/identifier> "ddec077a-3285-11f1-afcf-00090ffe0001";
    <http://purl.org/dc/terms/title> "Geolocatiedienst - BeSt Address"@nl, "Service de géolocalisation – BeSt Address"@fr, "Geolocation service - BeSt Address"@en, "Geolokalisierungsservice - BeSt Adresse"@de-t-en;
    <http://purl.org/dc/terms/description> "Met de geolocatiedienst kun je adressen, straten of gemeenten vinden die zijn opgenomen in het gewestelijke adressenregister, of een adres dat zich het dichtst bij een paar cartografische coördinaten bevindt. De antwoorden worden gegenereerd volgens het BeSt Address-model."@nl, "Le service de géolocalisation permet de retrouver une adresse, une rue ou une commune reprise dans le registre régional d’adresses, ou de retrouver l’adresse la plus proche d’un couple de coordonnées cartographiques. Les réponses envoyées sont conformes au modèle BeSt Address."@fr, "The geolocation service enables you to find an address, street or municipality listed in the regional address register, or to find the nearest address to a pair of map coordinates. Responses are sent according to the BeSt Address model."@en, "Der Geolokalisierungsdienst ermöglicht es Ihnen, eine Adresse, Straße oder Gemeinde zu finden, die im regionalen Adressregister aufgeführt ist, oder die nächste Adresse zu einem Paar von Kartenkoordinaten zu finden. Die Antworten werden nach dem BeSt-Adressmodell gesendet."@de-t-en;
    <http://purl.org/dc/terms/modified> "2026-04-07T14:44:46.000Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeRegisteredEntity/0240678477>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/subject> <http://eurovoc.europa.eu/5120>, <http://inspire.ec.europa.eu/theme/ad>, <http://inspire.ec.europa.eu/theme/gn>, <http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/regional>, <http://inspire.ec.europa.eu/metadata-codelist/SpatialDataServiceCategory/spatialPositioningService>;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/REGI>;
    <http://www.w3.org/ns/dcat#landingPage> <https://datastore.brussels/web/data/service/ddec077a-3285-11f1-afcf-00090ffe0001>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b277837_b277836_b277835_df_12_69772;
