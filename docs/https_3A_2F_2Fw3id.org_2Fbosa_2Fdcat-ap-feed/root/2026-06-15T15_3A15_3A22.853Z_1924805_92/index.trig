    <http://www.w3.org/ns/dcat#contactPoint> _:b278023_b278022_b278021_df_12_69849;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337388/>.
_:b278023_b278022_b278021_df_12_69848 a <http://www.w3.org/ns/adms#Identifier>;
