    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg/2022/868/oj>;
    <http://purl.org/dc/terms/rights> <http://data.gov.be/.well-known/genid/e32d7fc3e84f4f2093cf4aca98a69781548-46b6e6e4e0f1d36d>;
    <http://www.w3.org/ns/dcat#keyword> "Wonen Vlaanderen"@nl, "VLOK"@nl, "MAGDA"@nl, "Woningkwaliteit"@nl;
    <http://www.w3.org/ns/dcat#landingPage> <https://vlaamseoverheid.atlassian.net/wiki/spaces/MG/pages/1004835685/Vlok.GeefWoningKwaliteit-02.00>;
