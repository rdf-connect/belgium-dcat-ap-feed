<../../../index.trig> <https://w3id.org/tree#member> <#5fdc47d183028f21402a73590d91f4d1>.
<#5fdc47d183028f21402a73590d91f4d1> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://data.gov.be/.well-known/genid/dataset/brussels/e36141f3-088b-11f0-baa8-00090ffe0001>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:38:07.035Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#5fdc47d183028f21402a73590d91f4d1> {
<http://data.gov.be/.well-known/genid/dataset/brussels/e36141f3-088b-11f0-baa8-00090ffe0001> a <http://www.w3.org/ns/dcat#DataService>;
    <http://purl.org/dc/terms/identifier> "e36141f3-088b-11f0-baa8-00090ffe0001";
    <http://purl.org/dc/terms/title> "Downloaddienst - Stadsvernieuwing in het Brussels Hoofdstedelijk Gewest"@nl, "Service de téléchargement – Rénovation urbaine en région de Bruxelles-Capitale"@fr, "Download service - Urban renewal in the Brussels-Capital Region"@en, "Download-Service - Stadterneuerung in der Region Brüssel-Hauptstadt"@de-t-en;
    <http://purl.org/dc/terms/description> "Die downloaddienst laat toe om, door middel van een geformatteerde URL, elk object van de vectorbestanden die verband houden met de gebieden voor stadsvernieuwingsprogramma’s en -acties gefinancierd door het Brussels Hoofdstedelijk Gewest (duurzame wijkcontracten, stadsvernieuwingscontracten) en op de gebieden met voorkooprecht, te downloaden."@nl, "Ce service de téléchargement permet, au moyen d'une URL formatée, de télécharger chaque objet des jeux de données vectoriels portant sur les périmètres des programmes et des opérations de rénovation urbaine financés par la Région de Bruxelles-Capitale (contrats de quartiers durables, contrats de rénovation urbaine) ainsi que sur les périmètres de préemption en vigueur."@fr, "This download service allows, by means of a formatted URL, to download any object of the vectorial datasets related to the perimeters of programs and urban renewal operations financed by the Brussels-Capital Region (sustainable neighborhood contracts, urban renewal contracts) as well as to the current preemption perimeters."@en, "Dieser Download-Dienst ermöglicht es, mittels einer formatierten URL jedes Objekt der vektoriellen Datensätze herunterzuladen, die sich auf die Grenzen der von der Region Brüssel-Hauptstadt finanzierten Programme und Stadterneuerungsmaßnahmen (nachhaltige Nachbarschaftsverträge, Stadterneuerungsverträge) sowie auf die aktuellen Vorzugsgrenzen beziehen."@de-t-en;
    <http://purl.org/dc/terms/modified> "2025-12-09T17:18:52.000Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeRegisteredEntity/0240678477>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/subject> <http://eurovoc.europa.eu/3281>, <http://eurovoc.europa.eu/1695>, <http://eurovoc.europa.eu/c_f831f088>, <http://eurovoc.europa.eu/847>, <http://www.eionet.europa.eu/gemet/concept/4666>, <http://www.eionet.europa.eu/gemet/concept/6285>, <http://www.eionet.europa.eu/gemet/concept/8839>, <http://inspire.ec.europa.eu/theme/us>, <http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/regional>, <http://inspire.ec.europa.eu/metadata-codelist/SpatialDataServiceCategory/infoFeatureAccessService>;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/REGI>;
    <http://www.w3.org/ns/dcat#landingPage> <https://datastore.brussels/web/data/service/e36141f3-088b-11f0-baa8-00090ffe0001>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b277762_b277761_b277760_df_12_69747;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/IRREG>;
    <http://www.w3.org/ns/dcat#distribution> <http://data.gov.be/.well-known/genid/dist/brussels/a59093947e0544983fa6372e88491e8ff8ac00b8/5119e69463938f7713593781fe447c73a9242345>.
_:b277762_b277761_b277760_df_12_69747 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Paradigm"@nl, "Paradigm"@fr, "Paradigm"@en;
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:irisline@paradigm.brussels>
}
<../../../index.trig> <https://w3id.org/tree#member> <#cd575fb8938d2b002dc0b0adfc6221d1>.
<#cd575fb8938d2b002dc0b0adfc6221d1> a <https://www.w3.org/ns/activitystreams#Create>;
