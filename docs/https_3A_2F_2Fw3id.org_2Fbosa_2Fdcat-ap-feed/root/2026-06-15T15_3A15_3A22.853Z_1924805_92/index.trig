    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:38:09.342Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#1c971e76892deb131616c68348f24148> {
<https://metadata.vlaanderen.be/srv/resources/services/21fe103b-c01d-416d-8c19-c5b82ae00461> a <http://www.w3.org/ns/dcat#DataService>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/NLD>;
    <http://purl.org/dc/terms/identifier> "21fe103b-c01d-416d-8c19-c5b82ae00461";
    <http://purl.org/dc/terms/title> "Onderneming - GeefBeschikbareJaarrekeningen - Versie 02.00"@nl, "Entreprise - GiveAvailableComptes annuels - Version 02.00"@fr-t-nl, "Unternehmen - GiveAvailableJahreskonten - Version 02.00"@de-t-nl, "Company - GiveAvailableAnnual Accounts - Version 02.00"@en-t-nl;
    <http://purl.org/dc/terms/description> "De GeefBeschikbareJaarrekeningen 02.00 businessdienst maakt het mogelijk om op basis van een ondernemingsnummer een overzicht van de beschikbare jaarrekeningen te verkrijgen. Van de jaarrekeningen komen enkel de hoofdingen terug evenals de neerleggingsdatums. Om de jaarrekeningelementen op te vragen dient men een oproep uit te voeren via de GeefJaarrekeningen 02.00."@nl, "Le service GiveAvailableAnnual Accounts 02.00 business permet d'obtenir un aperçu des comptes annuels disponibles sur la base d'un numéro d'entreprise. Parmi les comptes annuels, seules les rubriques et les dates de dépôt sont renvoyées. Pour demander les éléments des états financiers, un appel doit être effectué via les comptes annuels 02h00."@fr-t-nl, "Der Geschäftsdienst GiveAvailableAnnual Accounts 02.00 ermöglicht es, sich anhand einer Firmennummer einen Überblick über die verfügbaren Jahresabschlüsse zu verschaffen. Von den Jahresabschlüssen werden nur die Überschriften und die Anmeldedaten zurückgegeben. Um die Abschlussbestandteile anzufordern, muss eine Aufforderung über den Jahresabschluss 02.00 erfolgen."@de-t-nl, "The GiveAvailableAnnual Accounts 02.00 business service makes it possible to obtain an overview of the available annual accounts on the basis of a company number. Of the annual accounts, only the headings and the filing dates are returned. To request the financial statements elements, a call must be made via the Annual Accounts 02.00."@en-t-nl;
    <http://www.w3.org/ns/adms#identifier> _:b278977_b278976_b278975_df_12_70539, _:b278977_b278976_b278975_df_12_70540;
    <http://www.w3.org/ns/dcat#version> "02.00";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeEstablishmentUnit/2256180804>;
    <http://purl.org/dc/terms/creator> <https://org.belgif.be/id/CbeEstablishmentUnit/2256180804>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg/2022/868/oj>;
    <http://www.w3.org/ns/dcat#keyword> "Integrator"@nl, "NBB"@nl, "MAGDA"@nl, "KBO"@nl, "VKBO"@nl, "Onderneming"@nl;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ECON>, <http://publications.europa.eu/resource/authority/data-theme/GOVE>;
    <http://www.w3.org/ns/dcat#landingPage> <https://vlaamseoverheid.atlassian.net/wiki/spaces/MG/pages/500007836/Onderneming.GeefBeschikbareJaarrekeningen-02.00>;
    <http://www.w3.org/ns/dcat#endpointDescription> <https://vlaamseoverheid.atlassian.net/wiki/spaces/MG/pages/500007836/Onderneming.GeefBeschikbareJaarrekeningen-02.00>;
