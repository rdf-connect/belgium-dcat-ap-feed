<../../../index.trig> <https://w3id.org/tree#member> <#35e02899c33ab4b70f289b0c75926701>.
<#35e02899c33ab4b70f289b0c75926701> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://metadata.vlaanderen.be/srv/resources/services/c5f0b4d1-d854-4a8f-943e-9f34bece3bce>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:38:09.347Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#35e02899c33ab4b70f289b0c75926701> {
<https://metadata.vlaanderen.be/srv/resources/services/c5f0b4d1-d854-4a8f-943e-9f34bece3bce> a <http://www.w3.org/ns/dcat#DataService>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/NLD>;
    <http://purl.org/dc/terms/identifier> "c5f0b4d1-d854-4a8f-943e-9f34bece3bce";
    <http://purl.org/dc/terms/title> "Adressenregister - Adressen"@nl, "Registre des adresses - Adresses"@fr-t-nl, "Adressregister - Adressen"@de-t-nl, "Register of addresses - Addresses"@en-t-nl;
    <http://purl.org/dc/terms/description> "Het Adressenregister voorziet de adresseerbare objecten in het Gebouwenregister van adressen en de wegen in het Wegenregister van straatnamen. De bevoegdheid voor adres- en straatnaamtoekenningen ligt bij de 300 Vlaamse gemeenten (bij CRAB-decreet). Het Adressenregister zal dan ook op middellange termijn het CRAB als authentieke bron voor adressen vervangen."@nl, "Le registre des adresses fournit les objets adressables dans le registre des bâtiments avec les adresses et les routes dans le registre routier des noms de rues. Les attributions d'adresse et de nom de rue relèvent de la compétence des 300 communes flamandes (par décret CRAB). Le registre des adresses remplacera donc le CRAB en tant que source authentique d’adresses à moyen terme."@fr-t-nl, "Das Adressregister stellt die adressierbaren Objekte im Gebäuderegister mit Adressen und Straßen im Straßenregister der Straßennamen zur Verfügung. Die Zuständigkeit für die Vergabe von Adressen und Straßennamen liegt bei den 300 flämischen Gemeinden (durch CRAB-Dekret). Das Adressregister wird daher mittelfristig an die Stelle des CRAB als authentische Adressquelle treten."@de-t-nl, "The Register of Addresses provides the addressable objects in the Buildings Register with addresses and the roads in the Road Register of street names. The competence for address and street name assignments lies with the 300 Flemish municipalities (by CRAB decree). The Register of Addresses will therefore replace the CRAB as an authentic source for addresses in the medium term."@en-t-nl;
    <http://www.w3.org/ns/adms#identifier> _:b278980_b278979_b278978_df_12_70542;
    <http://www.w3.org/ns/dcat#version> "1";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeEstablishmentUnit/2256180804>;
    <http://purl.org/dc/terms/creator> <https://org.belgif.be/id/CbeEstablishmentUnit/2256180804>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://www.w3.org/ns/dcat#keyword> "Adressen"@nl;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>;
    <http://www.w3.org/ns/dcat#landingPage> <https://overheid.vlaanderen.be/producten-diensten/gebouwen-adressenregister>;
    <http://www.w3.org/ns/dcat#endpointURL> <https://api.basisregisters.vlaanderen.be/v2/adressen/>;
    <http://www.w3.org/ns/dcat#endpointDescription> <https://docs.basisregisters.vlaanderen.be/docs/api-documentation.html#tag/Adressen>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b278980_b278979_b278978_df_12_70543;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337388/>.
_:b278980_b278979_b278978_df_12_70542 a <http://www.w3.org/ns/adms#Identifier>;
    <http://www.w3.org/2004/02/skos/core#notation> "https://metadata.vlaanderen.be/doc/service/c5f0b4d1-d854-4a8f-943e-9f34bece3bce".
_:b278980_b278979_b278978_df_12_70543 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Helpdesk Digitaal Vlaanderen", "agentschap Digitaal Vlaanderen"@nl;
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "agentschap Digitaal Vlaanderen"@nl;
    <http://www.w3.org/2006/vcard/ns#hasURL> <https://www.vlaanderen.be/digitaal-vlaanderen>;
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:digitaal.vlaanderen@vlaanderen.be>
}
