<../../../index.trig> <https://w3id.org/tree#member> <#53101addef6bfda59dd5ff910cdb71c6>.
<#53101addef6bfda59dd5ff910cdb71c6> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://metadata.vlaanderen.be/srv/resources/services/4343536c-aea8-4026-876c-151c39bfa4a0>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:38:09.574Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#53101addef6bfda59dd5ff910cdb71c6> {
<https://metadata.vlaanderen.be/srv/resources/services/4343536c-aea8-4026-876c-151c39bfa4a0> a <http://www.w3.org/ns/dcat#DataService>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/NLD>, <http://data.gov.be/.well-known/genid/e32d7fc3e84f4f2093cf4aca98a697811019-46b6e6e4e0f32092>;
    <http://purl.org/dc/terms/identifier> "4343536c-aea8-4026-876c-151c39bfa4a0";
    <http://purl.org/dc/terms/title> "DOSIS - VerwijderDossier"@nl, "DOSIS - Supprimer le fichier"@fr-t-nl, "DOSIS - Datei löschen"@de-t-nl, "DOSIS - Delete File"@en-t-nl;
    <http://purl.org/dc/terms/description> "DOSIS is een generieke bouwsteen dat de burger of onderneming op ieder moment een minimum status-overzicht geeft van zijn lopende dossiers bij een Vlaamse of lokale overheidsdienst. Van daaruit voorziet DOSIS de mogelijkheid om door te klikken naar het eigenlijke elektronische dossier op een digitaal loket van de bevoegde overheidsdienst. Via het Dossier_Delete endpoint kan een dossierbeheerder binnen de eigen informatiebron dossierstatus informatie verwijderen."@nl, "DOSIS est un bloc de construction générique qui donne au citoyen ou à l'entreprise à tout moment une vue d'ensemble minimale de ses dossiers actuels auprès d'un service gouvernemental flamand ou local. De là, DOSIS offre la possibilité de cliquer sur le fichier électronique réel sur un compteur numérique de l'administration publique compétente. Le point de terminaison File_Delete permet à un gestionnaire de fichiers de supprimer des informations d'état de fichier dans sa propre source d'informations."@fr-t-nl, "DOSIS ist ein allgemeiner Baustein, der dem Bürger oder Unternehmen jederzeit einen Mindeststatusüberblick über seine aktuellen Dateien bei einem flämischen oder kommunalen Dienst gibt. Von dort aus bietet DOSIS die Möglichkeit, sich auf einem digitalen Zähler der zuständigen öffentlichen Verwaltung in die eigentliche elektronische Akte durchzuklicken. Der File_Delete-Endpunkt ermöglicht es einem Dateimanager, Dateistatusinformationen innerhalb seiner eigenen Informationsquelle zu löschen."@de-t-nl, "DOSIS is a generic building block that gives the citizen or company at any time a minimum status overview of his current files at a Flemish or local government service. From there, DOSIS provides the possibility to click through to the actual electronic file on a digital counter of the competent public administration. The File_Delete endpoint allows a file manager to delete file status information within their own information source."@en-t-nl;
    <http://www.w3.org/ns/dcat#version> "V1";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeEstablishmentUnit/2256180804>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg/2022/868/oj>;
    <http://purl.org/dc/terms/rights> <http://data.gov.be/.well-known/genid/e32d7fc3e84f4f2093cf4aca98a697811019-46b6e6e4e0f32096>;
    <http://www.w3.org/ns/dcat#keyword> "DOSIS"@nl, "Dossier"@nl, "Status"@nl, "Dossierbeheerder"@nl, "Notificatie"@nl, "IPDC"@nl, "Dossiernummer"@nl, "Wijzigingsdatum"@nl, "Doorverwijzing"@nl, "Mijn burgerProfiel"@nl, "Verwijderen"@nl, "Vlaio"@nl, "e-loket ondernemers"@nl;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/SOCI>;
    <http://www.w3.org/ns/dcat#landingPage> <https://prod.dosis-burgers.vlaanderen.be/>;
    <http://www.w3.org/ns/dcat#endpointURL> <https://prod.dosis-burgers.vlaanderen.be/api/swagger/index#!/Dossier/Dossier_Delete>;
    <http://www.w3.org/ns/dcat#endpointDescription> <https://prod.dosis-burgers.vlaanderen.be/api>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b279061_b279060_b279059_df_12_70600;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337388/>.
_:b279061_b279060_b279059_df_12_70600 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "agentschap Digitaal Vlaanderen"@nl;
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "agentschap Digitaal Vlaanderen"@nl;
    <http://www.w3.org/2006/vcard/ns#hasURL> <https://www.vlaanderen.be/digitaal-vlaanderen>;
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:digitaal.vlaanderen@vlaanderen.be>;
    <http://www.w3.org/2006/vcard/ns#hasTelephone> <tel:+3292761500>
}
