_:b278416_b278415_b278414_df_12_70136 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Marc Roesbeke"@nl, "Agentschap voor Maritieme Dienstverlening en Kust, Vlaamse Hydrografie"@nl, "Marc Roesbeke, Christiaan Schaep"@nl, "MDK - afdeling Kust"@nl;
    <http://www.w3.org/2006/vcard/ns#hasURL> <https://www.agentschapmdk.be/nl/vlaamse-hydrografie>;
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:ict.afdelingkust.mdk@mow.vlaanderen.be>
