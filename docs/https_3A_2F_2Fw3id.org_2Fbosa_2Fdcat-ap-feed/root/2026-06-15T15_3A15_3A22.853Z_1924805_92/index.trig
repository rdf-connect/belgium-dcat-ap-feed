    <http://www.w3.org/ns/dcat#contactPoint> _:b278086_b278085_b278084_df_12_69898;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337388/>.
_:b278086_b278085_b278084_df_12_69896 a <http://www.w3.org/ns/adms#Identifier>;
    <http://www.w3.org/2004/02/skos/core#notation> "https://metadata.vlaanderen.be/srv/doc/service/f74efb28-c377-4650-bd1f-8091b983f2df".
_:b278086_b278085_b278084_df_12_69897 a <http://www.w3.org/ns/adms#Identifier>;
