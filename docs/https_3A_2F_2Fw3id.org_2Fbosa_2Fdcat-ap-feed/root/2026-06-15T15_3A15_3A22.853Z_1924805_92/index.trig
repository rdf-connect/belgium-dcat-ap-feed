    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg/2022/868/oj>;
    <http://www.w3.org/ns/dcat#keyword> "Integrator"@nl, "KBO"@nl, "Onderneming"@nl, "VKBO"@nl, "Graydon"@nl, "MAGDA"@nl;
