<#00347b533318c33d349863a89e9fb63f> {
<https://metadata.vlaanderen.be/srv/resources/services/50789ab0-f838-4d9a-916f-c38dc6e3c908> a <http://www.w3.org/ns/dcat#DataService>;
    <http://purl.org/dc/terms/identifier> "50789ab0-f838-4d9a-916f-c38dc6e3c908";
    <http://purl.org/dc/terms/title> "Verkeersscheidingsstelsels en vaarroutes op zee en naar de havens (WFS)"@nl, "Systèmes de séparation du trafic et routes maritimes en mer et vers les ports (WFS)"@fr-t-nl, "Verkehrstrennungssysteme und Schifffahrtsrouten auf See und zu Häfen (WFS)"@de-t-nl, "Traffic separation systems and shipping routes at sea and to ports (WFS)"@en-t-nl;
    <http://purl.org/dc/terms/description> "De verkeersscheidingsstelsels in het Belgisch Continentaal Plat zijn internationaal vastgestelde scheepvaartroutes met gescheiden verkeersbanen voor het scheepvaartverkeer op de Noordzee.Georeferentie-informatie:- Alle data is horizontaal gerefereerd in ETRS89/WGS84. INSPIRE Annex I thema Vervoersnetwerken"@nl, "Les systèmes de séparation du trafic sur le plateau continental belge sont des routes maritimes établies au niveau international avec des voies de trafic distinctes pour le trafic maritime en mer du Nord.Informations de géoréférence:- Toutes les données sont mentionnées horizontalement dans ETRS89/WGS84. INSPIRE Annexe I Thème Réseaux de transport"@fr-t-nl, "Die Verkehrstrennungssysteme im belgischen Festlandsockel sind international etablierte Schifffahrtsrouten mit separaten Fahrspuren für den Schiffsverkehr in der Nordsee.Georeferenzinformationen:- Alle Daten werden in ETRS89/WGS84 horizontal referenziert. INSPIRE Anhang I Thema Verkehrsnetze"@de-t-nl, "The traffic separation systems in the Belgian Continental Shelf are internationally established shipping routes with separate traffic lanes for shipping traffic on the North Sea.Georeference information:- All data is referred to horizontally in ETRS89/WGS84. INSPIRE Annex I Theme Transport networks"@en-t-nl;
    <http://purl.org/dc/terms/issued> "2020-11-09"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/adms#identifier> _:b278383_b278382_b278381_df_12_70111;
    <http://www.w3.org/ns/dcat#version> "2.0.0";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeEstablishmentUnit/2199336725>;
    <http://purl.org/dc/terms/conformsTo> <https://data.vlaanderen.be/id/concept/dataserviceprotocol/OGC:WFS-1.0.0-http-get-capabilities>, <https://data.vlaanderen.be/id/concept/dataserviceprotocol/OGC:WFS-1.0.0-http-get-feature>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg/2010/1089/oj>;
    <http://www.w3.org/ns/dcat#keyword> "VLAAMSE OVERHEID, ZEEGEBIEDEN, NOORDZEE, BAGGERWERKEN, DIEPTEN, HYDROGRAFIE, BAGGERGRONDEN, BAGGERSPECIE, DIEPTEGEGEVENS, BAGGERWERK, BATHYMETRIE, VOOROEVER, VLAAMSE KUST, DIEPTEGEBIED, HOOGTEREFERENTIESYSTEEM, NAUTISCH, OBSTRUCTIES, TOEGANGSGEULEN, WRAKKEN, VLAAMSE HYDROGRAFIE, DIEPTECIJFERS, DIEPTEZONES, ELECTRONICAL NAVIGATION CHART, ELECTRONISCHE ZEEKAART VLAAMSE BANKEN, ENC, ENC VLAAMSE BANKEN, ZEEKAART"@nl, "Verkeersscheidingsstelsels en vaarroutes in het Belgisch Continentaal Plat (WFS)"@nl;
    <http://purl.org/dc/terms/subject> <http://inspire.ec.europa.eu/metadata-codelist/SpatialDataServiceCategory/infoFeatureAccessService>, <https://metadata.vlaanderen.be/id/GDI-Vlaanderen-Service-Types/OGCWFS>, <http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/regional>;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/REGI>;
    <http://www.w3.org/ns/dcat#landingPage> <https://www.vlaanderen.be/DataCatalogRecord/873a92b0-8508-4f8e-a71d-7a2b6741cc21>;
    <http://www.w3.org/ns/dcat#servesDataset> <https://metadata.vlaanderen.be/srv/resources/datasets/50b69083-c4e6-4802-9614-d2d91675a71a>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b278383_b278382_b278381_df_12_70112;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337388/>.
_:b278383_b278382_b278381_df_12_70111 a <http://www.w3.org/ns/adms#Identifier>;
