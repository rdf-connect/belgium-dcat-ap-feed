    <http://purl.org/dc/terms/conformsTo> <https://data.vlaanderen.be/id/concept/dataserviceprotocol/OGC:WFS>, <https://data.vlaanderen.be/id/concept/dataserviceprotocol/OGC:WFS-2.0.0-http-get-capabilities>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg/2022/868/oj>;
    <http://purl.org/dc/terms/rights> <http://data.gov.be/.well-known/genid/rights/42099b4af021e53fd8fd4e056c2568d7c2e3ffa8>;
    <http://www.w3.org/ns/dcat#keyword> "ABW wijzigingen (WFS)"@nl;
    <http://purl.org/dc/terms/subject> <https://metadata.vlaanderen.be/id/GDI-Vlaanderen-Vlaamse-Administratieve-Eenheden/VlaamsBrabant>;
    <http://www.w3.org/ns/dcat#landingPage> <https://www.vlaanderen.be/DataCatalogRecord/c780151b-e0c8-4484-9500-8852d664cd39>;
    <http://www.w3.org/ns/dcat#endpointURL> <https://geoservices.vlaamsbrabant.be/AtlasBuurtwegen_wijzigingen/MapServer/WFSServer>;
    <http://www.w3.org/ns/dcat#endpointDescription> <https://geoservices.vlaamsbrabant.be/AtlasBuurtwegen_wijzigingen/MapServer/WFSServer?>;
    <http://www.w3.org/ns/dcat#servesDataset> <https://metadata.vlaanderen.be/srv/resources/datasets/ae983f25-7712-4513-8985-a73e64afc207>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b278182_b278181_b278180_df_12_69962;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3333250/>.
_:b278182_b278181_b278180_df_12_69961 a <http://www.w3.org/ns/adms#Identifier>;
    <http://www.w3.org/2004/02/skos/core#notation> "https://metadata.vlaanderen.be/srv/resources/services/c6b9ed24-9528-3565-bfdd-86210eaa1b81".
_:b278182_b278181_b278180_df_12_69962 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Provincie Vlaams-Brabant"@nl, "Ireen Librecht"@nl;
    <http://www.w3.org/2006/vcard/ns#hasURL> <https://www.vlaamsbrabant.be>;
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:gis@vlaamsbrabant.be>
}
