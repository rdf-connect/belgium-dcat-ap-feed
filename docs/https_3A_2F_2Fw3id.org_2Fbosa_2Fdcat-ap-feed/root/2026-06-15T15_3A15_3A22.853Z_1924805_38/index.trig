<#36bdc4fc5d315b5965489c97a7e21d52> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://metadata.vlaanderen.be/srv/resources/distributions/40e65e02-d4a6-4f4e-a1bd-3706b90b9a25>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:34:21.728Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#36bdc4fc5d315b5965489c97a7e21d52> {
<https://metadata.vlaanderen.be/srv/resources/distributions/40e65e02-d4a6-4f4e-a1bd-3706b90b9a25> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/NLD>;
    <http://purl.org/dc/terms/identifier> "40e65e02-d4a6-4f4e-a1bd-3706b90b9a25";
    <http://purl.org/dc/terms/title> "Kengetallen gewasbeschermingsgebruik in de Vlaamse landbouw"@nl;
    <http://purl.org/dc/terms/description> "De tabel geeft het gewasbeschermingsgebruik per ha en jaar weer voor 15 gewasgroepen. De invloed van het weer is in deze kengetallen afgevlakt door een voortschrijdend gewogen gemiddelde te nemen over drie jaar. Hierbij worden de oppervlakten van de gewassen die niet behandeld zijn meegerekend. Aangezien de opdeling van de producten of ze al dan niet toegelaten zijn in de biologische landbouw pas beschikbaar is vanaf 2014, start de tijdsreeks vanaf 2014. Via de knop 'download data' onder de tabel kan u de data van alle gewassen in een keer downloaden."@nl;
    <http://www.w3.org/ns/dcat#mediaType> <https://www.iana.org/assignments/media-types/text/csv>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/CSV>;
    <http://www.w3.org/ns/dcat#accessURL> <https://metadata.vlaanderen.be/srv/dut/catalog.search#/metadata/3126bed0-5f76-47b6-9faf-24266365f4ad>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://landbouwcijfers.vlaanderen.be/landbouw/totale-landbouw/gewasbescherming-kengetallen>;
    <http://purl.org/dc/terms/license> <http://data.vlaanderen.be/id/licentie/modellicentie-gratis-hergebruik/v1.0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>
}
