<http://data.gov.be/.well-known/genid/dist/brussels/3106e0ae034f0a91cb94c103362b539afdda94e8/51073b2cf2ccbe12c9a8ca65d27fafc4551dce34> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/title> "Daschboard Beschermde klanten"@nl, "Daschboard Beschermde klanten"@fr, "Daschboard Beschermde klanten"@en;
    <http://purl.org/dc/terms/description> "Dit dashboard bevat de recentste beschikbare gegevens over de evolutie van de sociale indicatoren van de elektriciteits- en gasmarkt in het Brussels Hoofdstedelijk Gewest. Het verzamelt de gegevens met betrekking tot de door BRUGEL behandelde aanvragen voor het statuut van beschermde klant. Het stelt de gebruiker in staat om in een paar pagina's de meest relevante informatie te bekijken."@nl, "Dit dashboard bevat de recentste beschikbare gegevens over de evolutie van de sociale indicatoren van de elektriciteits- en gasmarkt in het Brussels Hoofdstedelijk Gewest. Het verzamelt de gegevens met betrekking tot de door BRUGEL behandelde aanvragen voor het statuut van beschermde klant. Het stelt de gebruiker in staat om in een paar pagina's de meest relevante informatie te bekijken."@fr, "Dit dashboard bevat de recentste beschikbare gegevens over de evolutie van de sociale indicatoren van de elektriciteits- en gasmarkt in het Brussels Hoofdstedelijk Gewest. Het verzamelt de gegevens met betrekking tot de door BRUGEL behandelde aanvragen voor het statuut van beschermde klant. Het stelt de gebruiker in staat om in een paar pagina's de meest relevante informatie te bekijken."@en;
    <http://www.w3.org/ns/dcat#mediaType> <https://www.iana.org/assignments/media-types/text/xml>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/XML>;
    <http://www.w3.org/ns/dcat#accessURL> <https://datastore.brussels/web/data/dataset/5f134697-0eb1-430a-81c6-d26915edfabf>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://liens.brugel.brussels/Daschboard_beschermde_klanten>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>
}
