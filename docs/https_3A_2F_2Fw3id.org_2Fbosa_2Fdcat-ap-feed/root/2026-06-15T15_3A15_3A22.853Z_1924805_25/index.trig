<#dcb685c4d608131fb2614adb86361141> {
<https://metadata.vlaanderen.be/srv/resources/distributions/954e4ae8-1e5e-478d-bf4d-57f13ed3b4ee> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/identifier> "b3502c93-a91e-4527-96a9-c2e12901a273", "805af419-5de6-496b-a463-639ee0d1a530";
    <http://purl.org/dc/terms/title> "Evolutie huishoudelijk waterverbruik"@nl, "Aandeel van verschillende toepassingen in het huishoudelijk waterverbruik"@nl;
    <http://purl.org/dc/terms/description> "Het huishoudelijk hemelwater- en grondwaterverbruik wordt bepaald op basis van enquêtes in 2016 en 2021. De tussenliggende jaren werden ingeschat rekening houdend met seizoensfactoren. Het hemelwaterverbruik tussen 2000 en 2015 werd lineair geëxtrapoleerd op basis van de trend in het niet-seizoensgebonden gebruik in de periode 2016-2021. Het grondwaterverbruik in de periode 2000-2015 werd constant gehouden ten opzichte van 2016."@nl, "Deze grafiek geeft het aandeel weer van de verschillende toepassingen in het huishoudelijk waterverbruik in Vlaanderen."@nl;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/HTML>;
    <http://www.w3.org/ns/dcat#accessURL> <https://metadata.vlaanderen.be/srv/dut/catalog.search#/metadata/1bb08305-ebd8-4733-8e7a-fc96c4429aec>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://vmm.vlaanderen.be/feiten-cijfers/lucht/vanwaar-komt-de-luchtverontreiniging/huishoudens/waterverbruik-huishoudens/huishoudelijk-waterverbruik>, <https://vmm.vlaanderen.be/feiten-cijfers/lucht/vanwaar-komt-de-luchtverontreiniging/huishoudens/waterverbruik-huishoudens/toepassingen-huishoudelijk-waterverbruik>;
    <http://purl.org/dc/terms/license> <http://data.vlaanderen.be/id/licentie/modellicentie-gratis-hergebruik/v1.0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>
}
