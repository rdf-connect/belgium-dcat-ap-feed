<../../../index.trig> <https://w3id.org/tree#member> <#ced7adf2ab6d1795ad152a19c4021a80>.
<#ced7adf2ab6d1795ad152a19c4021a80> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://opendata.vlaanderen.be/dataset/cc9238ad-ae61-4e41-86e9-e12594e20b08/resource/e06c97ef-9e05-41b9-82a8-0cceb865263b>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:34:52.545Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#ced7adf2ab6d1795ad152a19c4021a80> {
<https://opendata.vlaanderen.be/dataset/cc9238ad-ae61-4e41-86e9-e12594e20b08/resource/e06c97ef-9e05-41b9-82a8-0cceb865263b> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/NLD>;
    <http://purl.org/dc/terms/identifier> "046017d0-ab67-416f-9dde-e6348542817b";
    <http://purl.org/dc/terms/title> "Emissie van stofprecusoren: NOx"@nl;
    <http://purl.org/dc/terms/description> "Fijn stof in de lucht bestaat uit primair en secundair fijn stof. Primaire deeltjes worden rechtstreeks uitgestoten in de atmosfeer. Secundaire deeltjes ontstaan door chemische reacties van gasvormige precursoren zoals NH3, SO2 en NOx. Ook (niet-methaan) vluchtige organische stoffen (NMVOS) komen tussen in de vorming van secundair fijn stof, zij het in mindere mate. Uit deze gassen of de reactieproducten ervan kunnen anorganische of organische aerosolen gevormd worden door de vorming van nieuwe deeltjes of door hechting aan reeds bestaande deeltjes. Uit analyses van de chemische samenstelling van fijn stof in Vlaanderen blijkt dat de secundaire anorganische fractie ontstaan uit omzettingen van NH3, NOx en SO2    30-40 % uitmaakt van de massa van PM10. Het exacte aandeel is onder meer afhankelijk van de meteorologische omstandigheden, de specifieke locatie en de import uit het buitenland."@nl;
    <http://www.w3.org/ns/dcat#mediaType> <https://www.iana.org/assignments/media-types/text/csv>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/CSV>;
    <http://www.w3.org/ns/dcat#accessURL> <https://metadata.vlaanderen.be/srv/dut/catalog.search#/metadata/a7db5b58-cf6b-3a55-96eb-586e04fc0557>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://vmm.vlaanderen.be/feiten-cijfers/lucht/overzicht-per-vervuilende-stof/fijn-stof/indicator-uitstoot-fijnstofprecursoren/uitstoot-nox-evolutie/@@download/csv>;
    <http://purl.org/dc/terms/license> <http://data.vlaanderen.be/id/licentie/modellicentie-gratis-hergebruik/v1.0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>
}
