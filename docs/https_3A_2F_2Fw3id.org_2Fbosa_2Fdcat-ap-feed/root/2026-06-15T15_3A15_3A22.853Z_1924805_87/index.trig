<../../../index.trig> <https://w3id.org/tree#member> <#7e3ae6113bb03ad77c4d666e1ae1a0e1>.
<#7e3ae6113bb03ad77c4d666e1ae1a0e1> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://data.gov.be/.well-known/genid/c5050bf711fd4a11b636296b948e921786-42affc57caae862d>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:37:45.532Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#7e3ae6113bb03ad77c4d666e1ae1a0e1> {
<http://data.gov.be/.well-known/genid/c5050bf711fd4a11b636296b948e921786-42affc57caae862d> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/FRA>;
    <http://purl.org/dc/terms/title> "INSPIRE - Sites protégés type Monuments Nationaux en Wallonie (BE) - ETRS89 / LAEA Europe"@fr;
    <http://purl.org/dc/terms/description> "Cette série de couches de données spatiales compilent les informations du thème \"Sites protégés\" dont les sites dont les sites sont classés comme Monument National en Wallonie.\n\nLa Directive européenne 2007/2/CE - Directive INSPIRE - établit une infrastructure d'information géographique dans la Communauté européenne. INSPIRE s'applique à 34 domaines thématiques répartis en 3 Annexes. La présente série comprend les couches de données géographiques faisant référence aux sites protégés (Annexe 1.9).\n\nAu sens de la Directive, les sites protégés sont : \"des zones désignées ou gérées dans un cadre législatif international, communautaire ou national en vue d’atteindre des objectifs spécifiques de conservation\". Chaque site protégé peut être attaché à un ou plusieurs mécanismes de désignation spécifiques. Parmi ces mécanismes se trouvent les sites classés comme Monument National.\n\nLes sites classés comme Monument National sont extraits de la série de couches de données INSPIRE \"Sites protégés en Wallonie\" qui reprend l'ensemble des sites protégés. La sélection se base sur le mécanisme utilisé pour procéder à la désignation des sites protégés et dont la valeur correspond aux sites classés comme Monument National. \nACCÈS : \nLes conditions générales d'accès s’appliquent (http://geoportail.wallonie.be/files/documents/ConditionsSPW/DataSPW-CGA.pdf)\n\nUTILISATION : \nLes conditions générales d'utilisation s'appliquent (http://geoportail.wallonie.be/files/documents/ConditionsSPW/DataSPW-CGU.pdf)"@fr;
    <http://purl.org/dc/terms/issued> "2020-09-07"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2024-01-31"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg_impl/2023/138/oj>, <http://data.europa.eu/eli/dir/2007/2/oj>;
    <http://purl.org/dc/terms/rights> <http://data.gov.be/.well-known/genid/c5050bf711fd4a11b636296b948e921786-42affc57caae862f>;
    <http://www.w3.org/ns/dcat#mediaType> <https://www.iana.org/assignments/media-types/application/gml+xml>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/GMZ>;
    <http://www.w3.org/ns/dcat#compressFormat> <https://www.iana.org/assignments/media-types/application/zip>;
    <http://www.w3.org/ns/dcat#accessURL> <https://geodata.wallonie.be/dataset/ce6b6455-3273-41e3-bfab-ae71bcd677cc>;
    <http://www.w3.org/ns/dcat#accessService> <https://geodata.wallonie.be/id/3dbe0017-a71f-4923-9b44-fdb5afef5778>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://geoservices.wallonie.be/geotraitement/spwdatadownload/get/ce6b6455-3273-41e3-bfab-ae71bcd677cc/PS.ProtectedSitesNationalMonumentsRecord.gml.zip>;
    <http://purl.org/dc/terms/license> <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>;
    <http://www.w3.org/ns/dcat#byteSize> "2663968"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>
}
