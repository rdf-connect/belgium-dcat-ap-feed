<../../../index.trig> <https://w3id.org/tree#member> <#f93c556d1a3a64024528e595e59318b9>.
<#f93c556d1a3a64024528e595e59318b9> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://data.gov.be/.well-known/genid/c5050bf711fd4a11b636296b948e921717-42affc57caae79f9>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:37:44.924Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#f93c556d1a3a64024528e595e59318b9> {
<http://data.gov.be/.well-known/genid/c5050bf711fd4a11b636296b948e921717-42affc57caae79f9> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/FRA>;
    <http://purl.org/dc/terms/title> "INSPIRE - Dénominations géographiques en Wallonie (BE) - Service de visualisation WMS"@fr;
    <http://purl.org/dc/terms/description> "Ce service de visualisation WMS INSPIRE permet de consulter les couches de données du thème \"Dénominations géographiques\" au sein du territoire wallon (Belgique).\n\nCe service de visualisation WMS est fourni par le Service public de Wallonie (SPW) et expose les couches de données géographiques constitutives du thème \"Dénominations géographiques\" de la Directive (Annexe 1.3) sur l'ensemble du territoire wallon.\n\nCe service permet donc de localiser ponctuellement les éléments suivants :\n- Unités administratives wallonnes (Région, Provinces, Communes);\n- Anciennes communes wallonnes;\n- Hameau et lieux-dits;\n- Éléments patrimoniaux repris au patrimoine mondial de l'UNESCO (ensemble architectural, monument);\n- Sites du réseau Natura 2000 et sites naturels protégés classés par l'IUCN (réserves forestières, cavités souterraines d'intérêt scientifique, réserves naturelles agréées et domaniales, zones humides d'intérêt biologique).\n\nChaque point est caractérisé par son toponyme.\n\nLe service est conforme aux spécifications de la Directive INSPIRE en la matière."@fr;
    <http://purl.org/dc/terms/issued> "2017-11-20"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2019-08-29"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/dir/2007/2/oj>, <http://data.europa.eu/eli/reg_impl/2023/138/oj>;
    <http://purl.org/dc/terms/rights> <http://data.gov.be/.well-known/genid/c5050bf711fd4a11b636296b948e921717-42affc57caae79fa>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/WMS_SRVC>;
    <http://www.w3.org/ns/dcat#accessURL> <https://geoservices.wallonie.be/geoserver/inspire_gn/ows?service=WMS&version=1.3.0&request=GetCapabilities>;
    <http://www.w3.org/ns/dcat#accessService> <https://geodata.wallonie.be/id/0d4274a9-1482-4056-b50b-a01ad15eac27>;
    <http://purl.org/dc/terms/license> <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>
}
