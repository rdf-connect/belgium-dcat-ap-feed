    <http://www.w3.org/ns/dcat#accessURL> <https://geoservices.wallonie.be/geoserver/inspire_so/ows?service=WMS&version=1.3.0&request=GetCapabilities>;
    <http://www.w3.org/ns/dcat#accessService> <https://geodata.wallonie.be/id/e25d6117-ff65-4f0c-a776-e31df6153b7b>;
    <http://purl.org/dc/terms/license> <https://geoportail.wallonie.be/files/documents/ConditionsSPW/DataSPW-CGU.pdf>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>
