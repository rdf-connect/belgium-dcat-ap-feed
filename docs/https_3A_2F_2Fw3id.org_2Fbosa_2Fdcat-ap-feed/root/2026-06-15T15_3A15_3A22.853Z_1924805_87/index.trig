<../../../index.trig> <https://w3id.org/tree#member> <#6c45ee15de3f1313c5c2711b80739682>.
<#6c45ee15de3f1313c5c2711b80739682> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://data.gov.be/.well-known/genid/c5050bf711fd4a11b636296b948e921780-42affc57caae8524>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:37:45.970Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#6c45ee15de3f1313c5c2711b80739682> {
<http://data.gov.be/.well-known/genid/c5050bf711fd4a11b636296b948e921780-42affc57caae8524> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/FRA>;
    <http://purl.org/dc/terms/title> "INSPIRE - Essais géotechniques - Forages en Wallonie (BE) - ETRS89 / Belgian Lambert 2008"@fr;
    <http://purl.org/dc/terms/description> "Cette couche de donnée au format conforme INSPIRE reprend les forages des essais géotechniques.\n\nCette donnée est issue de la donnée métier \"Essais géotechniques -Forages\"\n\nUn forage est un procédé de reconnaissance ponctuel, dans une direction donnée, des terrains meubles et/ou rocheux. Dans le but de déterminer les caractéristiques géomécaniques et physiques du milieu, les échantillons (remaniés et non remaniés) prélevés sont décrits par un géologue et, le cas échéant, des essais de laboratoire sont réalisés.\n\nDe essais in-situ peuvent être réalisés lors ou après le forage, comme des essais pressiométriques, mesures du niveau d'eau, essais de perméabilité, pH, conductivité, ...\nLes trous de forages peuvent être équipés pour un suivi piézométrique, inclinométrique, ...\n\nUn lien dans la couche donne accès à une description en PDF du forage.\n\nACCÈS : \nNo limitations to public access (https://inspire.ec.europa.eu/metadata-codelist/LimitationsOnPublicAccess/noLimitations) \n\nUTILISATION : \nCes données sont disponibles sous licence CC-BY 4.0 (https://publications.europa.eu/resource/authority/licence/CC_BY_4_0). Source: Service Public de Wallonie - https://geodata.wallonie.be/id/242f5fcd-6fb6-499d-aecf-74d74e53246e"@fr;
    <http://purl.org/dc/terms/issued> "2024-09-01"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2024-08-21"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg_impl/2023/138/oj>, <http://data.europa.eu/eli/dir/2007/2/oj>;
    <http://purl.org/dc/terms/rights> <http://data.gov.be/.well-known/genid/c5050bf711fd4a11b636296b948e921780-42affc57caae8526>;
    <http://www.w3.org/ns/dcat#mediaType> <https://www.iana.org/assignments/media-types/application/gml+xml>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/GMZ>;
    <http://www.w3.org/ns/dcat#compressFormat> <https://www.iana.org/assignments/media-types/application/zip>;
    <http://www.w3.org/ns/dcat#accessURL> <https://geodata.wallonie.be/dataset/242f5fcd-6fb6-499d-aecf-74d74e53246e>;
    <http://www.w3.org/ns/dcat#accessService> <https://geodata.wallonie.be/id/0d5b336f-dab5-4d3d-a71e-d64d257ccec8>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://geoservices.wallonie.be/geotraitement/spwdatadownload/get/242f5fcd-6fb6-499d-aecf-74d74e53246e/GE.borehole.FORAGES.gml.zip>;
    <http://purl.org/dc/terms/license> <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>;
    <http://www.w3.org/ns/dcat#byteSize> "53733"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>
}
