    <http://purl.org/dc/terms/rights> <http://data.gov.be/.well-known/genid/c5050bf711fd4a11b636296b948e921750-42affc57caae7f6d>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/WMS_SRVC>;
    <http://www.w3.org/ns/dcat#accessURL> <https://geoservices.wallonie.be/geoserver/inspire_ef/ows?service=WMS&version=1.3.0&request=GetCapabilities>;
    <http://www.w3.org/ns/dcat#accessService> <https://geodata.wallonie.be/id/ef2a8827-8bf4-47c3-b2cf-cbded3b0c33f>;
