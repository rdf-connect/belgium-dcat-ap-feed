<../../../index.trig> <https://w3id.org/tree#member> <#f234c464dde5bd0c3e98566ade8d1bb1>.
<#f234c464dde5bd0c3e98566ade8d1bb1> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://data.gov.be/.well-known/genid/c5050bf711fd4a11b636296b948e921714-42affc57caae78c3>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:37:45.380Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#f234c464dde5bd0c3e98566ade8d1bb1> {
<http://data.gov.be/.well-known/genid/c5050bf711fd4a11b636296b948e921714-42affc57caae78c3> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/FRA>;
    <http://purl.org/dc/terms/title> "INSPIRE - Répartition des espèces selon la Directive 92/43/EEC en Wallonie (BE) - ETRS89 / LAEA Europe"@fr;
    <http://purl.org/dc/terms/description> "Cette couche de données spatiales décrit la répartition des espèces selon la directive Natura 2000 - Habitat.\n\nCette donnée est proposée ici dans sa version conforme INSPIRE.\n\nA l'Article 17, la Directive Habitats prévoit que les États Membres établissent tous les 6 ans un rapport sur l'évaluation de l'état de conservation de chacun des habitats/espèces des annexes I, II, IV et V présents sur leur territoire et ce pour chacune des régions biogéographiques* où l'habitat/espèce est présent.\n\nUn troisième exercice de rapportage a eu lieu en 2019 (période 2013-2018) et fait suite aux deux précédents effectués, l'un en 2007 (période 2001-2006), l'autre en 2013 (période 2007-2012).\n\nACCÈS : Les conditions générales d'accès s’appliquent (https://geoportail.wallonie.be/files/documents/ConditionsSPW/DataSPW-CGA.pdf). \n\t\t\nUTILISATION : Les conditions générales d'utilisation s'appliquent (https://geoportail.wallonie.be/files/documents/ConditionsSPW/DataSPW-CGU.pdf)."@fr;
    <http://purl.org/dc/terms/issued> "2020-12-15"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2025-07-01"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/dir/1992/43/oj>, <http://data.europa.eu/eli/reg_impl/2023/138/oj>, <http://data.europa.eu/eli/dir/2007/2/oj>;
    <http://purl.org/dc/terms/rights> <http://data.gov.be/.well-known/genid/c5050bf711fd4a11b636296b948e921714-42affc57caae78c5>;
    <http://www.w3.org/ns/dcat#mediaType> <https://www.iana.org/assignments/media-types/application/gml+xml>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/GMZ>;
    <http://www.w3.org/ns/dcat#compressFormat> <https://www.iana.org/assignments/media-types/application/zip>;
    <http://www.w3.org/ns/dcat#accessURL> <https://geodata.wallonie.be/dataset/903fbc40-700a-44f0-9e05-ec9f6e87778c>;
    <http://www.w3.org/ns/dcat#accessService> <https://geodata.wallonie.be/id/2e131711-454b-4990-be1e-31a7b54e74b0>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://geoservices.wallonie.be/geotraitement/spwdatadownload/get/903fbc40-700a-44f0-9e05-ec9f6e87778c/SD.SpeciesDistribution.art17.gml.zip>;
    <http://purl.org/dc/terms/license> <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>;
    <http://www.w3.org/ns/dcat#byteSize> "4758"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>
}
