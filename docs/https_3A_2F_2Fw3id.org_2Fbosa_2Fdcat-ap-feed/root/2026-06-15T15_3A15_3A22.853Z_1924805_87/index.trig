    <http://purl.org/dc/terms/rights> <http://data.gov.be/.well-known/genid/c5050bf711fd4a11b636296b948e921717-42affc57caae795d>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/WMS_SRVC>;
