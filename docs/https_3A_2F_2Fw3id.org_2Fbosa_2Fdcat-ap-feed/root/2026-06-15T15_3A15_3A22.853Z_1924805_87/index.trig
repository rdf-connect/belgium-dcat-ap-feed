    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/FRA>;
    <http://purl.org/dc/terms/title> "INSPIRE - Réseaux de transport en Wallonie (BE) - Service de visualisation WMS"@fr;
    <http://purl.org/dc/terms/description> "Ce service de visualisation WMS INSPIRE permet de consulter les couches de données du thème \"Réseaux de transport\" au sein du territoire wallon (Belgique).\n\nCe service de visualisation WMS est fourni par le Service public de Wallonie (SPW) et expose les couches de données géographiques constitutives du thème \"Réseaux de transport\" de la Directive (Annexe 1.7) sur l'ensemble du territoire wallon.\n\nCe service permet donc de visualiser les couches de données sélectionnées comme faisant partie du thème \"Réseaux de transport\". Ces couches de données sont présentées \"telles quelles\", c'est-à-dire dans leur modèle de données initial, non conforme aux spécifications de données définies par la Directive. Les couches de données seront progressivement adaptées aux modèles de donnée commun INSPIRE suivant les spécifications du thème. \n\nLe service de visualisation est conforme aux spécifications de la Directive INSPIRE en la matière."@fr;
    <http://purl.org/dc/terms/issued> "2021-02-22"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2021-02-22"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg_impl/2023/138/oj>;
    <http://purl.org/dc/terms/rights> <http://data.gov.be/.well-known/genid/c5050bf711fd4a11b636296b948e921786-42affc57caae8639>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/WMS_SRVC>;
    <http://www.w3.org/ns/dcat#accessURL> <https://geoservices.wallonie.be/geoserver/inspire_tn/ows?service=WMS&version=1.3.0&request=GetCapabilities>;
    <http://www.w3.org/ns/dcat#accessService> <https://geodata.wallonie.be/id/afe6407c-125d-4ab8-9dcc-216ac848dad1>;
    <http://purl.org/dc/terms/license> <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>
}
