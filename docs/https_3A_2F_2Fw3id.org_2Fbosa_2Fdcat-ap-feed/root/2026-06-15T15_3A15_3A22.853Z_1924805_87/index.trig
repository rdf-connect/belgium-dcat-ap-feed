    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/WMS_SRVC>;
    <http://www.w3.org/ns/dcat#accessURL> <https://geoservices.wallonie.be/geoserver/inspire_hy/ows?service=WMS&version=1.3.0&request=GetCapabilities>;
    <http://www.w3.org/ns/dcat#accessService> <https://geodata.wallonie.be/id/d2e9a58f-8c03-4302-9aa3-a0db3da0b821>;
