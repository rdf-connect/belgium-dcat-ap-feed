    <http://www.w3.org/ns/dcat#accessService> <https://geodata.wallonie.be/id/3d0cb39c-e894-4434-8d2f-260d190286c1>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://geoservices.wallonie.be/geotraitement/spwdatadownload/get/634a8d37-c061-4309-863e-83c58db6048b/LU_ExistingLandUse_SIGEC2019.gml.zip>;
