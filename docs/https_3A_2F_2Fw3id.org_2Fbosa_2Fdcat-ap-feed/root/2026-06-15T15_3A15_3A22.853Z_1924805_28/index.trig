<#592745d5924c4fd7134548c1fc5a32ce> {
<https://metadata.vlaanderen.be/srv/resources/distributions/b26230ae-8d08-344f-8c32-a16cbea96d85> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/identifier> "b26230ae-8d08-344f-8c32-a16cbea96d85";
    <http://purl.org/dc/terms/title> "GRBgis"@nl;
    <http://purl.org/dc/terms/description> "Via de downloadtoepassing kan een gebruiker de vectordata van de verschillende objecten uit het Grootschalig Referentiebestand (GRB), afzonderlijk of allemaal samen, opvragen en dit als shapefile of gml. De gebruiker kan gegevens opvragen voor een specifieke zone (gemeente, provincie, Vlaanderen, kaartblad of een zelfgetekende zone). De gebruiker kan kiezen om ofwel de meest recente versie van de gegevens op te vragen, ofwel een historische versie op te vragen of de verschillen tussen twee gekozen tijdstippen op te vragen."@nl;
    <http://purl.org/dc/terms/conformsTo> <https://data.vlaanderen.be/id/concept/dataserviceprotocol/WWW:DOWNLOAD-1.0-http--download>;
    <http://purl.org/dc/terms/rights> <https://data.vlaanderen.be/id/licentie/Gebruik-van-geografische-gegevens-voor-publieke-taken-door-deelnemers-GDI-Vlaanderen/v1.0>, <https://data.vlaanderen.be/id/licentie/Gebruik-van-geografische-gegevens-voor-publieke-taken-door-instanties-niet-deelnemers-GDI-Vlaanderen/v1.0>, <https://codex.vlaanderen.be/Zoeken/Document.aspx?DID=1026111&param=inhoud&AID=1202131>, <http://data.gov.be/.well-known/genid/rights/8fa5a2f2924b22084cf9573f7843788eb704479c>, <http://data.gov.be/.well-known/genid/rights/5ee98dbdb2da5902ce02e6085343af74f04f29b5>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/SHP>;
    <http://www.w3.org/ns/dcat#accessURL> <https://metadata.vlaanderen.be/srv/dut/catalog.search#/metadata/7C823055-7BBF-4D62-B55E-F85C30D53162>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://download.vlaanderen.be/Producten/Detail?id=1&title=GRBgis>;
    <http://purl.org/dc/terms/license> <http://data.vlaanderen.be/id/licentie/modellicentie-gratis-hergebruik/v1.0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>;
    <http://www.w3.org/2011/content#characterEncoding> "ISO-8859-1"
