<https://opendata.vlaanderen.be/dataset/59c2b5f6-affd-4e32-a665-5698e0070561/resource/e0cc1714-d4f3-4944-8f20-0350e8a75ed3> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/NLD>;
    <http://purl.org/dc/terms/identifier> "3dad5ba0-2beb-41b0-a652-d3cf78783ffd";
    <http://purl.org/dc/terms/title> "Evolutie van de achtergrondconcentraties (jaargemiddelden) en piekconcentraties"@nl;
    <http://purl.org/dc/terms/description> "De kaart is gebaseerd op interpolatie van de resultaten van de meetstations in Vlaanderen en de omliggende regio's, aangevuld met een hoge resolutie modellering.Op de kaart:kunnen de concentraties lokaal hoger of lager zijn;stijgt de onzekerheid op de gemodelleerde concentraties naarmate je verder van een meetplaats gaat;houden we geen rekening met topografie, obstakels langs wegen (bv. bomen, geluidsschermen,...) en gesloten huizenrijen.De kaart is gebaseerd op interpolatie van de resultaten van de meetstations in Vlaanderen en de omliggende regio's, aangevuld met een hoge resolutie modellering."@nl;
    <http://www.w3.org/ns/dcat#mediaType> <https://www.iana.org/assignments/media-types/text/csv>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/CSV>;
    <http://www.w3.org/ns/dcat#accessURL> <https://metadata.vlaanderen.be/srv/dut/catalog.search#/metadata/294dd566-db80-342e-aa29-99185f9e52b3>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://vmm.vlaanderen.be/feiten-cijfers/lucht/overzicht-per-vervuilende-stof/ozon/indicator-ozonconcentratie/ozon-jaargemiddelden/@@download/csv>;
    <http://purl.org/dc/terms/license> <http://data.vlaanderen.be/id/licentie/modellicentie-gratis-hergebruik/v1.0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>
}
