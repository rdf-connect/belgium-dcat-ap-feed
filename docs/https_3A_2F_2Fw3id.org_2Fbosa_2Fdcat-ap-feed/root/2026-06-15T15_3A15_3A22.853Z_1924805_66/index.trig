    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/NLD>;
    <http://purl.org/dc/terms/identifier> "8dbb134d-c793-4d20-bcce-37a6b2d97c3c";
    <http://purl.org/dc/terms/title> "Evolutie van pesticiden in waterbodems"@nl;
    <http://purl.org/dc/terms/description> "Heel wat organochloorpesticiden (meestal insecticiden), hebben de neiging te binden aan zwevende deeltjes in de waterkolom. Als deze deeltjes bezinken, komen de eraan vastgehechte polluenten in de waterbodem terecht. Daar kunnen ze nog lange tijd aanwezig blijven. De meetresultaten worden op basis van de vergelijking met de referentiewaarde voor het geheel van de OCP's in kwaliteitsklassen ingedeeld."@nl;
    <http://www.w3.org/ns/dcat#mediaType> <https://www.iana.org/assignments/media-types/text/csv>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/CSV>;
    <http://www.w3.org/ns/dcat#accessURL> <https://metadata.vlaanderen.be/srv/dut/catalog.search#/metadata/ef8da2bb-fd5f-3466-a936-b153732c5aa9>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://vmm.vlaanderen.be/feiten-cijfers/water/kwaliteit-waterlopen/waterbodem/indicator-pesticiden-in-waterbodems/pesticiden-in-waterbodems/@@download/csv>;
    <http://purl.org/dc/terms/license> <http://data.vlaanderen.be/id/licentie/modellicentie-gratis-hergebruik/v1.0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>
}
