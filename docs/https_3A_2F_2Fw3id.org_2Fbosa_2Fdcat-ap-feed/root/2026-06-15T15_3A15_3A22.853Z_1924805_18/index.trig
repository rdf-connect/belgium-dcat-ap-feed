_:b54578_b54577_b54576_df_12_69369 a <http://www.w3.org/ns/dqv#QualityAnnotation>;
    <http://www.w3.org/ns/oa#hasBody> "http://data.gov.be/.well-known/genid/63236b7128d642e2a86d55d8b03caaf52-50AEC5EB8DCB747742BF240DE737C3BA"^^<http://www.w3.org/2001/XMLSchema#anyURI>
}
