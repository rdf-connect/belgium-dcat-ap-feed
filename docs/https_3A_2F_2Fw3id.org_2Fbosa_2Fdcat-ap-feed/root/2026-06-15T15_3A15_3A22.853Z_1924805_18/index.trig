_:b54155_b54154_b54153_df_12_69124 a <http://purl.org/ontology/bibo/Document>;
    <http://purl.org/dc/terms/title> "Thomas et al. (submitted). Mineral-bound organic carbon exposed by hillslope thermokarst terrain: case study in Cape Bounty, Canadian High Arctic. submitted to EGUsphere, SOIL. (2025-07-16)".
_:b54155_b54154_b54153_df_12_69125 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Thomas, Maxime";
