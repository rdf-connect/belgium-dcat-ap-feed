    <http://purl.org/dc/terms/creator> <http://data.gov.be/.well-known/genid/person/ucl/4b79f9f48eeacbb1bc69bb85b62f32229ff37102>, <http://data.gov.be/.well-known/genid/person/ucl/644f1029c745dd257e92b7141f7a26ebb9b3d7eb>, <http://data.gov.be/.well-known/genid/person/ucl/62b5e9bbdb14b836147cf85066a674cb37a83b80>, <http://data.gov.be/.well-known/genid/person/ucl/97e00959c7aef567aaa28ceccf9451283cfa758b>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/subject> "Physics";
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/KAAYFM>;
    <http://purl.org/dc/terms/bibliographicCitation> "Jeon, Sihyun; Kang, Yoojin; Lee, Gyunggoo; Yu, Chaehyun, 2021, \"Implementation of a search for dark matter in the mono-Higgs channel (36.1 fb-1; 13 TeV; ATLAS-EXOT-2016-25)\", https://doi.org/10.14428/DVN/KAAYFM, Open Data @ UCLouvain, V2";
    <http://www.w3.org/ns/dcat#contactPoint> _:b54137_b54136_b54135_df_12_69116;
