<#b9f02374f82dfb58db15d36d7403a046> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://transportdata.be/dataset/b83c0aa0-219c-4eaf-b8f6-ed8ab854554b>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:32:56.239Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#b9f02374f82dfb58db15d36d7403a046> {
<https://transportdata.be/dataset/b83c0aa0-219c-4eaf-b8f6-ed8ab854554b> a <http://www.w3.org/ns/dcat#Dataset>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/FRA>, <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/identifier> "b83c0aa0-219c-4eaf-b8f6-ed8ab854554b";
    <http://purl.org/dc/terms/title> "indigo-open-data-be"@en, "indigo-open-data-be"@nl-t-en, "indigo-open-data-be"@fr-t-en, "Indigo-Open-Data-Be"@de-t-en;
    <http://purl.org/dc/terms/description> "Description:\r\n - Ce dataset fournit des informations détaillées sur plusieurs parkings urbains, comprenant leurs caractéristiques de base et la localisation.\r\n\r\nDétails des champs:\r\n - ID: Identifiant unique pour chaque parking.\r\n - Nom: Nom du parking\r\n - Localisation: Coordonnées géographiques (`latitude`, `longitude`) indiquant la position du parking.\r\n - Capacité: Nombre total de places (`spacesTotal`).\r\n\r\nMise à jour des données:\r\nLes données sont mises à jour quotidiennement.\r\n\r\nUtilisation:\r\n - Open Data Commons Open Database License (ODbL)"@fr, "Description:\r\n - This dataset provides detailed information on several urban parking lots, including their basic characteristics and location.\r\n\r\nField details:\r\n - ID: Unique identifier for each parking lot.\r\n - Name: Car park name\r\n - Location: Geographical coordinates (`latitude`, `longitude`) indicating the position of the parking lot.\r\n - Capacity: Total number of spaces (`spacesTotal`).\r\n\r\nData update:\r\nData is updated daily.\r\n\r\nData usage:\r\n - Open Data Commons Open Database License (ODbL)"@en, "Beschrijving: \nDeze dataset geeft gedetailleerde informatie over verschillende stedelijke parkeerplaatsen, inclusief hun basiskenmerken en locatie. \n\nNadere gegevens over het veld: \n- ID: Unieke identificatiecode voor elke parkeerplaats. \n- Naam: Naam parkeerplaats\n- Locatie: Geografische coördinaten (\"breedtegraad\", \"lengtegraad\") die de positie van de parkeerplaats aangeven. \n- Capaciteit: Totaal aantal ruimten (\"ruimtenTotaal\"). \n\nBijwerking van gegevens: \nDe gegevens worden dagelijks bijgewerkt. \n\nGebruik van gegevens:  \nOpen Data Commons Open Database Licentie (ODbL)"@nl-t-en, "Beschreibung: \n- Dieser Datensatz enthält detaillierte Informationen zu mehreren städtischen Parkplätzen, einschließlich ihrer grundlegenden Merkmale und Lage. \n\nAngaben zum Feld: \n- Ausweis: Eindeutige Kennung für jeden Parkplatz. \n- Name: Name des Parkplatzes\n- Standort: Geografische Koordinaten (\"Breitengrad\", \"Längengrad\") zur Angabe der Position des Parkplatzes. \n- Kapazität: Gesamtzahl der Räume („SpacesTotal“). \n\nAktualisierung der Daten: \nDie Daten werden täglich aktualisiert. \n\nDatennutzung:  \nOpen-Data-Commons-Lizenz für offene Datenbanken (ODbL)"@de-t-en;
    <http://purl.org/dc/terms/issued> "2025-01-25T00:35:57.951698"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2025-12-10T07:00:32.910866"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/publisher> <https://opencorporates.com/id/companies/fr/800348146>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg_del/2017/1926/oj>;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TRAN>;
    <http://www.w3.org/ns/dcat#landingPage> <https://transportdata.be/dataset/b83c0aa0-219c-4eaf-b8f6-ed8ab854554b#>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b54518_b54517_b54516_df_12_69323;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/2802361/>;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/DAILY>;
    <http://purl.org/dc/terms/temporal> _:b54518_b54517_b54516_df_12_69324;
    <https://w3id.org/mobilitydcat-ap#georeferencingMethod> <https://w3id.org/mobilitydcat-ap/georeferencing-method/geocoordinates>;
    <https://w3id.org/mobilitydcat-ap#mobilityTheme> <https://w3id.org/mobilitydcat-ap/mobility-theme/parking-service-and-rest-area-information>;
    <https://w3id.org/mobilitydcat-ap#transportMode> <https://w3id.org/mobilitydcat-ap/transport-mode/car>, <https://w3id.org/mobilitydcat-ap/transport-mode/motorcycle>, <https://w3id.org/mobilitydcat-ap/transport-mode/bicycle>;
    <http://www.w3.org/ns/dcat#distribution> <https://transportdata.be/dataset/b83c0aa0-219c-4eaf-b8f6-ed8ab854554b/resource/0d8aebc7-6a70-475b-9dc6-47275501daca>, <https://transportdata.be/dataset/b83c0aa0-219c-4eaf-b8f6-ed8ab854554b/resource/ac2d3bce-0ee5-43b3-b70d-b2a2c992d7c7>, <https://transportdata.be/dataset/b83c0aa0-219c-4eaf-b8f6-ed8ab854554b/resource/4ca0175e-5927-4311-8860-bef86cf7ef16>.
_:b54518_b54517_b54516_df_12_69323 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Indigo";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:data.fr@group-indigo.com>.
_:b54518_b54517_b54516_df_12_69324 a <http://purl.org/dc/terms/PeriodOfTime>;
    <http://www.w3.org/ns/dcat#startDate> "2025-01-25T01:35:57"^^<http://www.w3.org/2001/XMLSchema#dateTime>
}
