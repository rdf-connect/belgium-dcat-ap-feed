    <http://purl.org/dc/terms/bibliographicCitation> "Fuks, Benjamin; Goodsell, Mark, 2025, \"Implementation of a search for electroweakinos with soft di-leptons and jigsaw variables (139/fb; ATLAS-SUSY-2018-16)\", https://doi.org/10.14428/DVN/1CPXHX, Open Data @ UCLouvain, V2";
    <http://www.w3.org/ns/dcat#contactPoint> _:b54488_b54487_b54486_df_12_69305;
    <http://www.w3.org/ns/dcat#distribution> <http://data.gov.be/.well-known/genid/dist/ucl/doi-10-14428/DVN/1CPXHX/LVU0VC>, <http://data.gov.be/.well-known/genid/dist/ucl/doi-10-14428/DVN/1CPXHX/QOX5OZ>, <http://data.gov.be/.well-known/genid/dist/ucl/doi-10-14428/DVN/1CPXHX/S3T0S5>, <http://data.gov.be/.well-known/genid/dist/ucl/doi-10-14428/DVN/1CPXHX/W5QA0C>, <http://data.gov.be/.well-known/genid/dist/ucl/doi-10-14428/DVN/1CPXHX/TA4ZZT>.
_:b54488_b54487_b54486_df_12_69305 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Fuks, Benjamin";
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "LPTHE / Sorbonne U.";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:fuks@lpthe.jussieu.fr>
}
