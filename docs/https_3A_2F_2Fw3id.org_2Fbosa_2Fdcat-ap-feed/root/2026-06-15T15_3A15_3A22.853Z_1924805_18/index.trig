    <http://purl.org/dc/terms/bibliographicCitation> "Colognesi, Victor; Ronsse, Renaud; Chatelain, Philippe, 2022, \"3D velocity and vorticity fields over a flapping period with periodic flapping\", https://doi.org/10.14428/DVN/KQQAQJ, Open Data @ UCLouvain, V1";
    <http://purl.org/ontology/bibo/citedBy> _:b54182_b54181_b54180_df_12_69140;
    <http://www.w3.org/ns/dcat#contactPoint> _:b54182_b54181_b54180_df_12_69141.
_:b54182_b54181_b54180_df_12_69140 a <http://purl.org/ontology/bibo/Document>;
    <http://purl.org/dc/terms/title> "Victor Colognesi, Renaud Ronsse, and Philippe Chatelain. Model coupling biomechanics and fluid dynamics for the simulation of controlled flapping flight. Bioinspiration & Biomimetics, 16(2), jan 2021.";
    <http://purl.org/dc/terms/identifier> "10.1088/1748-3190/abdd9c";
    <http://purl.org/ontology/bibo/uri> <https://iopscience.iop.org/article/10.1088/1748-3190/abdd9c>.
_:b54182_b54181_b54180_df_12_69141 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Colognesi, Victor";
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "Universite catholique de Louvain";
