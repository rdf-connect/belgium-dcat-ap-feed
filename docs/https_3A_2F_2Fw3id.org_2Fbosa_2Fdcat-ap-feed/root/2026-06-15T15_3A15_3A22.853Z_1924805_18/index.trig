    <http://purl.org/dc/terms/creator> <http://data.gov.be/.well-known/genid/person/ucl/1f656d24ed43be8bcfa49ba9b03c80131d634abd>, <http://data.gov.be/.well-known/genid/person/ucl/3294b374945651cbadb39433e960b326ced9e2cc>, <https://orcid.org/0009-0003-3274-2471>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://www.w3.org/ns/dcat#keyword> "Electric Vehicles"@en, "Simulation"@en, "Charging Behavior"@en, "Mobility Patterns"@en, "Generation Tool"@en, "Synthetic Dataset"@en;
    <http://purl.org/dc/terms/subject> "Computer and Information Science", "Engineering", "Other";
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/6GUFM9>;
    <http://purl.org/dc/terms/bibliographicCitation> "Van Rillaer, Victoria; de Schietere de Lophem, Mathias; Verhaeghe, Hélène, 2025, \"Synthetic Dataset of Electric Vehicles Charging Sessions\", https://doi.org/10.14428/DVN/6GUFM9, Open Data @ UCLouvain, V2";
    <http://www.w3.org/ns/dcat#contactPoint> _:b54104_b54103_b54102_df_12_69102;
    <http://purl.org/dc/terms/temporal> _:b54104_b54103_b54102_df_12_69103;
    <http://www.w3.org/ns/dcat#distribution> <http://data.gov.be/.well-known/genid/dist/ucl/doi-10-14428/DVN/6GUFM9/GM9M8Z>.
_:b54104_b54103_b54102_df_12_69102 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Van Rillaer, Victoria";
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "Universite catholique de Louvain";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:vanrillaervictoria@gmail.com>.
_:b54104_b54103_b54102_df_12_69103 a <http://purl.org/dc/terms/PeriodOfTime>;
