    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/FRA>;
    <http://purl.org/dc/terms/identifier> "d749cd54-31a2-4d20-bf52-f58c3010bdb0";
    <http://purl.org/dc/terms/title> "Plan hiver routes : tronçons sensibles"@fr, "Winterrouteplan: gevoelige secties"@nl-t-fr, "Winterplan Straßen: empfindliche Abschnitte"@de-t-fr, "Winter road plan: sensitive sections"@en-t-fr;
    <http://purl.org/dc/terms/description> "Wegvakken waarop het verkeer van bepaalde vrachtwagens tijdelijk kan worden verboden tijdens de verkeerswaarschuwingsfase van het Winterplan."@nl, "Tronçons routiers sur lesquels la circulation de certains poids lourds peut être momentanément interdite lors de la phase d’alerte routière du Plan hiver."@fr, "Straßenabschnitte, auf denen während der Warnephase des Winterplans vorübergehend der Verkehr bestimmter Lastkraftwagen verboten werden kann."@de, "Road sections on which the circulation of certain heavy goods vehicles may be temporarily prohibited during the road warning phase of the Winter Plan."@en;
    <http://purl.org/dc/terms/issued> "2023-03-13T13:38:33.400239"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2024-12-18T12:05:03.145043"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
