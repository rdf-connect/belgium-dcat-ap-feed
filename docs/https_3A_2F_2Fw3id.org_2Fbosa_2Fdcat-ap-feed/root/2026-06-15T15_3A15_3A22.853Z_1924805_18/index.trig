<../../../index.trig> <https://w3id.org/tree#member> <#fdde79a51689198bf07cd64687f455e0>.
<#fdde79a51689198bf07cd64687f455e0> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/GLWLTF>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:32:56.201Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#fdde79a51689198bf07cd64687f455e0> {
<http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/GLWLTF> a <http://www.w3.org/ns/dcat#Dataset>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/identifier> "doi:10.14428/DVN/GLWLTF";
    <http://purl.org/dc/terms/title> "Re-implementation of the W' into 1 lepton  + missing energy analysis (139 fb-1; ATLAS-EXOT-2018-30)"@en, "Herimplementatie van de W' in 1 lepton + ontbrekende energieanalyse (139 fb-1; ATLAS-EXOT-2018-30)"@nl-t-en, "Ré-implémentation du W' en 1 lepton + analyse d'énergie manquante (139 fb-1; ATLAS-EXOT-2018-30)"@fr-t-en, "Neuimplementierung des W' in 1 Lepton + fehlende Energieanalyse (139 fb-1; ATLAS-EXOT-2018-30)"@de-t-en;
    <http://purl.org/dc/terms/description> "Description: This consists of the re-implementation, in the MadAnalysis 5 framework, of an ATLAS search for extra charged W' bosons when they decay into a single lepton plus neutrino mode. 139/fb of LHC proton-proton collisions at 13 TeV has been analyzed.  \n \n  \r\n\r\nInformation on how to use this code and a detailed validation summary are available on the Public Analysis Database of MadAnalysis. The ATLAS analysis is documented on the collaboration wiki."@en, "Beschrijving: Dit bestaat uit de herimplementatie, in het MadAnalysis 5-framework, van een ATLAS-zoekopdracht naar extra geladen W'-bosonen wanneer ze vervallen in een enkele lepton plus neutrino-modus. 139/fb van LHC proton-proton botsingen bij 13 TeV is geanalyseerd. \n\n\n\nInformatie over het gebruik van deze code en een gedetailleerde validatiesamenvatting zijn beschikbaar in de Public Analysis Database of MadAnalysis. De ATLAS-analyse is gedocumenteerd op de samenwerkingswiki."@nl-t-en, "Description : Il s'agit de la ré-implémentation, dans le cadre MadAnalysis 5, d'une recherche ATLAS de bosons W' extra chargés lorsqu'ils se désintègrent en un seul mode lepton plus neutrino. On a analysé 139/fb de collisions proton-proton du LHC à 13 TeV. \n\n\n\nDes informations sur l'utilisation de ce code et un résumé de validation détaillé sont disponibles sur la base de données d'analyse publique de MadAnalysis. L'analyse ATLAS est documentée sur le wiki de collaboration."@fr-t-en, "Beschreibung: Dies besteht in der Neuimplementierung einer ATLAS-Suche nach extra geladenen W'-Bosonen im MadAnalysis 5-Framework, wenn sie in einen Leptonen-Plus-Neutrino-Modus zerfallen. 139/fb von LHC-Proton-Proton-Kollisionen bei 13 TeV wurden analysiert. \n\n\n\nInformationen zur Verwendung dieses Codes und eine detaillierte Validierungszusammenfassung sind in der Public Analysis Database of MadAnalysis verfügbar. Die ATLAS-Analyse wird im Collaboration-Wiki dokumentiert."@de-t-en;
    <http://purl.org/dc/terms/created> "2020-07-23T13:21:01Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/issued> "2020-07-23T13:21:19Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2020-07-23T13:21:19Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#version> "1";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeRegisteredEntity/0419052272>;
    <http://purl.org/dc/terms/creator> <http://data.gov.be/.well-known/genid/person/ucl/ea65306791435d71a40451ab93594d6ec9195760>, <http://data.gov.be/.well-known/genid/person/ucl/fc03d5edeeac18a7db0338b8a60c67b9839bb33e>, <http://data.gov.be/.well-known/genid/person/ucl/beed2fa2f26fe6512b6b5757fe21150523941a5d>, <http://data.gov.be/.well-known/genid/person/ucl/66bd545d4a312cae8f6a467d63081c207155bb6e>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/subject> "Physics";
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/GLWLTF>;
    <http://purl.org/dc/terms/bibliographicCitation> "Park, Kyungmin; Lee, SooJin; Jun, Won; Min, Ui, 2020, \"Re-implementation of the W' into 1 lepton + missing energy analysis (139 fb-1; ATLAS-EXOT-2018-30)\", https://doi.org/10.14428/DVN/GLWLTF, Open Data @ UCLouvain, V1";
    <http://www.w3.org/ns/dcat#contactPoint> _:b54494_b54493_b54492_df_12_69307;
    <http://www.w3.org/ns/dcat#distribution> <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-1737889563e-6f19e27e98fd>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-17378894ff6-937b1faa5b3b>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-173788952eb-9fcd4a86663a>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-173788797b7-a3815d29ce9e>.
_:b54494_b54493_b54492_df_12_69307 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Park, Kyungmin";
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "University of Seoul";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:jazzykm0110@gmail.com>
}
