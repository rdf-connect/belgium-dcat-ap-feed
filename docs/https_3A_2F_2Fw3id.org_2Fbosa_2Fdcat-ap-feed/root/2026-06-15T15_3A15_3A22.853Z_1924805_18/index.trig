    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TRAN>;
    <http://www.w3.org/ns/dcat#landingPage> <https://transportdata.be/dataset/d749cd54-31a2-4d20-bf52-f58c3010bdb0#>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b54806_b54805_b54804_df_12_69542;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337387/>;
