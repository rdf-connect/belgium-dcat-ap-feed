<../../../index.trig> <https://w3id.org/tree#member> <#ee40742aa90f2d81482b7c2c369e2578>.
<#ee40742aa90f2d81482b7c2c369e2578> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://transportdata.be/dataset/b24623cb-01d3-4f4f-9664-7980136d18f1>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:32:56.485Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#ee40742aa90f2d81482b7c2c369e2578> {
<https://transportdata.be/dataset/b24623cb-01d3-4f4f-9664-7980136d18f1> a <http://www.w3.org/ns/dcat#Dataset>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/NLD>;
    <http://purl.org/dc/terms/identifier> "b24623cb-01d3-4f4f-9664-7980136d18f1";
    <http://purl.org/dc/terms/title> "TCO-tool: vergelijk milieuvriendelijke en conventionele wagens"@nl, "Outil TCO: Comparer les voitures écologiques et conventionnelles"@fr-t-nl, "TCO-Tool: Vergleichen Sie umweltfreundliche und konventionelle Autos"@de-t-nl, "TCO tool: Compare Eco-Friendly and Conventional Cars"@en-t-nl;
    <http://purl.org/dc/terms/description> "De tool geeft de mogelijkheid om de Total Cost of Ownership van twee wagens te vergelijken. Er kunnen vergelijkingen gemaakt worden tussen elektrische, plug-in hybride, aardgas-, waterstof- en brandstofwagens.\r\n\r\nOm de vergelijking te kunnen maken wordt er rekening gehouden met  de juridische entiteit, fiscaliteit, het aantal gereden kilometers per jaar, de gebruiksduur in jaren, het theoretische en realistische verbruik en de laadmix. "@nl, "L'outil permet de comparer le coût total de possession de deux voitures. Des comparaisons peuvent être faites entre les voitures électriques, hybrides rechargeables, au gaz naturel, à hydrogène et à carburant. \n \nPour pouvoir faire la comparaison, l'entité juridique, la fiscalité, le nombre de kilomètres parcourus par an, la durée de vie utile en années, la consommation théorique et réaliste et le mix tarifaire sont pris en compte."@fr-t-nl, "Das Tool bietet die Möglichkeit, die Gesamtbetriebskosten von zwei Autos zu vergleichen. Es lassen sich Vergleiche zwischen Elektro-, Plug-in-Hybrid-, Erdgas-, Wasserstoff- und Kraftstofffahrzeugen anstellen. \n \nUm den Vergleich durchführen zu können, werden die juristische Person, die Besteuerung, die Anzahl der gefahrenen Kilometer pro Jahr, die Nutzungsdauer in Jahren, der theoretische und realistische Verbrauch und der Lademix berücksichtigt."@de-t-nl, "The tool gives the possibility to compare the Total Cost of Ownership of two cars. Comparisons can be made between electric, plug-in hybrid, natural gas, hydrogen and fuel cars. \n \nTo be able to make the comparison, the legal entity, taxation, the number of kilometres driven per year, the useful life in years, the theoretical and realistic consumption and the charging mix are taken into account."@en-t-nl;
    <http://purl.org/dc/terms/issued> "2025-01-17T12:21:33.113606"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2025-01-17T12:33:26.326513"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeEstablishmentUnit/2199336230>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg_del/2017/1926/oj>;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TRAN>;
    <http://www.w3.org/ns/dcat#landingPage> <https://transportdata.be/dataset/b24623cb-01d3-4f4f-9664-7980136d18f1#>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b54668_b54667_b54666_df_12_69444;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337388/>;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL_2>;
    <http://purl.org/dc/terms/temporal> _:b54668_b54667_b54666_df_12_69445;
    <https://w3id.org/mobilitydcat-ap#mobilityTheme> <https://w3id.org/mobilitydcat-ap/mobility-theme/general-information-for-trip-planning>, <https://w3id.org/mobilitydcat-ap/mobility-theme/parameters-needed-to-calculate-environmental-factors>;
    <https://w3id.org/mobilitydcat-ap#transportMode> <https://w3id.org/mobilitydcat-ap/transport-mode/car>;
    <http://www.w3.org/ns/dcat#distribution> <https://transportdata.be/dataset/b24623cb-01d3-4f4f-9664-7980136d18f1/resource/af495c38-a7b0-4649-ab9c-ca2b17478fee>.
_:b54668_b54667_b54666_df_12_69444 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Afdeling beleid";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:beleid@mow.vlaanderen.be>.
_:b54668_b54667_b54666_df_12_69445 a <http://purl.org/dc/terms/PeriodOfTime>;
    <http://www.w3.org/ns/dcat#startDate> "2025-01-17T09:56:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>
}
