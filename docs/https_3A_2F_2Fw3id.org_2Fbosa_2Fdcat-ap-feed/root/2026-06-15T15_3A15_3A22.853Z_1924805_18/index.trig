<../../../index.trig> <https://w3id.org/tree#member> <#70f35122a3d67713cf1833e2e22e1c82>.
<#70f35122a3d67713cf1833e2e22e1c82> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/XCEOYB>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:32:55.624Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#70f35122a3d67713cf1833e2e22e1c82> {
<http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/XCEOYB> a <http://www.w3.org/ns/dcat#Dataset>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/identifier> "doi:10.14428/DVN/XCEOYB";
    <http://purl.org/dc/terms/title> "Implementation of a search for dark matter production in association with a top quark pair (19.7 fb-1; 8 TeV; CMS-B2G-14-004)"@en, "Implementatie van een zoektocht naar donkere materie productie in combinatie met een top quark pair (19.7 fb-1; 8 TeV; CMS-B2G-14-004)"@nl-t-en, "Mise en œuvre d’une recherche de production de matière noire en association avec une paire de quarks supérieurs (19,7 fb-1; 8 TeV; CMS-B2G-14-004)"@fr-t-en, "Durchführung einer Suche nach der Produktion von Dunkler Materie in Verbindung mit einem Top-Quark-Paar (19,7 fb-1; 8 TeV; CMS-B2G-14-004)"@de-t-en;
    <http://purl.org/dc/terms/description> "Description: This consists of the implementation, in the MadAnalysis 5 framework, of a CMS search for dark matter when it is produced in association with a pair of top quarks. 19.7/fb of LHC proton-proton collisions at 8 TeV has been analyzed.  \n \n  \n\nInformation on how to use this code and a detailed validation summary are available on the Public Analysis Database of MadAnalysis. The CMS analysis is documented on the collaboration wiki."@en, "Beschrijving: Dit bestaat uit de implementatie, in het MadAnalysis 5-framework, van een CMS-zoekopdracht naar donkere materie wanneer deze wordt geproduceerd in samenwerking met een paar topquarks. 19.7/fb van LHC proton-proton botsingen bij 8 TeV is geanalyseerd. \n\n\n\nInformatie over het gebruik van deze code en een gedetailleerde validatiesamenvatting zijn beschikbaar in de Public Analysis Database of MadAnalysis. De CMS-analyse is gedocumenteerd op de samenwerkingswiki."@nl-t-en, "Description : Il s'agit de la mise en œuvre, dans le framework MadAnalysis 5, d'une recherche CMS de matière noire lorsqu'elle est produite en association avec une paire de quarks supérieurs. 19.7/fb de collisions proton-proton du LHC à 8 TeV a été analysé. \n\n\n\nDes informations sur l'utilisation de ce code et un résumé de validation détaillé sont disponibles sur la base de données d'analyse publique de MadAnalysis. L'analyse CMS est documentée sur le wiki de collaboration."@fr-t-en, "Beschreibung: Dies besteht in der Implementierung einer CMS-Suche nach dunkler Materie im MadAnalysis 5-Framework, wenn sie in Verbindung mit einem Paar Top-Quarks erzeugt wird. 19,7/fb von LHC-Proton-Proton-Kollisionen bei 8 TeV wurden analysiert. \n\n\n\nInformationen zur Verwendung dieses Codes und eine detaillierte Validierungszusammenfassung sind in der Public Analysis Database of MadAnalysis verfügbar. Die CMS-Analyse wird im Collaboration-Wiki dokumentiert."@de-t-en;
    <http://purl.org/dc/terms/created> "2021-06-10T18:14:27Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/issued> "2021-06-10T18:17:45Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2021-06-10T18:17:45Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#version> "2";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeRegisteredEntity/0419052272>;
    <http://purl.org/dc/terms/creator> <http://data.gov.be/.well-known/genid/person/ucl/652b99b193fdbdc2801eb4ecf20c84ba3bb85f03>, <https://orcid.org/0000-0002-0041-0566>, <https://orcid.org/0000-0002-3215-9652>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/subject> "Physics";
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/XCEOYB>;
    <http://purl.org/dc/terms/bibliographicCitation> "Fuks, Benjamin; Martini, Anthony, 2021, \"Implementation of a search for dark matter production in association with a top quark pair (19.7 fb-1; 8 TeV; CMS-B2G-14-004)\", https://doi.org/10.14428/DVN/XCEOYB, Open Data @ UCLouvain, V2";
    <http://www.w3.org/ns/dcat#contactPoint> _:b54161_b54160_b54159_df_12_69128;
    <http://www.w3.org/ns/dcat#distribution> <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-179f78be827-e2da7a12c297>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-179f78bea84-0204051702b9>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-179f78bf4f0-03edad292689>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-179f78ba8d5-eeccc0004a71>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-179f79143fe-3ea0514d56e0>.
_:b54161_b54160_b54159_df_12_69128 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Fuks, Benjamin";
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "LPTHE / Sorbonne U.";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:fuks@lpthe.jussieu.fr>
}
