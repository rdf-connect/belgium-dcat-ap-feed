    <http://purl.org/dc/terms/creator> <https://orcid.org/0000-0002-8754-0098>, <https://orcid.org/0000-0001-8549-3606>, <https://orcid.org/0000-0002-4608-3732>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://www.w3.org/ns/dcat#keyword> "tensegrity"@en, "self-stress"@en, "prestress"@en, "physical modeling"@en, "experimental testing"@en, "equilibrium matrix"@en, "dynamic relaxation"@en, "sensitivity matrix"@en;
    <http://purl.org/dc/terms/subject> "Engineering";
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/CDLVFV>;
    <http://purl.org/dc/terms/bibliographicCitation> "Feron, Jonas; Bertholet, Alex; Latteur, Pierre, 2022, \"Replication Data for: Experimental testing of a tensegrity simplex: self-stress implementation and static loading\", https://doi.org/10.14428/DVN/CDLVFV, Open Data @ UCLouvain, V2";
    <http://purl.org/ontology/bibo/citedBy> _:b54215_b54214_b54213_df_12_69156;
    <http://www.w3.org/ns/dcat#contactPoint> _:b54215_b54214_b54213_df_12_69157;
    <http://www.w3.org/ns/dcat#distribution> <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-183664ecc87-d49351972845>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-183664f00e4-6c3b55c79e7d>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-18366561499-f67614c11423>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-183665626f0-21c497b41239>.
_:b54215_b54214_b54213_df_12_69156 a <http://purl.org/ontology/bibo/Document>;
    <http://purl.org/dc/terms/title> "Feron J., Rhode-Barbarigos L., Latteur P., Experimental testing\nof a tensegrity simplex: self-stress implementation and static\nloading. Submitted to ASCE Journal of Structural Engineering,\n2022".
_:b54215_b54214_b54213_df_12_69157 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Feron, Jonas";
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "Universite catholique de Louvain";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:jonas.feron@uclouvain.be>
}
