    <http://purl.org/dc/terms/title> "Nominal retrieval results (ice cloud & dust OD)"@en;
    <http://purl.org/dc/terms/description> "Results of the nominal retrieval mode: dust & ice cloud OD.  \r\n\r\nThe csv file contains the following columns:    \r\nColumn 1: Orbit name  \r\nColumn 2: Spectrum number  \r\nColumn 3: Solar longitude (Ls) (°)  \r\nColumn 4: Martian year (MY)  \r\nColumn 5: Latitude (°)  \r\nColumn 6: Longitude (°)  \r\nColumn 7: Local time (LT) (h)  \r\nColumn 8: Solar zenith angle (SZA) (°)  \r\nColumn 9: Phase angle (°)  \r\nColumn 10: Dust optical depth (DOD) (@300 nm)  \r\nColumn 11: Error DOD  \r\nColumn 12: DOD fitted (1= fitted, 0=not fitted)  \r\nColumn 13: Cloud optical depth (COD) (@ 320 nm)  \r\nColumn 14: Error COD  \r\nColumn 15: COD fitted (1= fitted, 0=not fitted)  \r\nColumn 16: Dust Reff used (µm)  "@en;
    <http://purl.org/dc/terms/issued> "2025-12-16T12:30:48.689825"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2026-04-28T07:49:45.572546"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#mediaType> <https://www.iana.org/assignments/media-types/media-types.xhtml#text>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/TXT>;
    <http://www.w3.org/ns/dcat#accessURL> <https://data.aeronomie.be/dataset/5264f28e-d662-478e-ad64-634ce42d902d>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://data.aeronomie.be/dataset/5264f28e-d662-478e-ad64-634ce42d902d/resource/5135f93d-048d-426f-94f8-0f151ce5696d/download/willame2025_jgr.txt>;
    <http://purl.org/dc/terms/license> <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>;
