<../../../index.trig> <https://w3id.org/tree#member> <#d5febe48bef3fde222ae50179848c535>.
<#d5febe48bef3fde222ae50179848c535> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/3M87GD>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:32:55.493Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#d5febe48bef3fde222ae50179848c535> {
<http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/3M87GD> a <http://www.w3.org/ns/dcat#Dataset>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/identifier> "doi:10.14428/DVN/3M87GD";
    <http://purl.org/dc/terms/title> "Implementation of a search for dark matter in the mono-jet channel (3.2 fb-1; 13 TeV; ATLAS-EXOT-2015-03)"@en, "Implementatie van een zoektocht naar donkere materie in het mono-jetkanaal (3.2 fb-1; 13 TeV; ATLAS-EXOT-2015-03)"@nl-t-en, "Mise en œuvre d'une recherche de matière noire dans le canal mono-jet (3,2 fb-1; 13 TeV; ATLAS-EXOT-2015-03)"@fr-t-en, "Durchführung einer Suche nach Dunkler Materie im Monostrahlkanal (3.2 fb-1; 13 TeV; ATLAS-EXOT-2015-03)"@de-t-en;
    <http://purl.org/dc/terms/description> "Description: This consists of the implementation, in the MadAnalysis 5 framework, of an ATLAS search for dark matter in events featuring an energetic jet and a large amount of missing transverse energy. 3.2/fb of LHC proton-proton collisions at 13 TeV has been analysed.  \n \n  \n\nInformation on how to use this code and a detailed validation summary are available on the Public Analysis Database of MadAnalysis. The ATLAS analysis is documented on the collaboration wiki."@en, "Beschrijving: Dit bestaat uit de implementatie, in het MadAnalysis 5-raamwerk, van een ATLAS-zoektocht naar donkere materie in gebeurtenissen met een energetische straal en een grote hoeveelheid ontbrekende transversale energie. 3.2/fb van LHC proton-proton botsingen bij 13 TeV is geanalyseerd. \n\n\n\nInformatie over het gebruik van deze code en een gedetailleerde validatiesamenvatting zijn beschikbaar in de Public Analysis Database of MadAnalysis. De ATLAS-analyse is gedocumenteerd op de samenwerkingswiki."@nl-t-en, "Description : Il s'agit de la mise en œuvre, dans le cadre de MadAnalysis 5, d'une recherche ATLAS de matière noire dans des événements comportant un jet énergétique et une grande quantité d'énergie transversale manquante. 3.2/fb des collisions proton-proton du LHC à 13 TeV ont été analysées. \n\n\n\nDes informations sur l'utilisation de ce code et un résumé de validation détaillé sont disponibles sur la base de données d'analyse publique de MadAnalysis. L'analyse ATLAS est documentée sur le wiki de collaboration."@fr-t-en, "Beschreibung: Dies besteht in der Implementierung einer ATLAS-Suche nach dunkler Materie in Ereignissen mit einem energetischen Jet und einer großen Menge an fehlender transversaler Energie im MadAnalysis 5-Framework. 3,2/fb der LHC-Proton-Proton-Kollisionen bei 13 TeV wurden analysiert. \n\n\n\nInformationen zur Verwendung dieses Codes und eine detaillierte Validierungszusammenfassung sind in der Public Analysis Database of MadAnalysis verfügbar. Die ATLAS-Analyse wird im Collaboration-Wiki dokumentiert."@de-t-en;
    <http://purl.org/dc/terms/created> "2021-06-10T11:26:27Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/issued> "2021-06-10T11:30:54Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2021-06-10T11:30:54Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#version> "1";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeRegisteredEntity/0419052272>;
    <http://purl.org/dc/terms/creator> <http://data.gov.be/.well-known/genid/person/ucl/5072d6900cca35378a86a58d5f6a0bc4cc6d99c5>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/subject> "Physics";
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/3M87GD>;
    <http://purl.org/dc/terms/bibliographicCitation> "Sengupta, Dipan, 2021, \"Implementation of a search for dark matter in the mono-jet channel (3.2 fb-1; 13 TeV; ATLAS-EXOT-2015-03)\", https://doi.org/10.14428/DVN/3M87GD, Open Data @ UCLouvain, V1";
    <http://www.w3.org/ns/dcat#contactPoint> _:b54080_b54079_b54078_df_12_69088;
    <http://www.w3.org/ns/dcat#distribution> <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-179f6198b1a-cc3f70ab43a3>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-179f6198cc8-ac0db3ecf0da>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-179f6198e08-ca87f1e4a665>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-179f619b673-fc29345c3467>.
_:b54080_b54079_b54078_df_12_69088 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Fuks, Benjamin";
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "LPTHE / Sorbonne U.";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:fuks@lpthe.jussieu.fr>
}
<../../../index.trig> <https://w3id.org/tree#member> <#7be56e5de0090a775417a38e00b22f18>.
<#7be56e5de0090a775417a38e00b22f18> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/7SYXQ1>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:32:55.498Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#7be56e5de0090a775417a38e00b22f18> {
<http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/7SYXQ1> a <http://www.w3.org/ns/dcat#Dataset>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/identifier> "doi:10.14428/DVN/7SYXQ1";
    <http://purl.org/dc/terms/title> "Research Bibliography of Literature on the Formalist Tradition"@en, "Onderzoek Bibliografie van Literatuur over de Formalistische Traditie"@nl-t-en, "Bibliographie de la littérature sur la tradition formaliste"@fr-t-en, "Forschungsbibliographie der Literatur zur formalistischen Tradition"@de-t-en;
    <http://purl.org/dc/terms/description> "This is a bibliography of research literature relevant for the study of the Formalist tradition and authors (Formalists, formalistae, formalizantes) who wrote Formalist treatises or otherwise took part in the Formalist tradition. Some studies on the formal distinction in John Duns Scotus have been included, especially such ones that consider the later tradition. For the comprehensive literature on Duns Scotus and the formal distinction as discussed in his works, readers are referred to Tobias Hoffmann’s Duns Scotus Bibliography from 1950 to the Present (10th edition, August 2022) (URL: https://abelard.hypotheses.org/scotus-bibliography). Some publications on educational and institutional aspects relevant for an understanding of the Formalist tradition and its impact have been included.\nThis bibliography is a part of the output of Claus A. Andersen’s MSCA project FORMALITAS and will be continously updated on the FORMALITAS project website www.formalitas.eu."@en, "Dit is een bibliografie van onderzoeksliteratuur die relevant is voor de studie van de Formalistische traditie en auteurs (Formalisten, formalistae, formalizantes) die Formalistische verhandelingen hebben geschreven of anderszins hebben deelgenomen aan de Formalistische traditie. Sommige studies over het formele onderscheid in John Duns Scotus zijn opgenomen, vooral degenen die de latere traditie overwegen. Voor de uitgebreide literatuur over Duns Scotus en het formele onderscheid dat in zijn werken wordt besproken, wordt verwezen naar Tobias Hoffmann’s Duns Scotus Bibliography from 1950 to the Present (10e editie, augustus 2022) (URL: https://abelard.hypotheses.org/scotus-bibliography). Er zijn enkele publicaties opgenomen over educatieve en institutionele aspecten die relevant zijn voor een goed begrip van de formalistische traditie en de impact ervan. \nDeze bibliografie maakt deel uit van de output van het MSCA-project FORMALITAS van Claus A. Andersen en zal voortdurend worden bijgewerkt op de website van het FORMALITAS-project www.formalitas.eu."@nl-t-en, "Il s'agit d'une bibliographie de la littérature de recherche pertinente pour l'étude de la tradition formaliste et des auteurs (formalistes, formalistes, formalizantes) qui ont écrit des traités formalistes ou ont pris part à la tradition formaliste. Certaines études sur la distinction formelle chez John Duns Scotus ont été incluses, en particulier celles qui tiennent compte de la tradition ultérieure. Pour la littérature complète sur Duns Scotus et la distinction formelle telle que discutée dans ses œuvres, les lecteurs sont renvoyés à la bibliographie Duns Scotus de Tobias Hoffmann de 1950 à aujourd’hui (10e édition, août 2022) (URL: https://abelard.hypotheses.org/scotus-bibliography). Certaines publications sur les aspects éducatifs et institutionnels pertinents pour une compréhension de la tradition formaliste et de son impact ont été incluses. \nCette bibliographie fait partie des résultats du projet MSCA FORMALITAS de Claus A. Andersen et sera constamment mise à jour sur le site web du projet FORMALITAS www.formalitas.eu."@fr-t-en, "Dies ist eine Bibliographie der Forschungsliteratur, die für das Studium der formalistischen Tradition und der Autoren (Formalisten, Formalisten, Formalizenten) relevant ist, die formalistische Abhandlungen schrieben oder anderweitig an der formalistischen Tradition teilnahmen. Einige Studien über die formale Unterscheidung in John Duns Scotus wurden aufgenommen, insbesondere solche, die die spätere Tradition berücksichtigen. Für die umfassende Literatur zu Duns Scotus und die formale Unterscheidung, wie sie in seinen Werken diskutiert wird, wird auf Tobias Hoffmanns Duns Scotus Bibliographie von 1950 bis zur Gegenwart (10. Ausgabe, August 2022) verwiesen (URL: https://abelard.hypotheses.org/scotus-bibliography). Einige Veröffentlichungen zu pädagogischen und institutionellen Aspekten, die für das Verständnis der formalistischen Tradition und ihrer Auswirkungen relevant sind, wurden aufgenommen. \nDiese Bibliographie ist Teil der Ergebnisse des MSCA-Projekts FORMALITAS von Claus A. Andersen und wird kontinuierlich auf der FORMALITAS-Projektwebsite www.formalitas.eu aktualisiert."@de-t-en;
    <http://purl.org/dc/terms/created> "2025-04-04T10:12:16Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/issued> "2025-04-04T10:24:16Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2025-04-04T10:24:16Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#version> "1";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeRegisteredEntity/0419052272>;
    <http://purl.org/dc/terms/creator> <https://orcid.org/0000-0002-7042-2001>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://www.w3.org/ns/dcat#keyword> "Formalist tradition"@en;
    <http://purl.org/dc/terms/subject> "Arts and Humanities";
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/EDUC>, <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/7SYXQ1>;
    <http://purl.org/dc/terms/bibliographicCitation> "Andersen, Claus, 2025, \"Research Bibliography of Literature on the Formalist Tradition\", https://doi.org/10.14428/DVN/7SYXQ1, Open Data @ UCLouvain, V1";
    <http://purl.org/ontology/bibo/citedBy> _:b54083_b54082_b54081_df_12_69089;
    <http://www.w3.org/ns/dcat#contactPoint> _:b54083_b54082_b54081_df_12_69090;
    <http://www.w3.org/ns/dcat#distribution> <http://data.gov.be/.well-known/genid/dist/ucl/doi-10-14428/DVN/7SYXQ1/1MQYGK>.
_:b54083_b54082_b54081_df_12_69089 a <http://purl.org/ontology/bibo/Document>;
    <http://purl.org/dc/terms/title> "www.formalitas.eu".
_:b54083_b54082_b54081_df_12_69090 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Andersen, Claus";
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "Universite catholique de Louvain", "Université catholique de Louvain";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:claus.andersen@uclouvain.be>
}
