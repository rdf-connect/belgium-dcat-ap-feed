    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/subject> "Earth and Environmental Sciences";
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>, <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/5O6FJ3>;
    <http://purl.org/dc/terms/bibliographicCitation> "Thomas, Maxime; Fouché, Julien; Titeux, Hugues; Morelle, Charlotte; Bemelmans, Nathan; Lafrenière, Melissa; Heslop, Joanne K.; Opfergelt, Sophie, 2025, \"Mineral-bound organic carbon exposed by hillslope thermokarst terrain: case study in Cape Bounty, Canadian High Arctic\", https://doi.org/10.14428/DVN/5O6FJ3, Open Data @ UCLouvain, V1";
    <http://purl.org/ontology/bibo/citedBy> _:b54155_b54154_b54153_df_12_69124;
