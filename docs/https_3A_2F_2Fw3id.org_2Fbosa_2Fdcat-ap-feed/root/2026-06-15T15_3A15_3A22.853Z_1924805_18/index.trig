    <https://w3id.org/mobilitydcat-ap#mobilityTheme> <https://w3id.org/mobilitydcat-ap/mobility-theme/static-road-network-data>, <https://w3id.org/mobilitydcat-ap/mobility-theme/road-work-information>, <https://w3id.org/mobilitydcat-ap/mobility-theme/road-events-and-conditions>, <https://w3id.org/mobilitydcat-ap/mobility-theme/road-weather-conditions>, <https://w3id.org/mobilitydcat-ap/mobility-theme/real-time-traffic-data>;
    <https://w3id.org/mobilitydcat-ap#transportMode> <https://w3id.org/mobilitydcat-ap/transport-mode/car>, <https://w3id.org/mobilitydcat-ap/transport-mode/truck>, <https://w3id.org/mobilitydcat-ap/transport-mode/motorcycle>;
    <http://www.w3.org/ns/dcat#distribution> <https://transportdata.be/dataset/7b366d0b-2912-4b46-83f3-c1a68cb55e2a/resource/2b2bc5fa-d9b8-45e2-a2c1-d23b24ba9ca1>.
_:b54689_b54688_b54687_df_12_69458 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Be-Mobile";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:info@be-mobile.com>;
    <http://www.w3.org/2006/vcard/ns#hasTelephone> <tel:+3293305180>.
_:b54689_b54688_b54687_df_12_69459 a <http://purl.org/dc/terms/PeriodOfTime>;
    <http://www.w3.org/ns/dcat#startDate> "2023-04-07T13:32:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>
}
