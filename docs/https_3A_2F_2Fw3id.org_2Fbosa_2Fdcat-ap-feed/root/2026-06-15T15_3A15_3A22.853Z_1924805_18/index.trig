    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeRegisteredEntity/0419052272>;
    <http://purl.org/dc/terms/creator> <https://orcid.org/0000-0002-4083-0688>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/subject> "Chemistry";
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/2IPRXM>;
    <http://purl.org/dc/terms/bibliographicCitation> "Jonas, Alain, 2021, \"Videos of rebounds on Hegoa fabric (Fabric 7B of article)\", https://doi.org/10.14428/DVN/2IPRXM, Open Data @ UCLouvain, V1";
    <http://www.w3.org/ns/dcat#contactPoint> _:b54464_b54463_b54462_df_12_69291.
_:b54464_b54463_b54462_df_12_69291 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Jonas, Alain";
