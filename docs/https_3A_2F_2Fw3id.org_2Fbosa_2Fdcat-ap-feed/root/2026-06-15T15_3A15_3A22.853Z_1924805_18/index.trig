<#de525b10c0c20ce87e18251d7a509cdc> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/QR1WHK>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:32:56.045Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#de525b10c0c20ce87e18251d7a509cdc> {
<http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/QR1WHK> a <http://www.w3.org/ns/dcat#Dataset>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/identifier> "doi:10.14428/DVN/QR1WHK";
    <http://purl.org/dc/terms/title> "Implementation of a search for supersymmetry in the  di-lepton, multi-jet and missing energy channel (20.3 fb-1; 8 TeV; ATLAS-SUSY-2014-10)"@en, "Implementatie van een zoektocht naar supersymmetrie in het di-lepton, multi-jet en ontbrekende energiekanaal (20,3 fb-1; 8 TeV; ATLAS-SUSY-2014-10)"@nl-t-en, "Mise en œuvre d'une recherche de supersymétrie dans le canal d'énergie di-lepton, multi-jet et manquant (20,3 fb-1; 8 TeV; ATLAS-SUSY-2014-10)"@fr-t-en, "Durchführung einer Suche nach Supersymmetrie im Di-Lepton-, Multi-Jet- und fehlenden Energiekanal (20,3 fb-1; 8 TeV; ATLAS-SUSY-2014-10)"@de-t-en;
    <http://purl.org/dc/terms/description> "Description: This consists of the implementation, in the MadAnalysis 5 framework, of an ATLAS search in 20.3/fb of LHC proton-proton collisions at 8 TeV for supersymmetry in events featuring a pair of leptons, jets and missing transverse energy.\n \n  \n\nInformation on how to use this code and a detailed validation summary are available on the Public Analysis Database of MadAnalysis. The ATLAS analysis is documented on the collaboration wiki."@en, "Beschrijving: Dit bestaat uit de implementatie, in het MadAnalysis 5-framework, van een ATLAS-zoekopdracht in 20.3/fb van LHC-proton-protonbotsingen bij 8 TeV voor supersymmetrie in gebeurtenissen met een paar leptonen, jets en ontbrekende transversale energie.\n\n\n\nInformatie over het gebruik van deze code en een gedetailleerde validatiesamenvatting zijn beschikbaar in de Public Analysis Database of MadAnalysis. De ATLAS-analyse is gedocumenteerd op de samenwerkingswiki."@nl-t-en, "Description : Il s'agit de la mise en œuvre, dans le cadre de MadAnalysis 5, d'une recherche ATLAS dans 20,3/fb de collisions proton-proton du LHC à 8 TeV pour la supersymétrie dans des événements comportant une paire de leptons, des jets et une énergie transversale manquante.\n\n\n\nDes informations sur l'utilisation de ce code et un résumé de validation détaillé sont disponibles sur la base de données d'analyse publique de MadAnalysis. L'analyse ATLAS est documentée sur le wiki de collaboration."@fr-t-en, "Beschreibung: Dies besteht in der Implementierung einer ATLAS-Suche in 20.3/fb von LHC-Proton-Proton-Kollisionen bei 8 TeV für Supersymmetrie bei Ereignissen mit einem Paar Leptonen, Jets und fehlender transversaler Energie im MadAnalysis 5-Framework.\n\n\n\nInformationen zur Verwendung dieses Codes und eine detaillierte Validierungszusammenfassung sind in der Public Analysis Database of MadAnalysis verfügbar. Die ATLAS-Analyse wird im Collaboration-Wiki dokumentiert."@de-t-en;
    <http://purl.org/dc/terms/created> "2021-06-14T10:52:27Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/issued> "2021-06-14T10:54:07Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2021-06-14T10:54:07Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#version> "1";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeRegisteredEntity/0419052272>;
    <http://purl.org/dc/terms/creator> <http://data.gov.be/.well-known/genid/person/ucl/df0a79c02655587b2f4156e68f7a394b5ac9949a>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/subject> "Physics";
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/QR1WHK>;
    <http://purl.org/dc/terms/bibliographicCitation> "Dumont, Beranger, 2021, \"Implementation of a search for supersymmetry in the di-lepton, multi-jet and missing energy channel (20.3 fb-1; 8 TeV; ATLAS-SUSY-2014-10)\", https://doi.org/10.14428/DVN/QR1WHK, Open Data @ UCLouvain, V1";
    <http://www.w3.org/ns/dcat#contactPoint> _:b54404_b54403_b54402_df_12_69257;
    <http://www.w3.org/ns/dcat#distribution> <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-17a0a93f01d-b4dd4c0c1b89>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-17a0a93f13c-cb29f01c32cb>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-17a0a93f27e-fc9ac39096f2>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-17a0a94749e-05ce955a325c>.
_:b54404_b54403_b54402_df_12_69257 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Fuks, Benjamin";
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "LPTHE / Sorbonne U.";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:fuks@lpthe.jussieu.fr>
}
<../../../index.trig> <https://w3id.org/tree#member> <#8e8de8a844f6ef3f0c6a055f3b785d45>.
<#8e8de8a844f6ef3f0c6a055f3b785d45> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/ISBKR0>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:32:56.050Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#8e8de8a844f6ef3f0c6a055f3b785d45> {
<http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/ISBKR0> a <http://www.w3.org/ns/dcat#Dataset>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/identifier> "doi:10.14428/DVN/ISBKR0";
    <http://purl.org/dc/terms/title> "Di-prescribe: Behavioral Determinants of Deprescribing Questionnaire (BDDQ)"@en, "Di-voorschrijven: Behavioral Determinants of Deprescribing Questionnaire (BDDQ) (gedragsdeterminanten van het beschrijven van vragenlijsten)"@nl-t-en, "Di-prescrire: Déterminants comportementaux de la déprescription Questionnaire (BDDQ)"@fr-t-en, "Di-prescribe: Verhaltensdeterminanten des Deprescribing Questionnaire (BDDQ)"@de-t-en;
    <http://purl.org/dc/terms/description> "This dataset includes responses from 103 French-speaking Belgian citizens collected for the validation of the Behavioral Determinants of Deprescribing Questionnaire (BDDQ). The questionnaire was developed based on a previous systematic review that identified the core dimensions of deprescribing behavior and intention. Data was collected at the individual level between February and mid-April 2024. The dataset is subject to the General Data Protection Regulation (GDPR). All participants provided informed consent for the processing of their data by UCLouvain for scientific purposes."@en, "Deze dataset bevat antwoorden van 103 Franstalige Belgische burgers verzameld voor de validatie van de Behavioral Determinants of Deprescribing Questionnaire (BDDQ). De vragenlijst is ontwikkeld op basis van een eerdere systematische review die de kerndimensies van het beschrijven van gedrag en intentie identificeerde. Tussen februari en medio april 2024 werden op individueel niveau gegevens verzameld. De gegevensset is onderworpen aan de Algemene Verordening Gegevensbescherming (AVG). Alle deelnemers gaven geïnformeerde toestemming voor de verwerking van hun gegevens door UCLouvain voor wetenschappelijke doeleinden."@nl-t-en, "Cet ensemble de données comprend les réponses de 103 citoyens belges francophones recueillies pour la validation du questionnaire sur les déterminants comportementaux de la déprescription (BDDQ). Le questionnaire a été élaboré sur la base d'une revue systématique précédente qui a identifié les dimensions fondamentales de la déprescription du comportement et de l'intention. Les données ont été collectées au niveau individuel entre février et la mi-avril 2024. L'ensemble de données est soumis au règlement général sur la protection des données (RGPD). Tous les participants ont donné leur consentement éclairé au traitement de leurs données par l'UCLouvain à des fins scientifiques."@fr-t-en, "Dieser Datensatz enthält Antworten von 103 französischsprachigen belgischen Bürgern, die für die Validierung des Behavioral Determinants of Deprescribing Questionnaire (BDDQ) erhoben wurden. Der Fragebogen wurde auf der Grundlage einer früheren systematischen Überprüfung entwickelt, die die Kerndimensionen des Abschreibens von Verhalten und Intention identifizierte. Die Daten wurden zwischen Februar und Mitte April 2024 auf Einzelebene erhoben. Der Datensatz unterliegt der Datenschutz-Grundverordnung (DSGVO). Alle Teilnehmer erteilten eine informierte Einwilligung zur Verarbeitung ihrer Daten durch UCLouvain für wissenschaftliche Zwecke."@de-t-en;
    <http://purl.org/dc/terms/created> "2025-09-12T13:58:46Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/issued> "2025-09-12T14:03:31Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2025-09-12T14:03:31Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#version> "1";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeRegisteredEntity/0419052272>;
    <http://purl.org/dc/terms/creator> <http://data.gov.be/.well-known/genid/person/ucl/520e64467ade2df4d82da18eb4b3a47c3200a2eb>, <http://data.gov.be/.well-known/genid/person/ucl/c3eecf38aadf1554d4578e071df2392df2edad74>, <http://data.gov.be/.well-known/genid/person/ucl/4191c2b7ab03e0f4a168998731c84f7b95696043>, <http://data.gov.be/.well-known/genid/person/ucl/e0f859f310f3a3615bd036aab2100c6af2732711>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://www.w3.org/ns/dcat#keyword> "Deprescribing"@en, "Health behavior theories"@en, "Older adults"@en, "Psychometric properties"@en;
    <http://purl.org/dc/terms/subject> "Medicine, Health and Life Sciences";
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/HEAL>, <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/ISBKR0>;
    <http://purl.org/dc/terms/bibliographicCitation> "Alves Jorge, Sara; Van den Broucke Stephan; de Saint-Hubert Marie; Spinewine Anne, 2025, \"Di-prescribe: Behavioral Determinants of Deprescribing Questionnaire (BDDQ)\", https://doi.org/10.14428/DVN/ISBKR0, Open Data @ UCLouvain, V1";
    <http://www.w3.org/ns/dcat#contactPoint> _:b54407_b54406_b54405_df_12_69258;
    <http://www.w3.org/ns/dcat#distribution> <http://data.gov.be/.well-known/genid/dist/ucl/doi-10-14428/DVN/ISBKR0/NARAL5>.
_:b54407_b54406_b54405_df_12_69258 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Alves Jorge, Sara";
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "Universite catholique de Louvain";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:sara.alvesjorge@uclouvain.be>
}
