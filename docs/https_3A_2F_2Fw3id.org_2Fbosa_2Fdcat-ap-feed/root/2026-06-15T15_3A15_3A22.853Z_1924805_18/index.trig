<../../../index.trig> <https://w3id.org/tree#member> <#73a668851440669cfee792731a931dba>.
<#73a668851440669cfee792731a931dba> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://data.aeronomie.be/dataset/a28eff65-50f8-4310-b690-9e147bda357a/resource/d1c2dd37-c032-467d-9e09-b2dbfc828028>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:32:59.883Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#73a668851440669cfee792731a931dba> {
<https://data.aeronomie.be/dataset/a28eff65-50f8-4310-b690-9e147bda357a/resource/d1c2dd37-c032-467d-9e09-b2dbfc828028> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/title> "Harmonised satellite tropospheric ozone Climate Data Records (TAPIOWCA) (Version 1)"@en;
    <http://purl.org/dc/terms/description> "This file contains 16 satellite tropospheric ozone column Climate Data Records (monthly, 1° latitude x 1° longitude gridded) that were processed to harmonise their vertical top levels as well as their prior information. This netCDF file contains the following data records with various horizontal and temporal coverages: GOME, SCIAMACHY, OMI, GOME-2A, and GOME-2B (RAL/ESA); GOP-ECV (DLR/ESA); TROPOMI (KNMI/ESA); IASI-CDR (ULB/LATMOS/EUMETSAT); IASI-GOME2-B (LISA/AERIS); GTTO-ECV (DLR/BIRA-IASB/ESA); GTO-LIMB and OMI-LIMB (FMI/DLR/ESA); OMPS-LNM (IUP-UB); and OMI-MLS, OMPS-MERRA2, and EPIC-MERRA2 (GSFC/NASA). The Copernicus Atmosphere Monitoring Service ReAnalysis (CAMSRA) was used as a transfer standard for harmonisation, limiting the output CDRs to 2003-2023."@en;
    <http://purl.org/dc/terms/issued> "2025-12-10T11:56:12.050263"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2025-12-10T12:02:03.822872"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#mediaType> <https://www.iana.org/assignments/media-types/application/x-netcdf>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/NETCDF>;
    <http://www.w3.org/ns/dcat#accessURL> <https://data.aeronomie.be/dataset/a28eff65-50f8-4310-b690-9e147bda357a>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://data.aeronomie.be/dataset/a28eff65-50f8-4310-b690-9e147bda357a/resource/d1c2dd37-c032-467d-9e09-b2dbfc828028/download/2025_toar_sat_harm_bira-iasb.v1.0.nc>;
    <http://purl.org/dc/terms/license> <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>;
    <http://www.w3.org/ns/dcat#byteSize> "1045119737"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>
}
