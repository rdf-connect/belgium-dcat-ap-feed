<http://data.gov.be/.well-known/genid/dataset/foodtruck/foodtruck-cuisine-classification> a <http://www.w3.org/ns/dcat#Dataset>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/NLD>, <http://publications.europa.eu/resource/authority/language/FRA>, <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/identifier> "http://belgianfoodtruckfederation.org/dataset/yaml/opendata/foodtruck-cuisine-classification/";
    <http://purl.org/dc/terms/title> "Standard international des concepts culinaires pour food trucks"@fr, "Internationale standaard voor culinaire concepten voor food trucks"@nl, "International Standard for Culinary Concepts for Food Trucks"@en, "Internationaler Standard für kulinarische Konzepte für Food Trucks"@de-t-en;
    <http://purl.org/dc/terms/description> "Référentiel multilingue et hiérarchisé de classification des cuisines pour food-trucks. Conçu pour l'uniformisation terminologique et l'établissement d'une taxonomie universelle par la Belgian Food Truck Federation (BFTFED). Publié sous licence CC BY 4.0."@fr, "Meertalig en hiërarchisch referentiekader voor de classificatie van keukens voor foodtrucks. Ontworpen voor terminologische uniformiteit en het opzetten van een universele taxonomie door de Belgian Food Truck Federation (BFTFED). Gepubliceerd onder licentie CC BY 4.0."@nl, "Multilingual and hierarchical classification reference of cuisines for food trucks. Designed for terminological uniformity and establishing a universal taxonomy by the Belgian Food Truck Federation (BFTFED). Published under CC BY 4.0 license."@en, "Mehrsprachige und hierarchische Klassifizierungsreferenz von Küchen für Food Trucks. Konzipiert für die terminologische Einheitlichkeit und die Etablierung einer universellen Taxonomie durch den belgischen Food Truck Federation (BFTFED). Veröffentlicht unter CC BY 4.0 Lizenz."@de-t-en;
    <http://purl.org/dc/terms/created> "2025-01-01"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2025-12-11"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#version> "1.0.2";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeRegisteredEntity/0689677423>;
    <http://purl.org/dc/terms/creator> <http://data.gov.be/.well-known/genid/person/foodtruck/6db96080c8d03b3ee9b03e0e3676c04bec5cc80b>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://www.w3.org/ns/dcat#keyword> "food trucks"@fr, "cuisine"@fr, "taxonomie"@fr, "classification"@fr, "open data"@fr, "international"@fr, "concept culinaire"@fr, "food trucks"@nl, "keuken"@nl, "taxonomie"@nl, "classificatie"@nl, "open data"@nl, "internationaal"@nl, "culinair concept"@nl, "food trucks"@en, "cuisine"@en, "taxonomy"@en, "classification"@en, "open data"@en, "international"@en, "culinary concept"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ECON>;
    <http://www.w3.org/ns/dcat#landingPage> <https://belgianfoodtruckfederation.org/fr/open-data/>, <https://belgianfoodtruckfederation.org/nl/open-data/>;
