    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeRegisteredEntity/0419052272>;
    <http://purl.org/dc/terms/creator> <http://data.gov.be/.well-known/genid/person/ucl/e42a714654e03c8262ec879029b3b4903540221c>, <http://data.gov.be/.well-known/genid/person/ucl/a025548809a14272d00c3ab621fea4df5d8e7ad9>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/subject> "Social Sciences";
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/TECH>;
