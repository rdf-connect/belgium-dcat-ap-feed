_:b54470_b54469_b54468_df_12_69294 a <http://purl.org/ontology/bibo/Document>;
    <http://purl.org/dc/terms/title> "Richaud, B., Massonnet, F., Fichefet, T., Topál, D., Barthélemy, A., and Docquier, D.: Anatomy of Arctic and Antarctic sea ice lows in an ocean–sea ice model, The Cryosphere, 20, 791–810, 2026.";
    <http://purl.org/dc/terms/identifier> "10.5194/tc-20-791-2026";
