_:b54470_b54469_b54468_df_12_69296 a <http://xmlns.com/foaf/0.1/Project>.
_:b54470_b54469_b54468_df_12_69297 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Barthélemy, Antoine";
