<../../../index.trig> <https://w3id.org/tree#member> <#11749b1a79d3060a52101652fae32a7d>.
<#11749b1a79d3060a52101652fae32a7d> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://transportdata.be/dataset/0ac30f21-2a58-4ed3-bd4a-c20af72c5865>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:32:56.603Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#11749b1a79d3060a52101652fae32a7d> {
<https://transportdata.be/dataset/0ac30f21-2a58-4ed3-bd4a-c20af72c5865> a <http://www.w3.org/ns/dcat#Dataset>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/NLD>;
    <http://purl.org/dc/terms/identifier> "0ac30f21-2a58-4ed3-bd4a-c20af72c5865";
    <http://purl.org/dc/terms/title> "TN-ITS"@nl, "TN-ITS"@fr-t-nl, "TN-ITS"@de-t-nl, "TN-ITS"@en-t-nl;
    <http://purl.org/dc/terms/description> "De Vlaamse TN-ITS service wordt beschikbaar gesteld door het Agentschap Wegen en Verkeer sinds 2016 (piloot service). Deze service publiceert wijzigingen aan (statische) snelheidsregimes en andere verkeersborden (vb. voertuigbeperkingen) in Vlaanderen, zowel als puntelement dan als lijnelement. Verschillende manieren van location referencing (OpenLR, GML) zijn beschikbaar om het hergebruik van deze service te maximaliseren."@nl, "The Flemish TN-ITS service is available via the Agentschap Wegen en Verkeer and operational as a pilot service since 2016. The service mainly publishes changes of speed limits and traffic restrictions for roads in the Flemish region, supporting both point and linear features. Different types of location referencing methods are available to maximize the re-use of the information (OpenLR, GML)."@en, "Le service flamand TN-ITS est disponible via l'Agentschap Wegen en Verkeer et opérationnel en tant que service pilote depuis 2016. Le service publie principalement des modifications des limitations de vitesse et des restrictions de circulation pour les routes de la région flamande, en soutenant à la fois les caractéristiques ponctuelles et linéaires. Différents types de méthodes de référencement de localisation sont disponibles pour maximiser la réutilisation de l'information (OpenLR, GML)."@fr-t-en, "Der flämische TN-ITS-Dienst ist über die Agentschap Wegen en Verkeer verfügbar und seit 2016 als Pilotdienst in Betrieb. Der Dienst veröffentlicht hauptsächlich Änderungen der Geschwindigkeitsbegrenzungen und Verkehrsbeschränkungen für Straßen in der flämischen Region und unterstützt sowohl punktuelle als auch lineare Funktionen. Verschiedene Arten von Standortreferenzierungsmethoden stehen zur Verfügung, um die Wiederverwendung der Informationen zu maximieren (OpenLR, GML)."@de-t-en;
    <http://purl.org/dc/terms/issued> "2020-05-19T08:44:44.829220"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2024-12-18T12:05:40.537196"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeEstablishmentUnit/2143729494>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg_del/2017/1926/oj>, <http://data.europa.eu/eli/reg_del/2022/670/oj>;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TRAN>;
    <http://www.w3.org/ns/dcat#landingPage> <https://transportdata.be/dataset/0ac30f21-2a58-4ed3-bd4a-c20af72c5865#>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b54743_b54742_b54741_df_12_69500;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337388/>;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/DAILY>;
    <http://purl.org/dc/terms/temporal> _:b54743_b54742_b54741_df_12_69501;
    <https://w3id.org/mobilitydcat-ap#mobilityTheme> <https://w3id.org/mobilitydcat-ap/mobility-theme/static-traffic-signs-and-regulations>;
    <https://w3id.org/mobilitydcat-ap#transportMode> <https://w3id.org/mobilitydcat-ap/transport-mode/car>, <https://w3id.org/mobilitydcat-ap/transport-mode/truck>, <https://w3id.org/mobilitydcat-ap/transport-mode/motorcycle>;
    <http://www.w3.org/ns/dcat#distribution> <https://transportdata.be/dataset/0ac30f21-2a58-4ed3-bd4a-c20af72c5865/resource/919659d2-495b-491a-a68e-3aa4f4a1234b>.
_:b54743_b54742_b54741_df_12_69500 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Agentschap Wegen en Verkeer";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:wegen.verkeer@mow.vlaanderen.be>;
    <http://www.w3.org/2006/vcard/ns#hasTelephone> <tel:+3225537901>.
_:b54743_b54742_b54741_df_12_69501 a <http://purl.org/dc/terms/PeriodOfTime>;
    <http://www.w3.org/ns/dcat#startDate> "2016-12-31T10:44:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>
}
