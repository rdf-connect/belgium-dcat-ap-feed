<../../../index.trig> <https://w3id.org/tree#member> <#9df3a99f6c6f47a208b1bbd269b93486>.
<#9df3a99f6c6f47a208b1bbd269b93486> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/I5IFG8>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:32:55.570Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#9df3a99f6c6f47a208b1bbd269b93486> {
<http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/I5IFG8> a <http://www.w3.org/ns/dcat#Dataset>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/identifier> "doi:10.14428/DVN/I5IFG8";
    <http://purl.org/dc/terms/title> "Implementation of a search for squarks and gluinos in the multi-jet + missing energy channel (36.1 fb-1; 13 TeV; ATLAS-SUSY-2016-07)"@en, "Implementatie van een zoektocht naar squarks en gluinos in het multi-jet + ontbrekende energiekanaal (36.1 fb-1; 13 TeV; ATLAS-SUSY-2016-07)"@nl-t-en, "Mise en œuvre d'une recherche de squarks et de gluinos dans le canal d'énergie multijet + manquant (36.1 fb-1; 13 TeV; ATLAS-SUSY-2016-07)"@fr-t-en, "Durchführung einer Suche nach Squarks und Gluinos im Multijet + fehlender Energiekanal (36,1 fb-1; 13 TeV; ATLAS-SUSY-2016-07)"@de-t-en;
    <http://purl.org/dc/terms/description> "Description: This consists of the implementation, in the MadAnalysis 5 framework, of an ATLAS search for squarks and gluinos in events featuring multiple jets and a large amount of missing energy. 36.1/fb of LHC proton-proton collisions at 13 TeV has been analysed.  \n \n  \n\nInformation on how to use this code and a detailed validation summary are available on the Public Analysis Database of MadAnalysis. The ATLAS analysis is documented on the collaboration wiki."@en, "Beschrijving: Dit bestaat uit de implementatie, in het MadAnalysis 5-framework, van een ATLAS-zoektocht naar squarks en gluino's in evenementen met meerdere jets en een grote hoeveelheid ontbrekende energie. 36,1/fb aan LHC-proton-protonbotsingen bij 13 TeV is geanalyseerd. \n\n\n\nInformatie over het gebruik van deze code en een gedetailleerde validatiesamenvatting zijn beschikbaar in de Public Analysis Database of MadAnalysis. De ATLAS-analyse is gedocumenteerd op de samenwerkingswiki."@nl-t-en, "Description : Il s'agit de la mise en œuvre, dans le cadre de MadAnalysis 5, d'une recherche ATLAS de squarks et de gluinos dans des événements comportant plusieurs jets et une grande quantité d'énergie manquante. 36,1/fb de collisions proton-proton du LHC à 13 TeV a été analysé. \n\n\n\nDes informations sur l'utilisation de ce code et un résumé de validation détaillé sont disponibles sur la base de données d'analyse publique de MadAnalysis. L'analyse ATLAS est documentée sur le wiki de collaboration."@fr-t-en, "Beschreibung: Dies besteht in der Implementierung einer ATLAS-Suche nach Squarks und Gluinos im Rahmen von MadAnalysis 5 bei Ereignissen mit mehreren Jets und einer großen Menge an fehlender Energie. 36.1/fb von LHC-Proton-Proton-Kollisionen bei 13 TeV wurden analysiert. \n\n\n\nInformationen zur Verwendung dieses Codes und eine detaillierte Validierungszusammenfassung sind in der Public Analysis Database of MadAnalysis verfügbar. Die ATLAS-Analyse wird im Collaboration-Wiki dokumentiert."@de-t-en;
    <http://purl.org/dc/terms/created> "2021-06-10T07:52:57Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/issued> "2021-06-10T07:56:03Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2021-06-10T07:56:03Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#version> "1";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeRegisteredEntity/0419052272>;
    <http://purl.org/dc/terms/creator> <http://data.gov.be/.well-known/genid/person/ucl/9bd4e8a0f94d80b34f1607104db3c0dcb77850db>, <http://data.gov.be/.well-known/genid/person/ucl/3d9ad087e73af6e56ee20c7a226eb04588ab55d0>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/subject> "Physics";
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/I5IFG8>;
    <http://purl.org/dc/terms/bibliographicCitation> "Chalons, Guillaume; Reyes-Gonzalez, Humberto, 2021, \"Implementation of a search for squarks and gluinos in the multi-jet + missing energy channel (36.1 fb-1; 13 TeV; ATLAS-SUSY-2016-07)\", https://doi.org/10.14428/DVN/I5IFG8, Open Data @ UCLouvain, V1";
    <http://www.w3.org/ns/dcat#contactPoint> _:b54128_b54127_b54126_df_12_69112;
    <http://www.w3.org/ns/dcat#distribution> <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-179f553ab61-2b85ec18ce19>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-179f553acdd-b8f82c02878a>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-179f553ae23-664141c5802c>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-179f5562fc5-a9314006ec39>.
_:b54128_b54127_b54126_df_12_69112 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Fuks, Benjamin";
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "LPTHE / Sorbonne U.";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:fuks@lpthe.jussieu.fr>
}
<../../../index.trig> <https://w3id.org/tree#member> <#e16adfdac715914c6791931b062ef890>.
<#e16adfdac715914c6791931b062ef890> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/YA8E9V>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:32:55.575Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#e16adfdac715914c6791931b062ef890> {
<http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/YA8E9V> a <http://www.w3.org/ns/dcat#Dataset>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/identifier> "doi:10.14428/DVN/YA8E9V";
    <http://purl.org/dc/terms/title> "Re-implementation of the soft lepton + missing energy analysis of CMS (35.9 fb-1; CMS-SUS-16-048)"@en, "Herimplementatie van de soft lepton + missing energy analyse van CMS (35,9 fb-1; CMS-SUS-16-048)"@nl-t-en, "Remise en œuvre du lepton souple + analyse énergétique manquante du CMS (35,9 fb-1; CMS-SUS-16-048)"@fr-t-en, "Neuimplementierung des weichen Leptons + fehlende Energieanalyse von CMS (35,9 fb-1; CMS-SUS-16-048)"@de-t-en;
    <http://purl.org/dc/terms/description> "Description: This consists of the re-implementation, in the MadAnalysis 5 framework, of a CMS search for electroweakinos when they are pair-produced in association with soft leptons. 35.9/fb of LHC proton-proton collisions at 13 TeV has been analyzed.  \n \n  \r\n\r\nInformation on how to use this code and a detailed validation summary are available on the Public Analysis Database of MadAnalysis. The CMS analysis is documented on the collaboration wiki."@en, "Beschrijving: Dit bestaat uit de herimplementatie, in het MadAnalysis 5-framework, van een CMS-zoekopdracht naar elektroweakino's wanneer ze paarsgewijs worden geproduceerd in combinatie met zachte leptonen. 35.9/fb van LHC proton-proton botsingen bij 13 TeV is geanalyseerd. \n\n\n\nInformatie over het gebruik van deze code en een gedetailleerde validatiesamenvatting zijn beschikbaar in de Public Analysis Database of MadAnalysis. De CMS-analyse is gedocumenteerd op de samenwerkingswiki."@nl-t-en, "Description : Il s'agit de la ré-implémentation, dans le cadre de MadAnalysis 5, d'une recherche CMS d'électroweakinos lorsqu'ils sont produits en association avec des leptons mous. On a analysé 35,9/fb des collisions proton-proton du LHC à 13 TeV. \n\n\n\nDes informations sur l'utilisation de ce code et un résumé de validation détaillé sont disponibles sur la base de données d'analyse publique de MadAnalysis. L'analyse CMS est documentée sur le wiki de collaboration."@fr-t-en, "Beschreibung: Dies besteht in der Neuimplementierung einer CMS-Suche nach Elektroweakinos im MadAnalysis 5-Framework, wenn sie paarweise in Verbindung mit weichen Leptonen hergestellt werden. 35,9/fb von LHC-Proton-Proton-Kollisionen bei 13 TeV wurden analysiert. \n\n\n\nInformationen zur Verwendung dieses Codes und eine detaillierte Validierungszusammenfassung sind in der Public Analysis Database of MadAnalysis verfügbar. Die CMS-Analyse wird im Collaboration-Wiki dokumentiert."@de-t-en;
    <http://purl.org/dc/terms/created> "2022-05-04T10:42:59Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/issued> "2022-05-04T10:44:05Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2022-05-04T10:44:05Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#version> "2";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeRegisteredEntity/0419052272>;
    <http://purl.org/dc/terms/creator> <https://orcid.org/0000-0002-0041-0566>, <https://orcid.org/0000-0002-3215-9652>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/subject> "Physics";
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/YA8E9V>;
    <http://purl.org/dc/terms/bibliographicCitation> "Fuks, Benjamin, 2020, \"Re-implementation of the soft lepton + missing energy analysis of CMS (35.9 fb-1; CMS-SUS-16-048)\", https://doi.org/10.14428/DVN/YA8E9V, Open Data @ UCLouvain, V2";
    <http://purl.org/ontology/bibo/citedBy> _:b54131_b54130_b54129_df_12_69113;
    <http://www.w3.org/ns/dcat#contactPoint> _:b54131_b54130_b54129_df_12_69114;
    <http://www.w3.org/ns/dcat#distribution> <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-173289798cd-736b75bdb114>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-17328979acc-d7757cadc0b6>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-1808f181bb2-73f664517b1f>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-173289706cf-acb527c17e74>.
_:b54131_b54130_b54129_df_12_69113 a <http://purl.org/ontology/bibo/Document>;
    <http://purl.org/dc/terms/title> "G. Brooijmans, A. Buckley, S. Caron, A. Falkowski, B. Fuks et al.,\r\nLes Houches 2019 Physics at TeV Colliders: New Physics Working Group Report,\r\n[arXiv:2002.12220 [hep-ph]].";
    <http://purl.org/dc/terms/identifier> "2002.12220";
    <http://purl.org/ontology/bibo/uri> <https://arxiv.org/abs/2002.12220>.
