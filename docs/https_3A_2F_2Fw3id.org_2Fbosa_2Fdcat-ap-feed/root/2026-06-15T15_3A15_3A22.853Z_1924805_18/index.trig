    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/subject> "Physics";
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/I2CZWU>;
    <http://purl.org/dc/terms/bibliographicCitation> "Murphy, Taylor, 2021, \"Implementation of a search for supersymmetry in the multijet (at least 8 jets) + missing energy channel (139/fb; 13 TeV; ATLAS-SUSY-2018-17)\", https://doi.org/10.14428/DVN/I2CZWU, Open Data @ UCLouvain, V1";
    <http://www.w3.org/ns/dcat#contactPoint> _:b54062_b54061_b54060_df_12_69080;
    <http://www.w3.org/ns/dcat#distribution> <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-17cb7bb0a9c-890400cc3373>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-17cb7bb0c3b-eec96163d60a>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-17cb7bb0869-839f52112e46>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-17cb7bd5aeb-d8055bb72edf>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-17cb7bdae94-6fa11506c54f>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-17cb7bdb0eb-a3b472797a41>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-17cb7bdbb03-b5ae4881191d>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-17cb7bdab98-1b2bc6da5de8>.
_:b54062_b54061_b54060_df_12_69080 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Murphy, Taylor";
