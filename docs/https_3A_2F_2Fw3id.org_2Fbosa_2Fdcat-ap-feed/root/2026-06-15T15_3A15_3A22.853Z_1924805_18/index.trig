    <http://purl.org/dc/terms/bibliographicCitation> "Vermonden, Perrine; Cuvelier, Géraldine; Martin, Manon; Larondelle, Yvan, 2025, \"Processed lipidomic data on prostate and breast cancer cells\", https://doi.org/10.14428/DVN/RFGZVW, Open Data @ UCLouvain, V1, UNF:6:ORPJ5CT6qK6pzAgVmXvt5w== [fileUNF]";
    <http://purl.org/ontology/bibo/citedBy> _:b54365_b54364_b54363_df_12_69236;
