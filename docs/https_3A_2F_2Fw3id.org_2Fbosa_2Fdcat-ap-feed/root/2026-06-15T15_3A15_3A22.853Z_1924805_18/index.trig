    <http://purl.org/dc/terms/bibliographicCitation> "Bogaert, Jérémie; Escouflaire, Louis, 2024, \"Corpus InfOpinion-RTBF\", https://doi.org/10.14428/DVN/DMYIHZ, Open Data @ UCLouvain, V1";
    <http://purl.org/ontology/bibo/citedBy> _:b54341_b54340_b54339_df_12_69216;
    <http://www.w3.org/ns/dcat#contactPoint> _:b54341_b54340_b54339_df_12_69217;
    <http://www.w3.org/ns/dcat#distribution> <http://data.gov.be/.well-known/genid/dist/ucl/doi-10-14428/DVN/DMYIHZ/EZKE5S>, <http://data.gov.be/.well-known/genid/dist/ucl/doi-10-14428/DVN/DMYIHZ/PQ7RJ5>.
_:b54341_b54340_b54339_df_12_69216 a <http://purl.org/ontology/bibo/Document>;
    <http://purl.org/dc/terms/title> "Bogaert, J., Escouflaire, L., de Marneffe, M. C., Descampe, A., Standaert, F. X., & Fairon, C. (2023). TIPECS: A corpus cleaning method using machine learning and qualitative analysis. In International Conference on Corpus Linguistics (JLC).".
_:b54341_b54340_b54339_df_12_69217 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Escouflaire, Louis";
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "Universite catholique de Louvain";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:louis.escouflaire@uclouvain.be>
}
