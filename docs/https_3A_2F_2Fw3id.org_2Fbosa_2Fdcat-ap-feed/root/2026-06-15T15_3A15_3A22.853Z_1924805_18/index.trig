    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/GGOXOS>;
    <http://purl.org/dc/terms/bibliographicCitation> "Samofalova, Yuliya; Catellani, Andrea; Pizarro Pedraza, Andrea; Cougnon, Louise-Amélie, 2023, \"Multi-platform corpora from climate change opinion leading organizations in Belgium, France, and Norway\", https://doi.org/10.14428/DVN/GGOXOS, Open Data @ UCLouvain, V1";
