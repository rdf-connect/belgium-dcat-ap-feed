    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>, <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/JSDC8Q>;
    <http://purl.org/dc/terms/bibliographicCitation> "Barthélemy, Antoine; Richaud, Benjamin; Topal, Daniel; Massonnet, François; Fichefet, Thierry; Goosse, Hugues; Docquier, David, 2026, \"Global sea ice and ocean fields simulated with the model NEMO 4.2.2 - SI3 in three configurations of increasing horizontal resolution\", https://doi.org/10.14428/DVN/JSDC8Q, Open Data @ UCLouvain, V1";
    <http://purl.org/ontology/bibo/citedBy> _:b54470_b54469_b54468_df_12_69294, _:b54470_b54469_b54468_df_12_69295;
