<../../../index.trig> <https://w3id.org/tree#member> <#aa9e8bf40897398606e944dfc8f91538>.
<#aa9e8bf40897398606e944dfc8f91538> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/RSDO9W>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:32:55.677Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#aa9e8bf40897398606e944dfc8f91538> {
<http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/RSDO9W> a <http://www.w3.org/ns/dcat#Dataset>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/identifier> "doi:10.14428/DVN/RSDO9W";
    <http://purl.org/dc/terms/title> "Implementation of a search for dark matter in the mono-Z channel (2.3 fb-1; 13 TeV; CMS-EXO-16-010)"@en, "Implementatie van een zoektocht naar donkere materie in het mono-Z kanaal (2,3 fb-1; 13 TeV; CMS-EXO-16-010)"@nl-t-en, "Mise en œuvre d'une recherche de matière noire dans le canal mono-Z (2,3 fb-1; 13 TeV; CMS-EXO-16-010)"@fr-t-en, "Durchführung einer Suche nach Dunkler Materie im Mono-Z-Kanal (2,3 fb-1; 13 TeV; CMS-EXO-16-010)"@de-t-en;
    <http://purl.org/dc/terms/description> "Description: This consists of the implementation, in the MadAnalysis 5 framework, of a CMS search for dark matter when it is produced in association with a Z-boson. 2.3/fb of LHC proton-proton collisions at 13 TeV has been analyzed.  \n \n  \n\nInformation on how to use this code and a detailed validation summary are available on the Public Analysis Database of MadAnalysis. The CMS analysis is documented on the collaboration wiki."@en, "Beschrijving: Dit bestaat uit de implementatie, in het MadAnalysis 5-framework, van een CMS-zoekopdracht naar donkere materie wanneer deze wordt geproduceerd in samenwerking met een Z-boson. 2.3/fb van LHC proton-proton botsingen bij 13 TeV is geanalyseerd. \n\n\n\nInformatie over het gebruik van deze code en een gedetailleerde validatiesamenvatting zijn beschikbaar in de Public Analysis Database of MadAnalysis. De CMS-analyse is gedocumenteerd op de samenwerkingswiki."@nl-t-en, "Description : Il s'agit de l'implémentation, dans le framework MadAnalysis 5, d'une recherche CMS de matière noire lorsqu'elle est produite en association avec un Z-boson. 2.3/fb des collisions proton-proton du LHC à 13 TeV ont été analysées. \n\n\n\nDes informations sur l'utilisation de ce code et un résumé de validation détaillé sont disponibles sur la base de données d'analyse publique de MadAnalysis. L'analyse CMS est documentée sur le wiki de collaboration."@fr-t-en, "Beschreibung: Dies besteht in der Implementierung einer CMS-Suche nach dunkler Materie im MadAnalysis 5-Framework, wenn sie in Verbindung mit einem Z-Boson produziert wird. 2,3/fb LHC-Proton-Proton-Kollisionen bei 13 TeV wurden analysiert. \n\n\n\nInformationen zur Verwendung dieses Codes und eine detaillierte Validierungszusammenfassung sind in der Public Analysis Database of MadAnalysis verfügbar. Die CMS-Analyse wird im Collaboration-Wiki dokumentiert."@de-t-en;
    <http://purl.org/dc/terms/created> "2021-06-11T03:25:38Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/issued> "2021-06-11T03:27:06Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2021-06-11T03:27:06Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#version> "1";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeRegisteredEntity/0419052272>;
    <http://purl.org/dc/terms/creator> <https://orcid.org/0000-0002-0041-0566>, <https://orcid.org/0000-0002-3215-9652>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/subject> "Physics";
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/RSDO9W>;
    <http://purl.org/dc/terms/bibliographicCitation> "Fuks, Benjamin, 2021, \"Implementation of a search for dark matter in the mono-Z channel (2.3 fb-1; 13 TeV; CMS-EXO-16-010)\", https://doi.org/10.14428/DVN/RSDO9W, Open Data @ UCLouvain, V1";
    <http://www.w3.org/ns/dcat#contactPoint> _:b54185_b54184_b54183_df_12_69142;
    <http://www.w3.org/ns/dcat#distribution> <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-179f987cfc1-9b92fbef38b3>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-179f987d626-beace7c789d8>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-179f987dc3e-e672afcb2502>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-179f9877173-86fac4691feb>.
_:b54185_b54184_b54183_df_12_69142 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Fuks, Benjamin";
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "LPTHE / Sorbonne U.";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:fuks@lpthe.jussieu.fr>
}
<../../../index.trig> <https://w3id.org/tree#member> <#ee999574a68e3ea73ff752b594b1e84e>.
<#ee999574a68e3ea73ff752b594b1e84e> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/Y63IQ5>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:32:55.682Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#ee999574a68e3ea73ff752b594b1e84e> {
<http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/Y63IQ5> a <http://www.w3.org/ns/dcat#Dataset>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/identifier> "doi:10.14428/DVN/Y63IQ5";
    <http://purl.org/dc/terms/title> "Implementation of a search for dark matter in the mono-jet channel (19.7 fb-1; 8 TeV; CMS-EXO-12-048)"@en, "Implementatie van een zoektocht naar donkere materie in het mono-jet kanaal (19.7 fb-1; 8 TeV; CMS-EXO-12-048)"@nl-t-en, "Mise en œuvre d'une recherche de matière noire dans le canal monojet (19,7 fb-1; 8 TeV; CMS-EXO-12-048)"@fr-t-en, "Durchführung einer Suche nach Dunkler Materie im Mono-Jet-Kanal (19,7 fb-1; 8 TeV; CMS-EXO-12-048)"@de-t-en;
    <http://purl.org/dc/terms/description> "Description: This consists of the implementation, in the MadAnalysis 5 framework, of a CMS search for dark matter when it is produced in association with a energetic jet 19.7/fb of LHC proton-proton collisions at 8 TeV has been analyzed.  \n \n  \n\nInformation on how to use this code and a detailed validation summary are available on the Public Analysis Database of MadAnalysis. The CMS analysis is documented on the collaboration wiki."@en, "Beschrijving: Dit bestaat uit de implementatie, in het MadAnalysis 5-framework, van een CMS-zoekopdracht naar donkere materie wanneer deze wordt geproduceerd in combinatie met een energetische jet 19.7/fb van LHC-proton-protonbotsingen bij 8 TeV is geanalyseerd. \n\n\n\nInformatie over het gebruik van deze code en een gedetailleerde validatiesamenvatting zijn beschikbaar in de Public Analysis Database of MadAnalysis. De CMS-analyse is gedocumenteerd op de samenwerkingswiki."@nl-t-en, "Description : Il s'agit de la mise en œuvre, dans le cadre de MadAnalysis 5, d'une recherche CMS de matière noire lorsqu'elle est produite en association avec un jet énergétique 19.7/fb de collisions proton-proton LHC à 8 TeV a été analysée. \n\n\n\nDes informations sur l'utilisation de ce code et un résumé de validation détaillé sont disponibles sur la base de données d'analyse publique de MadAnalysis. L'analyse CMS est documentée sur le wiki de collaboration."@fr-t-en, "Beschreibung: Diese besteht darin, im MadAnalysis 5-Framework eine CMS-Suche nach Dunkler Materie zu implementieren, wenn sie in Verbindung mit einem energetischen Jet 19,7/fb von LHC-Proton-Proton-Kollisionen bei 8 TeV erzeugt wird. \n\n\n\nInformationen zur Verwendung dieses Codes und eine detaillierte Validierungszusammenfassung sind in der Public Analysis Database of MadAnalysis verfügbar. Die CMS-Analyse wird im Collaboration-Wiki dokumentiert."@de-t-en;
    <http://purl.org/dc/terms/created> "2021-06-10T19:27:46Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/issued> "2021-06-10T19:29:12Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2021-06-10T19:29:12Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#version> "1";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeRegisteredEntity/0419052272>;
    <http://purl.org/dc/terms/creator> <http://data.gov.be/.well-known/genid/person/ucl/f853f38893cb1f4834a47b13e40c54d4a8c6ddfc>, <http://data.gov.be/.well-known/genid/person/ucl/3a6a8b496ef8dc0e1918a616273ba7f83df34e3a>, <https://orcid.org/0000-0002-0041-0566>, <https://orcid.org/0000-0002-3215-9652>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/subject> "Physics";
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/Y63IQ5>;
    <http://purl.org/dc/terms/bibliographicCitation> "Fuks, Benjamin; Conte, Eric; Guo, Jun, 2021, \"Implementation of a search for dark matter in the mono-jet channel (19.7 fb-1; 8 TeV; CMS-EXO-12-048)\", https://doi.org/10.14428/DVN/Y63IQ5, Open Data @ UCLouvain, V1";
    <http://www.w3.org/ns/dcat#contactPoint> _:b54188_b54187_b54186_df_12_69143;
    <http://www.w3.org/ns/dcat#distribution> <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-179f7d2011b-6fe9a757cba0>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-179f7d2031b-985d0f12e1a7>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-179f7d20566-0c0f35b4e930>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-179f7d1ac9c-3149ea6a85d6>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-179f7d2cda6-b4509d361617>.
_:b54188_b54187_b54186_df_12_69143 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Fuks, Benjamin";
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "LPTHE / Sorbonne U.";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:fuks@lpthe.jussieu.fr>
}
