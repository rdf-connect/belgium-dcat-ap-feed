<../../../index.trig> <https://w3id.org/tree#member> <#31f6ec609ab9bb8f34e4895e948d298a>.
<#31f6ec609ab9bb8f34e4895e948d298a> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/A2Z26E>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:32:56.085Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#31f6ec609ab9bb8f34e4895e948d298a> {
<http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/A2Z26E> a <http://www.w3.org/ns/dcat#Dataset>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/identifier> "doi:10.14428/DVN/A2Z26E";
    <http://purl.org/dc/terms/title> "Data_HV_IPS_RS"@en, "Gegevens_HV_IPS_RS"@nl-t-en, "Données_HV_IPS_RS"@fr-t-en, "Daten_HV_IPS_RS"@de-t-en;
    <http://purl.org/dc/terms/description> "Data were collected under three conditions: hyperventilation (HV), photic stimulation (SL), and resting state (RS).\nThis longitudinal study includes 12 patients, evaluated at four visits: V1 (pre-implantation), V3 (1 month after implantation), V4 (3 months after implantation), and V5 (6 months after implantation)."@en, "De gegevens werden verzameld onder drie voorwaarden: hyperventilatie (HV), fotische stimulatie (SL) en rusttoestand (RS).\nDeze longitudinale studie omvat 12 patiënten, geëvalueerd bij vier bezoeken: V1 (pre-implantatie), V3 (1 maand na implantatie), V4 (3 maanden na implantatie) en V5 (6 maanden na implantatie)."@nl-t-en, "Les données ont été collectées sous trois conditions: hyperventilation (HV), stimulation photique (SL) et état de repos (RS).\nCette étude longitudinale comprend 12 patients, évalués à quatre visites: V1 (pré-implantation), V3 (1 mois après l'implantation), V4 (3 mois après l'implantation) et V5 (6 mois après l'implantation)."@fr-t-en, "Die Daten wurden unter drei Bedingungen erhoben: Hyperventilation (HV), photische Stimulation (SL) und Ruhezustand (RS).\nDiese Längsschnittstudie umfasst 12 Patienten, die bei vier Besuchen ausgewertet wurden: V1 (Präimplantation), V3 (1 Monat nach Implantation), V4 (3 Monate nach Implantation) und V5 (6 Monate nach Implantation)."@de-t-en;
    <http://purl.org/dc/terms/created> "2025-11-28T09:44:13Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/issued> "2025-11-28T10:36:20Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2025-11-28T10:36:20Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#version> "2";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeRegisteredEntity/0419052272>;
    <http://purl.org/dc/terms/creator> <http://data.gov.be/.well-known/genid/person/ucl/b83d87afd9ef38e7a797ae5ae0d7ad6c68b0fa88>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/subject> "Medicine, Health and Life Sciences";
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/HEAL>, <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/A2Z26E>;
    <http://purl.org/dc/terms/bibliographicCitation> "Vicini, Raphaël, 2025, \"Data_HV_IPS_RS\", https://doi.org/10.14428/DVN/A2Z26E, Open Data @ UCLouvain, V2";
    <http://www.w3.org/ns/dcat#contactPoint> _:b54425_b54424_b54423_df_12_69269.
_:b54425_b54424_b54423_df_12_69269 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Vicini, Raphaël";
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "Universite catholique de Louvain";
