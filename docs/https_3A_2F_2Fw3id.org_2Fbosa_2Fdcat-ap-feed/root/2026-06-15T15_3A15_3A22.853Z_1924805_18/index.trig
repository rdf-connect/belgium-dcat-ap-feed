    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/LBCDSE>;
    <http://purl.org/dc/terms/bibliographicCitation> "Jullion, Michel, 2026, \"Comparaison des outils d'océrisation\", https://doi.org/10.14428/DVN/LBCDSE, Open Data @ UCLouvain, V1";
    <http://www.w3.org/ns/dcat#contactPoint> _:b54140_b54139_b54138_df_12_69117;
