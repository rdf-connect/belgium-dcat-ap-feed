    <http://purl.org/dc/terms/bibliographicCitation> "Rybowski, Nicolas; Pelsser, Cristel; Bonaventure, Olivier, 2024, \"oFIQUIC: Leveraging QUIC in OSPF for seamless network topology changes\", https://doi.org/10.14428/DVN/76LJ8Y, Open Data @ UCLouvain, V1";
    <http://purl.org/ontology/bibo/citedBy> _:b54251_b54250_b54249_df_12_69173;
    <http://www.w3.org/ns/dcat#contactPoint> _:b54251_b54250_b54249_df_12_69174;
    <http://www.w3.org/ns/dcat#distribution> <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-18f7740df64-db16672cf24c>.
_:b54251_b54250_b54249_df_12_69173 a <http://purl.org/ontology/bibo/Document>;
    <http://purl.org/dc/terms/identifier> "2078.1/286860";
    <http://purl.org/ontology/bibo/uri> <http://hdl.handle.net/2078.1/286860>.
_:b54251_b54250_b54249_df_12_69174 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Rybowski, Nicolas";
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "Universite catholique de Louvain";
