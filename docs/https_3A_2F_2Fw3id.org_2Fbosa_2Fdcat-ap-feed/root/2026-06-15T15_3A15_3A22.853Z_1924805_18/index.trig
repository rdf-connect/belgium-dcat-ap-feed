    <http://purl.org/dc/terms/bibliographicCitation> "Barducci, Daniele, 2021, \"Implementation of a search for dark matter in the mono-photon channel (20.3 fb-1; 8 TeV; ATLAS-EXOT-2014-06)\", https://doi.org/10.14428/DVN/LVOXP5, Open Data @ UCLouvain, V2";
    <http://www.w3.org/ns/dcat#contactPoint> _:b54086_b54085_b54084_df_12_69091;
