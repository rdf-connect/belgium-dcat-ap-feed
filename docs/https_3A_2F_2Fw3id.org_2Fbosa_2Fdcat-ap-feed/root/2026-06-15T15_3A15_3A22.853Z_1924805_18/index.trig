    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/EHXDMB>;
    <http://purl.org/dc/terms/bibliographicCitation> "Cougnon, Louise-Amélie; Anciaux Amélie, 2025, \"VEPRe Interviews Data Analysis Grid\", https://doi.org/10.14428/DVN/EHXDMB, Open Data @ UCLouvain, V1";
