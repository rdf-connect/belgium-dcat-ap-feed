<../../../index.trig> <https://w3id.org/tree#member> <#fcd986a05a62ebd3b03f11b6cf0dbe02>.
<#fcd986a05a62ebd3b03f11b6cf0dbe02> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/EA4S4D>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:32:55.604Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#fcd986a05a62ebd3b03f11b6cf0dbe02> {
<http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/EA4S4D> a <http://www.w3.org/ns/dcat#Dataset>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/identifier> "doi:10.14428/DVN/EA4S4D";
    <http://purl.org/dc/terms/title> "Implementation of a search for sleptons and electroweakinos in the dilepton + MET channel (139 fb-1; ATLAS-SUSY-2018-32)"@en, "Implementatie van een zoektocht naar sleepons en elektroweakinos in het dilepton + MET kanaal (139 fb-1; ATLAS-SUSY-2018-32)"@nl-t-en, "Mise en œuvre d'une recherche de sleptons et d'électroweakinos dans le canal dilepton + MET (139 fb-1; ATLAS-SUSY-2018-32)"@fr-t-en, "Durchführung einer Suche nach Sleptonen und Elektroweakinos im Dilepton + MET-Kanal (139 fb-1; ATLAS-SUSY-2018-32)"@de-t-en;
    <http://purl.org/dc/terms/description> "Description: This consists of the implementation, in the MadAnalysis 5 framework, of an ATLAS search for the production of a pair of electroweakinos or sleptons that decays into two leptons and missing transverse energy. 139/fb of LHC proton-proton collisions at 13 TeV has been analysed.  \n \n  \n\nInformation on how to use this code and a detailed validation summary are available on the Public Analysis Database of MadAnalysis. The ATLAS analysis is documented on the collaboration wiki."@en, "Beschrijving: Dit bestaat uit de implementatie, in het MadAnalysis 5-framework, van een ATLAS-zoekopdracht naar de productie van een paar elektroweakino's of sleepons die vervallen in twee leptonen en transversale energie missen. 139/fb van LHC-proton-protonbotsingen bij 13 TeV is geanalyseerd. \n\n\n\nInformatie over het gebruik van deze code en een gedetailleerde validatiesamenvatting zijn beschikbaar in de Public Analysis Database of MadAnalysis. De ATLAS-analyse is gedocumenteerd op de samenwerkingswiki."@nl-t-en, "Description : Il s'agit de la mise en œuvre, dans le cadre de MadAnalysis 5, d'une recherche ATLAS pour la production d'une paire d'électroweakinos ou de sleptons qui se désintègre en deux leptons et manque d'énergie transversale. On a analysé 139/fb de collisions proton-proton du LHC à 13 TeV. \n\n\n\nDes informations sur l'utilisation de ce code et un résumé de validation détaillé sont disponibles sur la base de données d'analyse publique de MadAnalysis. L'analyse ATLAS est documentée sur le wiki de collaboration."@fr-t-en, "Beschreibung: Dies besteht in der Implementierung einer ATLAS-Suche nach der Produktion eines Paares von Elektroweakinos oder Sleptonen, die in zwei Leptonen zerfallen und transversale Energie vermissen. 139/fb von LHC-Proton-Proton-Kollisionen bei 13 TeV wurden analysiert. \n\n\n\nInformationen zur Verwendung dieses Codes und eine detaillierte Validierungszusammenfassung sind in der Public Analysis Database of MadAnalysis verfügbar. Die ATLAS-Analyse wird im Collaboration-Wiki dokumentiert."@de-t-en;
    <http://purl.org/dc/terms/created> "2024-04-22T06:21:40Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/issued> "2024-04-22T06:28:07Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2024-04-22T06:28:07Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#version> "6";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeRegisteredEntity/0419052272>;
    <http://purl.org/dc/terms/creator> <https://orcid.org/0000-0002-0041-0566>, <https://orcid.org/0000-0002-3215-9652>, <https://orcid.org/0000-0001-8721-8042>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/subject> "Physics";
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/EA4S4D>;
    <http://purl.org/dc/terms/bibliographicCitation> "Fuks, Benjamin; Araz, Jack Y., 2020, \"Implementation of a search for sleptons and electroweakinos in the dilepton + MET channel (139 fb-1; ATLAS-SUSY-2018-32)\", https://doi.org/10.14428/DVN/EA4S4D, Open Data @ UCLouvain, V6";
    <http://www.w3.org/ns/dcat#contactPoint> _:b54149_b54148_b54147_df_12_69122;
    <http://www.w3.org/ns/dcat#distribution> <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-1889ffd8f12-a3d8ca378b74>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-17e69cb3055-81716d71558a>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-175755319f5-36e265dd4727>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-18f047793e8-9ae06129dc48>, <http://data.gov.be/.well-known/genid/dist/ucl/s3-//dataverse-1757553163e-2ec47d0abf7f>.
_:b54149_b54148_b54147_df_12_69122 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Fuks, Benjamin";
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "LPTHE / Sorbonne U.";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:fuks@lpthe.jussieu.fr>
}
<../../../index.trig> <https://w3id.org/tree#member> <#0e95aeab4ad64a6c4c30bfafc19c74d5>.
<#0e95aeab4ad64a6c4c30bfafc19c74d5> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/MGNYNN>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:32:55.609Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#0e95aeab4ad64a6c4c30bfafc19c74d5> {
<http://data.gov.be/.well-known/genid/dataset/ucl/doi-10-14428/DVN/MGNYNN> a <http://www.w3.org/ns/dcat#Dataset>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/identifier> "doi:10.14428/DVN/MGNYNN";
    <http://purl.org/dc/terms/title> "RGB orthomosaic, digital surface model and slope over Stordalen Mire, Northern Sweden, 2021"@en, "RGB orthomosaic, digitaal oppervlaktemodel en helling over Stordalen Mire, Noord-Zweden, 2021"@nl-t-en, "RVB orthomosaïque, modèle de surface numérique et pente au-dessus de Stordalen Mire, nord de la Suède, 2021"@fr-t-en, "RGB-Orthomosaik, digitales Oberflächenmodell und Hang über Stordalen Mire, Nordschweden, 2021"@de-t-en;
    <http://purl.org/dc/terms/description> "RGB mosaic, digital surface model and slope derived from 367 images extracted from UAS photogrammetry (UAS: DJI MAVIC 2 PRO L1/L2 PPK). The UAS flight took place on September 17th, 2021 at an altitude of 110 m above ground level with a 70% forward overlap and a camera angle of 90°. The perspective centers of the camera were georeferenced with centimeter-level precision by post-processing RINEX data from a GNSS base station located at Abisko Scientific Research Station (swepos.lantmateriet.se; reference station 0ABI) using RTKlib v.2.3.4 software. The orthomosaic and digital surface model have been derived using Agisoft Metashape professional v1.7.5. The digital surface model represents relative elevation after removal of the bowl-shape effect from the original elevation data. Spatial resolution is 10 cm."@en, "RGB-mozaïek, digitaal oppervlaktemodel en helling afgeleid van 367 beelden uit UAS-fotogrammetrie (UAS: DJI MAVIC 2 PRO L1/L2 PPK). De UAS-vlucht vond plaats op 17 september 2021 op een hoogte van 110 m boven de grond met een voorwaartse overlap van 70% en een camerahoek van 90°. De perspectiefcentra van de camera werden met precisie op centimeterniveau gegeorefereerd door nabewerking van RINEX-gegevens van een GNSS-basisstation in Abisko Scientific Research Station (swepos.lantmateriet.se; referentiestation 0ABI) met behulp van RTKlib v.2.3.4-software. Het orthomosaische en digitale oppervlaktemodel is afgeleid met behulp van Agisoft Metashape professional v1.7.5. Het digitale oppervlaktemodel vertegenwoordigt relatieve hoogte na verwijdering van het kom-vormeffect van de oorspronkelijke hoogtegegevens. Ruimtelijke resolutie is 10 cm."@nl-t-en, "Mosaïque RVB, modèle de surface numérique et pente dérivée de 367 images extraites de la photogrammétrie UAS (UAS: DJI MAVIC 2 PRO L1/L2 PPK). Le vol de l'UAS a eu lieu le 17 septembre 2021 à une altitude de 110 m au-dessus du niveau du sol avec un chevauchement vers l'avant de 70% et un angle de caméra de 90°. Les centres de perspective de la caméra ont été géoréférencés avec une précision centimétrique en post-traitant les données RINEX d’une station de base GNSS située à la station de recherche scientifique d’Abisko (swepos.lantmateriet.se; station de référence 0ABI) utilisant le logiciel RTKlib v.2.3.4. Le modèle de surface orthomosaïque et numérique a été dérivé à l'aide d'Agisoft Metashape Professional v1.7.5. Le modèle numérique de surface représente l'élévation relative après suppression de l'effet de forme de bol des données d'élévation originales. La résolution spatiale est de 10 cm."@fr-t-en, "RGB-Mosaik, digitales Oberflächenmodell und Steigung, abgeleitet aus 367 Bildern, die aus der UAS-Photogrammetrie extrahiert wurden (UAS: DJI MAVIC 2 PRO L1/L2 PPK). Der UAS-Flug fand am 17. September 2021 in einer Höhe von 110 m über dem Boden mit einer 70%igen Vorwärtsüberlappung und einem Kamerawinkel von 90° statt. Die perspektivischen Zentren der Kamera wurden mit Zentimetergenauigkeit georeferenziert, indem RINEX-Daten von einer GNSS-Basisstation an der wissenschaftlichen Forschungsstation Abisko (swepos.lantmateriet.se; Referenzstation 0ABI) mit RTKlib v.2.3.4 Software. Das orthomosaische und digitale Oberflächenmodell wurde mit Agisoft Metashape professional v1.7.5 abgeleitet. Das digitale Oberflächenmodell stellt die relative Höhe dar, nachdem der schüsselförmige Effekt aus den ursprünglichen Höhendaten entfernt wurde. Die räumliche Auflösung beträgt 10 cm."@de-t-en;
    <http://purl.org/dc/terms/created> "2025-02-10T15:19:14Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/issued> "2025-02-11T20:23:11Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2025-02-11T20:23:11Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#version> "1";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeRegisteredEntity/0419052272>;
    <http://purl.org/dc/terms/creator> <https://orcid.org/0000-0002-3661-8203>, <https://orcid.org/0000-0002-2434-9552>, <https://orcid.org/0000-0002-7248-9920>, <https://orcid.org/0000-0003-3486-7799>, <https://orcid.org/0000-0002-3785-8305>, <https://orcid.org/0000-0002-4938-9438>, <https://orcid.org/0000-0002-8237-3446>, <https://orcid.org/0000-0002-1773-4823>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://www.w3.org/ns/dcat#keyword> "drone"@en, "UAV"@en, "photogrammetry"@en;
    <http://purl.org/dc/terms/subject> "Earth and Environmental Sciences";
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>, <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.14428/DVN/MGNYNN>;
    <http://purl.org/dc/terms/bibliographicCitation> "Thomas, Maxime; Villani, Maëlle; du Bois d’Aische, Eléonore; Hirst, Catherine; Lundin, Erik; Van Oost, Kristof; Vanacker, Veerle; Opfergelt, Sophie, 2025, \"RGB orthomosaic, digital surface model and slope over Stordalen Mire, Northern Sweden, 2021\", https://doi.org/10.14428/DVN/MGNYNN, Open Data @ UCLouvain, V1";
    <http://www.w3.org/ns/dcat#contactPoint> _:b54152_b54151_b54150_df_12_69123;
    <http://www.w3.org/ns/dcat#distribution> <http://data.gov.be/.well-known/genid/dist/ucl/doi-10-14428/DVN/MGNYNN/YZZRKH>, <http://data.gov.be/.well-known/genid/dist/ucl/doi-10-14428/DVN/MGNYNN/CPLW4I>, <http://data.gov.be/.well-known/genid/dist/ucl/doi-10-14428/DVN/MGNYNN/ND46C0>.
_:b54152_b54151_b54150_df_12_69123 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Thomas, Maxime";
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "Universite catholique de Louvain";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:maxime.thomas@uclouvain.be>
}
