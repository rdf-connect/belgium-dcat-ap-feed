<#150ad32153493ae799bdaa2df0f3eafb> {
<https://data.aeronomie.be/dataset/61589085-c269-4f2a-b367-d9b1245db12d/resource/325b0920-7d9f-4ad1-b5e5-348a9591ca14> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/title> "Lauder total and partial ozone column coincidences"@en;
    <http://purl.org/dc/terms/description> "Zip file containing multiple netCDF files with partial (PC) and total (TC) column coincidences for FTIR with Dobson, lidar, MWR, ozonesonde, Umkehr, and UV2 at Lauder. The files contain the measurement times as well as the ozone column values. The variables within the files indicate whether the ozone profiles have been regridded (containing 'on_FTIR'), smoothed (containing 'smooth_with_FTIR_avk'), substituted with a prior (containing 'with_FTIR_prior') before calculating the partial columns ('pc')."@en;
    <http://purl.org/dc/terms/issued> "2024-06-12T16:59:12.483518"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
