<../../../index.trig> <https://w3id.org/tree#member> <#bfc73e3c93af817958862b7cf5b0e510>.
<#bfc73e3c93af817958862b7cf5b0e510> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://transportdata.be/dataset/eb4072c8-9dad-4dde-872f-41f1be49369e>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:32:56.697Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#bfc73e3c93af817958862b7cf5b0e510> {
<https://transportdata.be/dataset/eb4072c8-9dad-4dde-872f-41f1be49369e> a <http://www.w3.org/ns/dcat#Dataset>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/identifier> "eb4072c8-9dad-4dde-872f-41f1be49369e";
    <http://purl.org/dc/terms/title> "poppy-trips"@en, "papaver-trips"@nl-t-en, "voyages de pavot"@fr-t-en, "Mohn-Reisen"@de-t-en;
    <http://purl.org/dc/terms/description> "A trip represents a journey taken by a Poppy customer with a geo-tagged start and stop point.\r\nThe trips endpoint allows a user to query historical trip data. \r\nIf you represent a local authority, you may request access to this data by contacting us by email. "@en, "Een reis vertegenwoordigt een reis gemaakt door een Poppy-klant met een geo-getagd start- en stoppunt. \nMet het eindpunt voor ritten kan een gebruiker historische ritgegevens opvragen.  \nAls u een lokale autoriteit vertegenwoordigt, kunt u om toegang tot deze gegevens verzoeken door per e-mail contact met ons op te nemen."@nl-t-en, "Un voyage représente un voyage effectué par un client Poppy avec un point de départ et d'arrêt géolocalisé. \nLe point de terminaison des trajets permet à un utilisateur d'interroger les données historiques des trajets.  \nSi vous représentez une autorité locale, vous pouvez demander l'accès à ces données en nous contactant par e-mail."@fr-t-en, "Eine Reise ist eine Reise, die ein Poppy-Kunde mit einem geo-getaggten Start- und Stopppunkt unternommen hat. \nDer Trips-Endpunkt ermöglicht es einem Benutzer, historische Trip-Daten abzufragen.  \nWenn Sie eine lokale Behörde vertreten, können Sie den Zugriff auf diese Daten beantragen, indem Sie uns per E-Mail kontaktieren."@de-t-en;
    <http://purl.org/dc/terms/issued> "2020-02-27T20:42:57.426472"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2024-12-18T12:05:15.949258"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeRegisteredEntity/0681505370>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg_del/2017/1926/oj>;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TRAN>;
    <http://www.w3.org/ns/dcat#landingPage> <https://transportdata.be/dataset/eb4072c8-9dad-4dde-872f-41f1be49369e#>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b54800_b54799_b54798_df_12_69538;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/2800867/>, <https://sws.geonames.org/3337388/>;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/IRREG>;
    <http://purl.org/dc/terms/temporal> _:b54800_b54799_b54798_df_12_69539;
    <https://w3id.org/mobilitydcat-ap#mobilityTheme> <https://w3id.org/mobilitydcat-ap/mobility-theme/sharing-and-hiring-services>;
    <https://w3id.org/mobilitydcat-ap#transportMode> <https://w3id.org/mobilitydcat-ap/transport-mode/car-sharing>;
    <http://www.w3.org/ns/dcat#distribution> <https://transportdata.be/dataset/eb4072c8-9dad-4dde-872f-41f1be49369e/resource/1556cfbd-c1b2-4762-a9bd-8f5b53713168>.
_:b54800_b54799_b54798_df_12_69538 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Thibaut Nguyen";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:hello@poppy.be>;
    <http://www.w3.org/2006/vcard/ns#hasTelephone> <tel:+32475123456>.
_:b54800_b54799_b54798_df_12_69539 a <http://purl.org/dc/terms/PeriodOfTime>;
    <http://www.w3.org/ns/dcat#startDate> "2020-02-27T21:40:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>
}
<../../../index.trig> <https://w3id.org/tree#member> <#1cb1ce7b335a264cbc84af7bea36a95a>.
<#1cb1ce7b335a264cbc84af7bea36a95a> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://transportdata.be/dataset/b38193f3-8455-4c84-b253-e021e4ffa306>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:32:56.702Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#1cb1ce7b335a264cbc84af7bea36a95a> {
<https://transportdata.be/dataset/b38193f3-8455-4c84-b253-e021e4ffa306> a <http://www.w3.org/ns/dcat#Dataset>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/identifier> "b38193f3-8455-4c84-b253-e021e4ffa306";
    <http://purl.org/dc/terms/title> "Planning Travel - Flibco Time Table & Bus Stops location"@en, "Plannen van reizen - Flibco Time Table & Bus Stops locatie"@nl-t-en, "Planification des déplacements - Flibco Time Table & Emplacement des arrêts de bus"@fr-t-en, "Reiseplanung - Flibco Time Table & Bus Stops location"@de-t-en;
    <http://purl.org/dc/terms/description> "This comprehensive table serves as a valuable resource for Flibco customers in Belgium, offering detailed insights into the timetables for every bus line operated by the company. Tailored specifically for end-users, this user-friendly interface empowers travelers to proactively plan their journeys. By providing essential information on departure and arrival times, passengers can make informed decisions, ensuring a seamless and convenient travel experience with Flibco across the Belgian network."@en, "Deze uitgebreide tabel dient als een waardevolle bron voor Flibco-klanten in België en biedt gedetailleerde inzichten in de dienstregelingen voor elke buslijn die door het bedrijf wordt geëxploiteerd. Deze gebruiksvriendelijke interface is speciaal afgestemd op eindgebruikers en stelt reizigers in staat hun reizen proactief te plannen. Door essentiële informatie over vertrek- en aankomsttijden te verstrekken, kunnen passagiers weloverwogen beslissingen nemen en zorgen voor een naadloze en gemakkelijke reiservaring met Flibco over het hele Belgische netwerk."@nl-t-en, "Ce tableau complet constitue une ressource précieuse pour les clients de Flibco en Belgique, offrant des informations détaillées sur les horaires de chaque ligne de bus exploitée par la société. Conçue spécifiquement pour les utilisateurs finaux, cette interface conviviale permet aux voyageurs de planifier leurs voyages de manière proactive. En fournissant des informations essentielles sur les heures de départ et d'arrivée, les passagers peuvent prendre des décisions éclairées, garantissant une expérience de voyage fluide et pratique avec Flibco sur l'ensemble du réseau belge."@fr-t-en, "Diese umfassende Tabelle dient als wertvolle Ressource für Flibco-Kunden in Belgien und bietet detaillierte Einblicke in die Fahrpläne für jede Buslinie des Unternehmens. Diese benutzerfreundliche Oberfläche wurde speziell für Endbenutzer entwickelt und ermöglicht es Reisenden, ihre Reisen proaktiv zu planen. Durch die Bereitstellung wichtiger Informationen zu Abflug- und Ankunftszeiten können Passagiere fundierte Entscheidungen treffen, um ein nahtloses und bequemes Reiseerlebnis mit Flibco im gesamten belgischen Netzwerk zu gewährleisten."@de-t-en;
    <http://purl.org/dc/terms/issued> "2023-11-24T09:36:12.519466"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2024-12-18T12:05:03.793506"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeRegisteredEntity/0831920104>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg_del/2017/1926/oj>;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TRAN>;
    <http://www.w3.org/ns/dcat#landingPage> <https://transportdata.be/dataset/b38193f3-8455-4c84-b253-e021e4ffa306#>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b54803_b54802_b54801_df_12_69540;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/2802361/>;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/IRREG>;
    <http://purl.org/dc/terms/temporal> _:b54803_b54802_b54801_df_12_69541;
    <https://w3id.org/mobilitydcat-ap#georeferencingMethod> <https://w3id.org/mobilitydcat-ap/georeferencing-method/other>;
    <https://w3id.org/mobilitydcat-ap#mobilityTheme> <https://w3id.org/mobilitydcat-ap/mobility-theme/public-transport-scheduled-transport>, <https://w3id.org/mobilitydcat-ap/mobility-theme/timetables-static>, <https://w3id.org/mobilitydcat-ap/mobility-theme/stop-facilities-location-and-features>, <https://w3id.org/mobilitydcat-ap/mobility-theme/general-information-for-trip-planning>;
    <https://w3id.org/mobilitydcat-ap#transportMode> <https://w3id.org/mobilitydcat-ap/transport-mode/bus>;
    <http://www.w3.org/ns/dcat#distribution> <https://transportdata.be/dataset/b38193f3-8455-4c84-b253-e021e4ffa306/resource/c2efcd98-09da-4567-abd9-a5f8b0fb398e>, <https://transportdata.be/dataset/b38193f3-8455-4c84-b253-e021e4ffa306/resource/b378f263-fb0f-4b96-a13c-cdd6f5f0a3d4>.
_:b54803_b54802_b54801_df_12_69540 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Jurges Veizaj";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:jve@slg.lu>;
    <http://www.w3.org/2006/vcard/ns#hasTelephone> <tel:+352661671401>.
_:b54803_b54802_b54801_df_12_69541 a <http://purl.org/dc/terms/PeriodOfTime>;
