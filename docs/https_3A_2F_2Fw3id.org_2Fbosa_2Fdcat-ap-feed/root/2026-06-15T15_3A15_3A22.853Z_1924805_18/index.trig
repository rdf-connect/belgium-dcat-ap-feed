    <https://www.w3.org/ns/activitystreams#object> <https://transportdata.be/dataset/139fb9fa-c5ae-4ed1-a994-1905843d6c63>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:32:56.476Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#2e5b2ef943a865605f76df8594c40f3b> {
<https://transportdata.be/dataset/139fb9fa-c5ae-4ed1-a994-1905843d6c63> a <http://www.w3.org/ns/dcat#Dataset>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/identifier> "139fb9fa-c5ae-4ed1-a994-1905843d6c63";
    <http://purl.org/dc/terms/title> "felyx Antwerp"@en, "felyx Antwerpen"@nl-t-en, "felyx Anvers"@fr-t-en, "felyx Antwerpen"@de-t-en;
    <http://purl.org/dc/terms/description> "Die General Bikeshare Feed Specification, bekannt als GBFS, ist der offene Datenstandard für Shared Mobility. GBFS stellt Echtzeit-Datenfeeds in einem einheitlichen Format öffentlich online zur Verfügung, mit einem Schwerpunkt auf Auffindbarkeit.\r\n\r\nBei Interesse kontaktieren Sie bitte felyx, um zu besprechen, ob und wie Zugang gewährt werden kann."@de, "The General Bikeshare Feed Specification, known as GBFS, is the open data standard for shared mobility. GBFS makes real-time data feeds in a uniform format publicly available online, with an emphasis on findability.\r\n\r\nIn case of interest, please contact felyx to discuss if and how access can be granted"@en, "De General Bikeshare Feed Specification, bekend als GBFS, is de open data standaard voor gedeelde mobiliteit. GBFS maakt real-time datafeeds beschikbaar in een uniform formaat, openbaar online, met nadruk op vindbaarheid.\r\n\r\nBij interesse kunt u contact opnemen met felyx om te bespreken of en hoe toegang verleend kan worden."@nl, "La spécification générale des flux de partage de vélos, connue sous le nom de GBFS, est la norme de données ouvertes pour la mobilité partagée. GBFS rend les flux de données en temps réel disponibles en ligne dans un format uniforme, avec une emphase sur la facilité de recherche.\r\n\r\nEn cas d'intérêt, veuillez contacter felyx pour discuter de la possibilité et des modalités d'accès."@fr;
    <http://purl.org/dc/terms/issued> "2025-02-06T11:32:37.750109"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2025-02-07T06:55:25.347215"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeRegisteredEntity/0720798585>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg_del/2017/1926/oj>;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TRAN>;
    <http://www.w3.org/ns/dcat#landingPage> <https://transportdata.be/dataset/139fb9fa-c5ae-4ed1-a994-1905843d6c63#>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b54662_b54661_b54660_df_12_69440;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337388/>;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/IRREG>;
    <http://purl.org/dc/terms/temporal> _:b54662_b54661_b54660_df_12_69441;
    <https://w3id.org/mobilitydcat-ap#mobilityTheme> <https://w3id.org/mobilitydcat-ap/mobility-theme/sharing-and-hiring-services>, <https://w3id.org/mobilitydcat-ap/mobility-theme/e-scooter-sharing-locations-and-stations>, <https://w3id.org/mobilitydcat-ap/mobility-theme/e-scooter-sharing-availability>;
    <https://w3id.org/mobilitydcat-ap#transportMode> <https://w3id.org/mobilitydcat-ap/transport-mode/bike-sharing>, <https://w3id.org/mobilitydcat-ap/transport-mode/e-scooter>;
    <http://www.w3.org/ns/dcat#distribution> <https://transportdata.be/dataset/139fb9fa-c5ae-4ed1-a994-1905843d6c63/resource/c47b7b4a-1eb2-4e73-9f41-b0869311940f>.
_:b54662_b54661_b54660_df_12_69440 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Zeus Team";
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:zeus@cooltra.com>;
    <http://www.w3.org/2006/vcard/ns#hasTelephone> <tel:+34607871107>.
_:b54662_b54661_b54660_df_12_69441 a <http://purl.org/dc/terms/PeriodOfTime>;
    <http://www.w3.org/ns/dcat#startDate> "2025-01-21T12:27:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>
}
