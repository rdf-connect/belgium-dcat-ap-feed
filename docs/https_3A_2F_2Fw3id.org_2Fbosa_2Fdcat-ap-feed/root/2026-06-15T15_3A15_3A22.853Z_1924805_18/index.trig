    <http://purl.org/dc/terms/creator> <http://data.gov.be/.well-known/genid/person/ucl/83c74b72b51e3e645d68196aeebd2a58474d7f66>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/rights> <http://data.gov.be/.well-known/genid/rights/99a2eea7fca5c3aed2c249ad7c3fa30666b8d823>;
    <http://purl.org/dc/terms/subject> "Computer and Information Science", "Medicine, Health and Life Sciences";
