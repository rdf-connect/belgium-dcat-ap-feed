<#a202f661265bfe87db2a6e369b8bce8b> {
<https://metadata.vlaanderen.be/srv/resources/distributions/a2cf12ed-226f-327f-bef6-87e2dd969096> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/identifier> "a2cf12ed-226f-327f-bef6-87e2dd969096";
    <http://purl.org/dc/terms/title> "terrein_pts"@nl;
    <http://purl.org/dc/terms/description> "Deze WFS kaartlaag bevat puntlocaties van terreinen met jeugdinfrastructuur. Buitenruimtes voor activiteiten in openlucht en/of een openbaar domein. Die kunnen specifiek ingericht zijn als een ontmoetingsruimte voor de jeugd, met zitbanken, een picknickplaats, barbecue, of een kampvuur. Er zijn daar in mindere of meerdere mate speel- of sportmogelijkheden. Punten duiden op het middelpunt van de buitenruimte. De URL is een GetFeature request voor de WFS API die een resultaat in GeoJSON-formaat teruggeeft."@nl;
    <http://purl.org/dc/terms/conformsTo> <https://data.vlaanderen.be/id/concept/dataserviceprotocol/WWW:DOWNLOAD-1.0-http--download>;
    <http://purl.org/dc/terms/rights> <https://codex.vlaanderen.be/PrintDocument.ashx?id=1019561>, <https://codex.vlaanderen.be/PrintDocument.ashx?id=1020931>, <http://data.gov.be/.well-known/genid/rights/554ce19dbf1b5f8ac6e563b197e6ea5def71a052>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/GEOJSON>;
    <http://www.w3.org/ns/dcat#accessURL> <https://metadata.vlaanderen.be/srv/dut/catalog.search#/metadata/122100b9-8f9f-416d-abee-e5c9c99924a0>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://data.uitwisselingsplatform.be/be.dcjm.infrastructuur/jeugdmaps-infrastructuur/geoinfracompleet/ows?service=WFS&version=2.0.0&request=GetFeature&typeName=terrein_pts&Features=40000&outputFormat=application/json>;
    <http://purl.org/dc/terms/license> <http://data.vlaanderen.be/id/licentie/modellicentie-gratis-hergebruik/v1.0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>;
    <http://www.w3.org/2011/content#characterEncoding> "UTF-8"
}
