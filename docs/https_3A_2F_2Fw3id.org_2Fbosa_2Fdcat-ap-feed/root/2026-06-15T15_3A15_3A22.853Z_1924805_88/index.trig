<../../../index.trig> <https://w3id.org/tree#member> <#bb088cfe60cc8a2d6d732863d682da73>.
<#bb088cfe60cc8a2d6d732863d682da73> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://transportdata.be/dataset/fbb36ed6-c16c-4009-acb9-f2cebadc5d1c/resource/1f049516-4214-45b4-b9a5-e98ef69750cc>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:37:50.650Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#bb088cfe60cc8a2d6d732863d682da73> {
<https://transportdata.be/dataset/fbb36ed6-c16c-4009-acb9-f2cebadc5d1c/resource/1f049516-4214-45b4-b9a5-e98ef69750cc> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/title> "Tours from Center Lille"@en;
    <http://purl.org/dc/terms/description> "This dataset provides the weekly schedule of shuttle bus services from Stop Lille City Center (Flandre station). Each record represents a single bus tour with detailed stop information, departure time, price and the corresponding day of the week.\r\n\r\ndepartureDay is a numeric value indicating the weekday of the departure:\r\n\r\n0 = Monday\r\n1 = Tuesday\r\n2 = Wednesday\r\n3 = Thursday\r\n4 = Friday\r\n5 = Saturday\r\n6 = Sunday\r\n\r\nThe data is suitable for integration into multimodal journey planners, passenger information systems, and mobility apps."@en;
    <http://purl.org/dc/terms/issued> "2025-06-30T11:44:21.305563"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2025-06-30T11:44:37.167919"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/rights> <http://data.gov.be/.well-known/genid/63236b7128d642e2a86d55d8b03caaf52-36CC13E725EEAEAD492993495AF2FFED>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/JSON>;
    <http://www.w3.org/ns/dcat#accessURL> <https://transportdata.be/dataset/fbb36ed6-c16c-4009-acb9-f2cebadc5d1c/resource/1f049516-4214-45b4-b9a5-e98ef69750cc/download/1019_center_lille_all_days_merged.json>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://transportdata.be/dataset/fbb36ed6-c16c-4009-acb9-f2cebadc5d1c/resource/1f049516-4214-45b4-b9a5-e98ef69750cc/download/1019_center_lille_all_days_merged.json>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>;
    <https://w3id.org/mobilitydcat-ap#applicationLayerProtocol> <https://w3id.org/mobilitydcat-ap/application-layer-protocol/other>;
    <https://w3id.org/mobilitydcat-ap#mobilityDataStandard> <https://w3id.org/mobilitydcat-ap/mobility-data-standard/other>
}
