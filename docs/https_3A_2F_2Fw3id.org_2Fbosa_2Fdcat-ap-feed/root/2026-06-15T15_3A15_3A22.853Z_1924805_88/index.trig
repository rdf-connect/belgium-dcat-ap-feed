    <http://purl.org/dc/terms/title> "Public charging infrastructure static dataset selected CPOs"@en;
    <http://purl.org/dc/terms/description> "Public charging infrastructure static dataset selected CPOs, as required by Article 20 of the AFIR regulation. The information consists of the location and AFIR specifications of charging points for electric vehicles"@en;
    <http://purl.org/dc/terms/issued> "2025-10-30T16:50:56.249898"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
