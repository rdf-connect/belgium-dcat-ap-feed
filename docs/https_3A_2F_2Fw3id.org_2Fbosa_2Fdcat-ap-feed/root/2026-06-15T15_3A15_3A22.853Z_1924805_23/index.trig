    <http://www.w3.org/ns/dcat#accessService> <https://metadata.vlaanderen.be/srv/resources/services/bb6057db-0369-3f3a-84ff-343885c5543c>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://geo.api.vlaanderen.be/bodemgebruikbodembedekking/wcs?SERVICE=WCS&VERSION=2.0.1&request=GetCoverage&CRS=EPSG:31370&subset=x,http://www.opengis.net/def/crs/EPSG/0/31370(102200,102700)&subset=y,http://www.opengis.net/def/crs/EPSG/0/31370(192500,193000)&scalefactor=2&COVERAGEID=Bodembed&FORMAT=image/tiff&RESPONSE_CRS=EPSG:31370>;
