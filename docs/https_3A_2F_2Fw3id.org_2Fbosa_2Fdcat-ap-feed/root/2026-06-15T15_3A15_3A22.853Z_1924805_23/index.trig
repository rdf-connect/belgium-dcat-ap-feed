<#8b4e7dc9cbc632673e8cd04ac8fbb010> {
<https://metadata.vlaanderen.be/srv/resources/distributions/7bd2c188-7fe6-3acd-8cb9-111b2a6daf1a> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/identifier> "7bd2c188-7fe6-3acd-8cb9-111b2a6daf1a";
    <http://purl.org/dc/terms/title> "WOK5_12"@nl;
    <http://purl.org/dc/terms/description> "Geografische raster-dataset die de bodembedekking in Vlaanderen weergeeft, toestand 2012. Deze kaart heeft een focus op permeabiliteit van de bodem, meer specifiek de ‘Waterondoorlaatbaarheid’. Het heeft hier een hydrologische context waarbij het verlies van de waterdoorlaatbaarheid belangrijk is. Waterondoorlaatbaarheid houdt verband met de oppervlakte waar het bodemoppervlak zijn infiltreerbaarheid voor water is verloren omwille van het aanbrengen van een artificieel waterondoorlatend oppervlak en dus waar water afstroomt via dit oppervlak. De kaart wordt weergegeven in percentage waterondoorlaatbaarheid per pixel (5m resolutie). (De accessURL verwijst naar een gelimiteerde set van data, volgens de INSPIRE afspraken)"@nl;
    <http://www.w3.org/ns/adms#identifier> _:b70330_b70329_b70328_df_12_5044;
    <http://purl.org/dc/terms/conformsTo> <https://data.vlaanderen.be/id/concept/dataserviceprotocol/OGC:WCS-2.0.1-http-get-coverage>;
    <http://purl.org/dc/terms/rights> <https://metadata.vlaanderen.be/srv/dut/catalog.search#/metadata/7458be82-ee6a-4eed-9f79-a0f8a358fbfa/formatters/legalconstraints>;
    <http://www.w3.org/ns/dcat#mediaType> <https://www.iana.org/assignments/media-types/application/xml>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/WCS_SRVC>;
    <http://www.w3.org/ns/dcat#accessURL> <https://metadata.vlaanderen.be/srv/dut/catalog.search#/metadata/8e828735-1474-4bd8-8c90-bebebe51e590>;
    <http://www.w3.org/ns/dcat#accessService> <https://metadata.vlaanderen.be/srv/resources/services/bb6057db-0369-3f3a-84ff-343885c5543c>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://geo.api.vlaanderen.be/bodemgebruikbodembedekking/wcs?SERVICE=WCS&VERSION=2.0.1&request=GetCoverage&CRS=EPSG:31370&subset=x,http://www.opengis.net/def/crs/EPSG/0/31370(102200,102700)&subset=y,http://www.opengis.net/def/crs/EPSG/0/31370(192500,193000)&scalefactor=2&COVERAGEID=WOK5_12&FORMAT=image/tiff&RESPONSE_CRS=EPSG:31370>;
