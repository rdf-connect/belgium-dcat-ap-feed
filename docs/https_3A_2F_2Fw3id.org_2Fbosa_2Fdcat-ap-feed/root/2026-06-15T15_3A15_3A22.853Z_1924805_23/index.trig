<../../../index.trig> <https://w3id.org/tree#member> <#46b23f3865822354d1ceff4355b21cc2>.
<#46b23f3865822354d1ceff4355b21cc2> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://metadata.vlaanderen.be/srv/resources/distributions/88202d88-ea27-366d-b2e0-75c09feb4bd3>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:33:17.995Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#46b23f3865822354d1ceff4355b21cc2> {
<https://metadata.vlaanderen.be/srv/resources/distributions/88202d88-ea27-366d-b2e0-75c09feb4bd3> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/identifier> "88202d88-ea27-366d-b2e0-75c09feb4bd3";
    <http://purl.org/dc/terms/title> "WOK5_15"@nl;
    <http://purl.org/dc/terms/description> "Geografische raster-dataset die de bodembedekking in Vlaanderen weergeeft, toestand 2015. Deze kaart heeft een focus op permeabiliteit van de bodem, meer specifiek de ‘Waterondoorlaatbaarheid’. Het heeft hier een hydrologische context waarbij het verlies van de waterdoorlaatbaarheid belangrijk is. Waterondoorlaatbaarheid houdt verband met de oppervlakte waar het bodemoppervlak zijn infiltreerbaarheid voor water is verloren omwille van het aanbrengen van een artificieel waterondoorlatend oppervlak en dus waar water afstroomt via dit oppervlak. De kaart wordt weergegeven in percentage waterondoorlaatbaarheid per pixel (5m resolutie). (De accessURL verwijst naar een gelimiteerde set van data, volgens de INSPIRE afspraken)"@nl;
    <http://www.w3.org/ns/adms#identifier> _:b70225_b70224_b70223_df_12_4996;
    <http://purl.org/dc/terms/conformsTo> <https://data.vlaanderen.be/id/concept/dataserviceprotocol/OGC:WCS-2.0.1-http-get-coverage>;
    <http://purl.org/dc/terms/rights> <https://metadata.vlaanderen.be/srv/dut/catalog.search#/metadata/7458be82-ee6a-4eed-9f79-a0f8a358fbfa/formatters/legalconstraints>;
    <http://www.w3.org/ns/dcat#mediaType> <https://www.iana.org/assignments/media-types/application/xml>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/WCS_SRVC>;
    <http://www.w3.org/ns/dcat#accessURL> <https://metadata.vlaanderen.be/srv/dut/catalog.search#/metadata/55dc7066-bcda-4fa7-baa0-6c0a027f035d>;
    <http://www.w3.org/ns/dcat#accessService> <https://metadata.vlaanderen.be/srv/resources/services/bb6057db-0369-3f3a-84ff-343885c5543c>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://geo.api.vlaanderen.be/bodemgebruikbodembedekking/wcs?SERVICE=WCS&VERSION=2.0.1&request=GetCoverage&CRS=EPSG:31370&subset=x,http://www.opengis.net/def/crs/EPSG/0/31370(102200,102700)&subset=y,http://www.opengis.net/def/crs/EPSG/0/31370(192500,193000)&scalefactor=2&COVERAGEID=WOK5_15&FORMAT=image/tiff&RESPONSE_CRS=EPSG:31370>;
    <http://purl.org/dc/terms/license> <http://data.vlaanderen.be/id/licentie/modellicentie-gratis-hergebruik/v1.0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>;
    <http://www.w3.org/2011/content#characterEncoding> "ISO-8859-1".
_:b70225_b70224_b70223_df_12_4996 a <http://www.w3.org/ns/adms#Identifier>;
    <http://www.w3.org/2004/02/skos/core#notation> "WOK5_15"^^<http://www.opengis.net/wcs#CoverageDescription>
}
