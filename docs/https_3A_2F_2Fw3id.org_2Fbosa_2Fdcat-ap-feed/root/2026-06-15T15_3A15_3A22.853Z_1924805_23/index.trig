<../../../index.trig> <https://w3id.org/tree#member> <#d2526b246f1aac6f136e7f498783e111>.
<#d2526b246f1aac6f136e7f498783e111> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://metadata.vlaanderen.be/srv/resources/distributions/d2e6490b-6ae6-372f-83e3-c809952470de>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:33:18.027Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#d2526b246f1aac6f136e7f498783e111> {
<https://metadata.vlaanderen.be/srv/resources/distributions/d2e6490b-6ae6-372f-83e3-c809952470de> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/identifier> "d2e6490b-6ae6-372f-83e3-c809952470de";
    <http://purl.org/dc/terms/title> "Bodemgebr"@nl;
    <http://purl.org/dc/terms/description> "Geografische raster-dataset die het bodemgebruik in Vlaanderen en Brussel weergeeft, toestand 2001. Het bodemgebruik klassificeert hoe de mens de bodem gebruikt en op welke manier hij de biofysische attributen van het aardoppervlak manipuleert. Het bodemgebruiksbestand werd opgebouwd door het Bodembedekkingsbestand (2001) te combineren en te interpreteren met een aantal gekende geografische datasets (bodemassociaties, CORINE landcover en het wegennet van de Grote Structuren). De grondresolutie bedraag 15 m, het bodemgebruik is ingedeeld in 19 klassen. (De accessURL verwijst naar een gelimiteerde set van data, volgens de INSPIRE afspraken)"@nl;
    <http://www.w3.org/ns/adms#identifier> _:b70249_b70248_b70247_df_12_5008;
    <http://purl.org/dc/terms/conformsTo> <https://data.vlaanderen.be/id/concept/dataserviceprotocol/OGC:WCS-2.0.1-http-get-coverage>;
    <http://purl.org/dc/terms/rights> <https://metadata.vlaanderen.be/srv/dut/catalog.search#/metadata/7458be82-ee6a-4eed-9f79-a0f8a358fbfa/formatters/legalconstraints>;
    <http://www.w3.org/ns/dcat#mediaType> <https://www.iana.org/assignments/media-types/application/xml>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/WCS_SRVC>;
    <http://www.w3.org/ns/dcat#accessURL> <https://metadata.vlaanderen.be/srv/dut/catalog.search#/metadata/C4FF31DC-9AB2-46A4-848B-4C345BBDDC57>;
    <http://www.w3.org/ns/dcat#accessService> <https://metadata.vlaanderen.be/srv/resources/services/bb6057db-0369-3f3a-84ff-343885c5543c>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://geo.api.vlaanderen.be/bodemgebruikbodembedekking/wcs?SERVICE=WCS&VERSION=2.0.1&request=GetCoverage&CRS=EPSG:31370&subset=x,http://www.opengis.net/def/crs/EPSG/0/31370(102200,102700)&subset=y,http://www.opengis.net/def/crs/EPSG/0/31370(192500,193000)&scalefactor=2&COVERAGEID=Bodemgebr&FORMAT=image/tiff&RESPONSE_CRS=EPSG:31370>;
    <http://purl.org/dc/terms/license> <http://data.vlaanderen.be/id/licentie/modellicentie-gratis-hergebruik/v1.0>;
