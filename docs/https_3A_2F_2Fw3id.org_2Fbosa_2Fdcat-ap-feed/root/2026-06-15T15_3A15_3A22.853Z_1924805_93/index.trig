    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    <http://www.w3.org/ns/dcat#landingPage> <https://www.geo.be/catalog/details/29238f19-ac79-4a4a-a797-5490226381ec?l=en>, <https://www.geo.be/catalog/details/29238f19-ac79-4a4a-a797-5490226381ec?l=fr>, <https://www.geo.be/catalog/details/29238f19-ac79-4a4a-a797-5490226381ec?l=nl>, <https://www.geo.be/catalog/details/29238f19-ac79-4a4a-a797-5490226381ec?l=de>;
    <http://www.w3.org/ns/dcat#endpointURL> <https://wms.ngi.be/inspire/ortho/service?request=GetCapabilities&service=WMS&version=1.3.0>, <https://wmts.ngi.be/inspire/ortho/1.0.0/WMTSCapabilities.xml>;
    <http://www.w3.org/ns/dcat#servesDataset> <https://publish4.geo.be/geodcat/collections/main/items/e59181f0-8469-44c6-8f6c-a5e1a4af15d5>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b279881_b279880_b279879_df_12_71123;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/2802361/>;
    <http://data.europa.eu/930/custodian> <https://org.belgif.be/id/CbeRegisteredEntity/0216755012>.
_:b279881_b279880_b279879_df_12_71123 a <http://www.w3.org/2006/vcard/ns#Kind>;
