    <http://www.w3.org/ns/dcat#endpointURL> <https://data.geo.be/ws/govroam/wms?request=getcapabilities&service=wms>;
    <http://www.w3.org/ns/dcat#servesDataset> <https://publish4.geo.be/geodcat/collections/main/items/d63b72da-6e7f-4981-b6fe-04133a127041>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b279779_b279778_b279777_df_12_71088;
