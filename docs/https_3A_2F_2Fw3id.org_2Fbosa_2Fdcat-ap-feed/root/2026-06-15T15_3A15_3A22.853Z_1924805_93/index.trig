    <http://www.w3.org/ns/dcat#keyword> "Vlaamse Baisregisters"@nl, "kadaster"@nl, "FOD FIN"@nl, "MAGDA"@nl, "VLABEL"@nl;
    <http://www.w3.org/ns/dcat#landingPage> <https://vlaamseoverheid.atlassian.net/wiki/spaces/MG/pages/584320222/Kadaster.ZoekEigendomstoestanden-02.00>;
