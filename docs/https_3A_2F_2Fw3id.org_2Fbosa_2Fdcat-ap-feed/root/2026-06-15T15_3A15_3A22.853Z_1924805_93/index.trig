    <https://www.w3.org/ns/activitystreams#object> <https://publish4.geo.be/geodcat/collections/main/items/8bdd5d37-a2aa-4015-8c6f-1f42b711242b>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:38:11.039Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#d3e9b26fa852545eec5024ab4d1d740b> {
<https://publish4.geo.be/geodcat/collections/main/items/8bdd5d37-a2aa-4015-8c6f-1f42b711242b> a <http://www.w3.org/ns/dcat#DataService>;
    <http://purl.org/dc/terms/identifier> "8bdd5d37-a2aa-4015-8c6f-1f42b711242b";
    <http://purl.org/dc/terms/title> "CORINE High Resolution Layers (WMS)"@en, "CORINE High Resolution layers (WMS)"@fr, "CORINE High Resolution Layers (WMS)"@nl, "CORINE High Resolution Layers (WMS)"@de;
    <http://purl.org/dc/terms/description> "This web service allows viewing CORINE High Resolution Layers Belgium covering the Belgian territory within the framework of a Pan-European coverage. This service is compliant with the INSPIRE specifications."@en, "Ce web-service assure la visualisation des données CORINE High Resolution Layers occupant le territoire belge dans le cadre d’une couverture paneuropé"@fr, "Deze web-service verzekert de visualisatie van CORINE High Resolution Layers Belgium die het Belgische grondgebied overdekken in het kader van een pan-Europese overdekking. De dienst is conform met INSPIRE-specificaties."@nl, "Dieser Webservice sorgt für die Visualisierung CORINE High Resolution Layers die das belgische Landgebiet innerhalb von einer pan-europäischen Deckung abdecken. Der Service entspricht den INSPIRE-Spezifikationen."@de;
    <http://purl.org/dc/terms/type> <http://inspire.ec.europa.eu/metadata-codelist/SpatialDataServiceType/view>;
    <http://purl.org/dc/terms/issued> "2014-07-09"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2022-06-28"^^<http://www.w3.org/2001/XMLSchema#date>;
