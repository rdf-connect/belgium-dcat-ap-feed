    <http://www.w3.org/ns/dcat#servesDataset> <https://geodata.wallonie.be/id/1acca4fe-cdfb-49c3-ba79-e3af84d3ca1b>, <https://geodata.wallonie.be/id/1bf35aa7-78e1-4fb2-963e-a7dd3d99f94a>, <http://geodata.wallonie.be/id/3de9790e-529f-431f-ac4f-e86d827bde8e>, <https://geodata.wallonie.be/id/4d7bee3c-e8a5-43c2-88b4-649388945f5b>, <https://geodata.wallonie.be/id/663fdba6-2cd0-41b5-b469-94bb46b61a1b>, <https://geodata.wallonie.be/id/888f36ff-0cd8-4228-9db6-09e2f159ef57>, <https://geodata.wallonie.be/id/9adf29e8-c53e-48a2-80ca-f5969f8cae00>, <https://geodata.wallonie.be/id/9cee721c-dc3d-42f7-82bc-c5cd78bbed28>, <https://geodata.wallonie.be/id/9d7e2875-b56b-42d7-b09c-899d9e3726f1>, <https://geodata.wallonie.be/id/b4f18d2d-d47c-4aaf-b638-01d76ba2a3b3>, <https://geodata.wallonie.be/id/b852eb54-434d-4933-8700-3987041010d7>, <https://geodata.wallonie.be/id/bb4bf5bf-7caf-409a-b7cd-9967b5496217>, <https://geodata.wallonie.be/id/db49325b-765a-4571-a701-e2e4cae91c1d>, <https://geodata.wallonie.be/id/e43e9109-80de-4079-add6-f2c4dfbf0ecb>, <https://geodata.wallonie.be/id/f936f399-f9d4-441d-9bb0-b17fb3b1b1b1>;
