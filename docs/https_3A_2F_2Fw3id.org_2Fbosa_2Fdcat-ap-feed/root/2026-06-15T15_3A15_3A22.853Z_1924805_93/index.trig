    <http://www.w3.org/ns/dcat#contactPoint> _:b279446_b279445_b279444_df_12_70874;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337388/>.
_:b279446_b279445_b279444_df_12_70872 a <http://www.w3.org/ns/adms#Identifier>;
