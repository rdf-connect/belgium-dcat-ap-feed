    <http://purl.org/dc/terms/subject> <http://inspire.ec.europa.eu/theme/nz>, <http://www.eionet.europa.eu/gemet/theme/32>, <http://www.eionet.europa.eu/gemet/concept/12783>, <http://inspire.ec.europa.eu/metadata-codelist/SpatialDataServiceCategory/infoMapAccessService>, <http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/regional>;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>, <http://publications.europa.eu/resource/authority/data-theme/SOCI>;
    <http://www.w3.org/ns/dcat#landingPage> <https://metawal.wallonie.be/geonetwork/srv/api/records/6989ee60-17ee-44da-807d-0941fe5685f5>;
    <http://xmlns.com/foaf/0.1/page> <http://data.europa.eu/eli/reg/2009/976>, <http://data.europa.eu/eli/reg/2010/1089>, <https://directory.spatineo.com/service/165507>;
