    <http://www.w3.org/ns/dcat#servesDataset> <https://geodata.wallonie.be/id/3dc91d81-338f-425d-b27b-f62aa0464e21>, <https://geodata.wallonie.be/id/46b18670-60dd-4ee4-a7fc-780ae638d307>, <https://geodata.wallonie.be/id/70c5ee8d-1554-468b-b5d4-7c976b046894>, <https://geodata.wallonie.be/id/91de65d9-b057-453c-992d-4c0f83dea829>, <https://geodata.wallonie.be/id/938c92ef-9fcc-495f-9f48-dcec19ec7cc8>, <https://geodata.wallonie.be/id/eed22735-0947-4e2d-8de9-b9cfbf492c80>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b280064_b280063_b280062_df_12_71190;
