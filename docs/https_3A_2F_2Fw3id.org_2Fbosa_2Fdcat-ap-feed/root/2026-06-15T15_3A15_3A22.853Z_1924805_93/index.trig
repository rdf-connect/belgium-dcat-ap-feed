<../../../index.trig> <https://w3id.org/tree#member> <#575e39041c052a763989dca6528fbd3a>.
<#575e39041c052a763989dca6528fbd3a> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://metadata.vlaanderen.be/srv/resources/services/7990290b-9d00-4816-90a7-6113ffcdefd7>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:38:10.461Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#575e39041c052a763989dca6528fbd3a> {
<https://metadata.vlaanderen.be/srv/resources/services/7990290b-9d00-4816-90a7-6113ffcdefd7> a <http://www.w3.org/ns/dcat#DataService>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/NLD>, <http://data.gov.be/.well-known/genid/e32d7fc3e84f4f2093cf4aca98a697811451-46b6e6e4e0f4392f>;
    <http://purl.org/dc/terms/identifier> "7990290b-9d00-4816-90a7-6113ffcdefd7";
    <http://purl.org/dc/terms/title> "DOSIS - ZoekDossierViaOndernemingsnummer"@nl, "DOSIS - SearchDossierViaNuméro d'entreprise"@fr-t-nl, "DOSIS - SearchDossierViaFirmennummer"@de-t-nl, "DOSIS - SearchDossierViaCompany number"@en-t-nl;
    <http://purl.org/dc/terms/description> "DOSIS is een generieke bouwsteen dat de burger of onderneming op ieder moment een minimum status-overzicht geeft van zijn lopende dossiers bij een Vlaamse of lokale overheidsdienst. Van daaruit voorziet DOSIS de mogelijkheid om door te klikken naar het eigenlijke elektronische dossier op een digitaal loket van de bevoegde overheidsdienst. Via het Dossier_GetByOndernemingsNummer endpoint kan een dossierbeheerder binnen de eigen informatiebron een lijst van dossierstatussen opzoeken voor het gekozen onderneming."@nl, "DOSIS est un bloc de construction générique qui donne au citoyen ou à l'entreprise à tout moment une vue d'ensemble minimale de ses dossiers actuels auprès d'un service gouvernemental flamand ou local. De là, DOSIS offre la possibilité de cliquer sur le fichier électronique réel sur un compteur numérique de l'administration publique compétente. Via le point de terminaison File_GetByEnterpriseEnterpriseNumber, un gestionnaire de fichiers peut rechercher une liste d'états de fichiers pour l'entreprise choisie dans sa propre source d'informations."@fr-t-nl, "DOSIS ist ein allgemeiner Baustein, der dem Bürger oder Unternehmen jederzeit einen Mindeststatusüberblick über seine aktuellen Dateien bei einem flämischen oder kommunalen Dienst gibt. Von dort aus bietet DOSIS die Möglichkeit, sich auf einem digitalen Zähler der zuständigen öffentlichen Verwaltung in die eigentliche elektronische Akte durchzuklicken. Über den Endpunkt File_GetByEnterpriseEnterpriseNumber kann ein Dateimanager eine Liste von Dateistatus für das ausgewählte Unternehmen in seiner eigenen Informationsquelle nachschlagen."@de-t-nl, "DOSIS is a generic building block that gives the citizen or company at any time a minimum status overview of his current files at a Flemish or local government service. From there, DOSIS provides the possibility to click through to the actual electronic file on a digital counter of the competent public administration. Via the File_GetByEnterpriseEnterpriseNumber endpoint, a file manager can look up a list of file statuses for the chosen company within his own information source."@en-t-nl;
    <http://www.w3.org/ns/dcat#version> "V1";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeEstablishmentUnit/2256180804>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg/2022/868/oj>;
    <http://purl.org/dc/terms/rights> <http://data.gov.be/.well-known/genid/e32d7fc3e84f4f2093cf4aca98a697811451-46b6e6e4e0f43931>;
    <http://www.w3.org/ns/dcat#keyword> "DOSIS"@nl, "Dossier"@nl, "Status"@nl, "Dossierbeheerder"@nl, "Notificatie"@nl, "IPDC"@nl, "Dossiernummer"@nl, "Wijzigingsdatum"@nl, "Doorverwijzing"@nl, "Mijn burgerProfiel"@nl, "Vlaio"@nl, "e-loket ondernemers"@nl, "Zoeken"@nl;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/SOCI>;
    <http://www.w3.org/ns/dcat#landingPage> <https://prod.dosis-burgers.vlaanderen.be/>;
    <http://www.w3.org/ns/dcat#endpointURL> <https://prod.dosis-burgers.vlaanderen.be/api/swagger/index#!/Dossier/Dossier_GetByOndernemingsNummer>;
    <http://www.w3.org/ns/dcat#endpointDescription> <https://prod.dosis-burgers.vlaanderen.be/api>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b279518_b279517_b279516_df_12_70923;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337388/>.
_:b279518_b279517_b279516_df_12_70923 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "agentschap Digitaal Vlaanderen"@nl;
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "agentschap Digitaal Vlaanderen"@nl;
    <http://www.w3.org/2006/vcard/ns#hasURL> <https://www.vlaanderen.be/digitaal-vlaanderen>;
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:digitaal.vlaanderen@vlaanderen.be>;
    <http://www.w3.org/2006/vcard/ns#hasTelephone> <tel:+3292761500>
}
