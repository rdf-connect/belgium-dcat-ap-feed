<../../../index.trig> <https://w3id.org/tree#member> <#4269b29839cc8c13d65332e7d2ec7763>.
<#4269b29839cc8c13d65332e7d2ec7763> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://metadata.vlaanderen.be/srv/resources/services/6dcfdf6a-7c00-4c49-88a3-2e2fe1c168c7>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:38:09.827Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#4269b29839cc8c13d65332e7d2ec7763> {
<https://metadata.vlaanderen.be/srv/resources/services/6dcfdf6a-7c00-4c49-88a3-2e2fe1c168c7> a <http://www.w3.org/ns/dcat#DataService>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/NLD>;
    <http://purl.org/dc/terms/identifier> "6dcfdf6a-7c00-4c49-88a3-2e2fe1c168c7";
    <http://purl.org/dc/terms/title> "Vlaams Loket Woningkwaliteit - PubliceerMutatieNotificatie - Versie 02.01"@nl, "Vlaams Loket Woningkwaliteit - PubliceerMutatieNotification - Version 02.01"@fr-t-nl, "Vlaams Loket Woningkwaliteit - PubliceerMutatieMitteilung - Version 02.01"@de-t-nl, "Vlaams Loket Woningkwaliteit - PubliceerMutatieNotification - Version 02.01"@en-t-nl;
    <http://purl.org/dc/terms/description> "Als VLOK aanpassingen doet aan gegevens die door hen beheerd worden (wijziging, aanpassing of wissen) genereren zij een mutatie. Deze mutaties worden opgelijst in een CSV bestand en doorgestuurd naar MAGDA. Enkel de sleutels van de gewijzigde gegevens worden doorgestuurd met enkele noodzakelijke meta data. De aangepaste gegevens zelf worden niet doorgestuurd.\n\nMAGDA verwerkt deze gepubliceerde gegevens en stuurt deze door naar de afnemers in een MutatieNotificatie vorm.\n\nZie ook de bron-informatie op https://vlok.vlaanderen.be/webservices/#!Documents/vlokpubliceermutatienotificatie0201bron.htm"@nl, "Si VLOK apporte des ajustements aux données qu'ils gèrent (modification, ajustement ou suppression), ils génèrent une mutation. Ces mutations sont répertoriées dans un fichier CSV et transmises à MAGDA. Seules les clés des données modifiées sont transmises avec certaines métadonnées nécessaires. Les données modifiées elles-mêmes ne seront pas transmises.\n\nMAGDA traite ces données publiées et les transmet aux clients dans un formulaire de notification de mutation. \n\nVoir également les informations sources à l’adresse https://vlok.vlaanderen.be/webservices/#!Documents/vlokpublicatiemutatienotificatie0201bron.htm"@fr-t-nl, "Wenn VLOK Anpassungen an Daten vornimmt, die von ihnen verwaltet werden (Änderung, Anpassung oder Löschung), erzeugen sie eine Mutation. Diese Mutationen werden in einer CSV-Datei aufgelistet und an MAGDA weitergeleitet. Nur die Schlüssel der geänderten Daten werden mit einigen notwendigen Metadaten weitergeleitet. Die geänderten Daten selbst werden nicht weitergeleitet.\n\nMAGDA verarbeitet diese veröffentlichten Daten und leitet sie in einem Mutationsbenachrichtigungsformular an die Kunden weiter. \n\nSiehe auch die Quellinformationen unter https://vlok.vlaanderen.be/webservices/#!Documents/vlokpublicatiemutatienotificatie0201bron.htm"@de-t-nl, "If VLOK makes adjustments to data that is managed by them (modification, adjustment or deletion), they generate a mutation. These mutations are listed in a CSV file and forwarded to MAGDA. Only the keys of the changed data are forwarded with some necessary meta data. The modified data itself will not be forwarded.\n\nMAGDA processes these published data and forwards them to the customers in a Mutation Notification form. \n\nSee also the source information at https://vlok.vlaanderen.be/webservices/#!Documents/vlokpublicatiemutatienotificatie0201bron.htm"@en-t-nl;
    <http://www.w3.org/ns/adms#identifier> _:b279167_b279166_b279165_df_12_70666, _:b279167_b279166_b279165_df_12_70667;
    <http://www.w3.org/ns/dcat#version> "02.01";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeEstablishmentUnit/2256180804>;
    <http://purl.org/dc/terms/creator> <https://org.belgif.be/id/CbeEstablishmentUnit/2256180804>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg/2022/868/oj>;
    <http://purl.org/dc/terms/rights> <http://data.gov.be/.well-known/genid/e32d7fc3e84f4f2093cf4aca98a697811106-46b6e6e4e0f35953>;
    <http://www.w3.org/ns/dcat#keyword> "Omgevingsvergunning"@nl, "Departement Omgeving"@nl, "MAGDA"@nl;
    <http://www.w3.org/ns/dcat#landingPage> <https://vlaamseoverheid.atlassian.net/wiki/spaces/MG/pages/608796724/Vlok.PubliceerMutatieNotificatie-02.01+bron>;
    <http://www.w3.org/ns/dcat#endpointDescription> <https://vlaamseoverheid.atlassian.net/wiki/spaces/MG/pages/608796724/Vlok.PubliceerMutatieNotificatie-02.01+bron>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b279167_b279166_b279165_df_12_70668;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337388/>.
_:b279167_b279166_b279165_df_12_70666 a <http://www.w3.org/ns/adms#Identifier>;
    <http://www.w3.org/2004/02/skos/core#notation> "https://metadata.vlaanderen.be/srv/doc/service/6dcfdf6a-7c00-4c49-88a3-2e2fe1c168c7".
_:b279167_b279166_b279165_df_12_70667 a <http://www.w3.org/ns/adms#Identifier>;
    <http://www.w3.org/2004/02/skos/core#notation> "https://metadata.vlaanderen.be/srv/doc/service/6dcfdf6a-7c00-4c49-88a3-2e2fe1c168c7".
_:b279167_b279166_b279165_df_12_70668 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "MAGDA Service Desk", "agentschap Digitaal Vlaanderen"@nl;
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "agentschap Digitaal Vlaanderen"@nl;
    <http://www.w3.org/2006/vcard/ns#hasURL> <https://helpdesk.magda.vlaanderen.be>;
