    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg/2022/868/oj>;
    <http://purl.org/dc/terms/rights> <http://data.gov.be/.well-known/genid/e32d7fc3e84f4f2093cf4aca98a697811340-46b6e6e4e0f3f286>;
    <http://www.w3.org/ns/dcat#keyword> "Departement Omgeving"@nl, "Omgevingsvergunning"@nl, "MAGDA"@nl;
    <http://www.w3.org/ns/dcat#landingPage> <https://vlaamseoverheid.atlassian.net/wiki/spaces/MG/pages/749994048/Energie.GeefEpc-02.01>;
