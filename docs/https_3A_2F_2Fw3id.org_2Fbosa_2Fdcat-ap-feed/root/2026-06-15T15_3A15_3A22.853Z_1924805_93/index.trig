    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/REGI>;
    <http://www.w3.org/ns/dcat#landingPage> <https://www.geo.be/catalog/details/e62c672b-60e9-4307-a929-a95fcbfa4e2a?l=en>, <https://www.geo.be/catalog/details/e62c672b-60e9-4307-a929-a95fcbfa4e2a?l=fr>, <https://www.geo.be/catalog/details/e62c672b-60e9-4307-a929-a95fcbfa4e2a?l=nl>, <https://www.geo.be/catalog/details/e62c672b-60e9-4307-a929-a95fcbfa4e2a?l=de>;
