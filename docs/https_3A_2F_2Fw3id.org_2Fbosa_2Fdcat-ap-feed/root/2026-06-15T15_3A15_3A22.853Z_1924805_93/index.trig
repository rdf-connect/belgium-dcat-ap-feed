    <http://www.w3.org/2004/02/skos/core#notation> "https://metadata.vlaanderen.be/doc/service/15fba32a-7372-465b-b89b-e9ecf051abef".
_:b279659_b279658_b279657_df_12_71019 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "MAGDA Service Desk", "agentschap Digitaal Vlaanderen"@nl;
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "agentschap Digitaal Vlaanderen"@nl;
