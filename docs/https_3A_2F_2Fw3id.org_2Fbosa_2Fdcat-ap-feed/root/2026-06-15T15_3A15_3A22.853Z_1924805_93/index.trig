    <http://purl.org/dc/terms/subject> <http://inspire.ec.europa.eu/theme/bu>, <http://www.eionet.europa.eu/gemet/theme/5>, <http://www.eionet.europa.eu/gemet/concept/1029>, <http://www.eionet.europa.eu/gemet/concept/11312>, <http://inspire.ec.europa.eu/metadata-codelist/SpatialDataServiceCategory/infoMapAccessService>, <http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/regional>;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/REGI>;
    <http://www.w3.org/ns/dcat#landingPage> <https://metawal.wallonie.be/geonetwork/srv/api/records/dfaa11a2-3e03-4250-a6de-0a6996d54b39>;
    <http://xmlns.com/foaf/0.1/page> <http://data.europa.eu/eli/reg/2009/976>, <http://data.europa.eu/eli/reg/2010/1089>, <https://directory.spatineo.com/service/165503>;
    <http://www.w3.org/ns/dcat#endpointURL> <https://geoservices.wallonie.be/geoserver/inspire_bu/ows?service=WMS&version=1.3.0>;
