    <http://purl.org/dc/terms/subject> <http://inspire.ec.europa.eu/metadata-codelist/SpatialDataServiceCategory/infoMapAccessService>, <https://www.geo.be/thesaurus/fvw.xml>, <https://www.geo.be/thesaurus/apo.xml>, <http://inspire.ec.europa.eu/theme/oi>, <http://www.eionet.europa.eu/gemet/concept/3144>, <http://www.eionet.europa.eu/gemet/concept/135>, <http://www.eionet.europa.eu/gemet/concept/oi>, <http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/national>;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>;
    <http://www.w3.org/ns/dcat#landingPage> <https://www.geo.be/catalog/details/f580600b-720d-11f0-aab7-00be433d8c24?l=en>, <https://www.geo.be/catalog/details/f580600b-720d-11f0-aab7-00be433d8c24?l=fr>, <https://www.geo.be/catalog/details/f580600b-720d-11f0-aab7-00be433d8c24?l=nl>, <https://www.geo.be/catalog/details/f580600b-720d-11f0-aab7-00be433d8c24?l=de>;
    <http://www.w3.org/ns/dcat#endpointURL> <https://wms.ngi.be/orthophotos_1960s/service?service=wms&version=1.3.0&request=getcapabilities>, <https://wmts.ngi.be/orthophotos_1960s/1.0.0/WMTSCapabilities.xml>;
    <http://www.w3.org/ns/dcat#servesDataset> <https://publish4.geo.be/geodcat/collections/main/items/TO%20COMPLETE>, <https://publish4.geo.be/geodcat/collections/main/items/c3594ed1-1d4c-11f1-856c-20c19bc9b64c>, <https://publish4.geo.be/geodcat/collections/main/items/4939b2bc-2926-11f1-b23e-20c19bc9b64c>, <https://publish4.geo.be/geodcat/collections/main/items/433748b4-292c-11f1-a769-20c19bc9b64c>, <https://publish4.geo.be/geodcat/collections/main/items/2363a560-29ff-11f1-a24a-20c19bc9b64c>, <https://publish4.geo.be/geodcat/collections/main/items/e866c4ac-29fe-11f1-a203-20c19bc9b64c>, <https://publish4.geo.be/geodcat/collections/main/items/dcc83997-29fc-11f1-9907-20c19bc9b64c>, <https://publish4.geo.be/geodcat/collections/main/items/946dd1dd-29fe-11f1-9d6d-20c19bc9b64c>, <https://publish4.geo.be/geodcat/collections/main/items/380df80f-29fe-11f1-a136-20c19bc9b64c>;
