    <http://www.w3.org/ns/dcat#contactPoint> _:b279245_b279244_b279243_df_12_70726;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337388/>.
_:b279245_b279244_b279243_df_12_70725 a <http://www.w3.org/ns/adms#Identifier>;
    <http://www.w3.org/2004/02/skos/core#notation> "https://metadata.vlaanderen.be/srv/resources/services/020bbb62-7c6c-305c-bb28-57757cbf1441".
