<../../../index.trig> <https://w3id.org/tree#member> <#9ea198c93cd55efa247b2019dc48d406>.
<#9ea198c93cd55efa247b2019dc48d406> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://metadata.vlaanderen.be/srv/resources/services/43c703a7-05c1-48ea-b4dd-5428a3b2de53>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:38:10.626Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#9ea198c93cd55efa247b2019dc48d406> {
<https://metadata.vlaanderen.be/srv/resources/services/43c703a7-05c1-48ea-b4dd-5428a3b2de53> a <http://www.w3.org/ns/dcat#DataService>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/NLD>, <http://data.gov.be/.well-known/genid/e32d7fc3e84f4f2093cf4aca98a697811541-46b6e6e4e0f47669>;
    <http://purl.org/dc/terms/identifier> "43c703a7-05c1-48ea-b4dd-5428a3b2de53";
    <http://purl.org/dc/terms/title> "Notificaties - Algemeen"@nl, "Notifications - Généralités"@fr-t-nl, "Benachrichtigungen - Allgemeines"@de-t-nl, "Notifications - General"@en-t-nl;
    <http://purl.org/dc/terms/description> "De Notificatiebouwsteen is een generieke bouwsteen die de burger of onderneming informeert over een actie, wijziging, dossierstatus...  bij een Vlaamse of lokale overheidsdienst. Deze communicatie kan via volgende 2 kanalen verstuurd worden: passief (= u ziet een bel eens aangemeld op Mijn BurgerProfiel) of actief (= email of een pushbericht). In één NotificatieBundel kan u dus aangeven over welke kanalen u wilt informeren en dit naar één of meerdere bestemmelingen. U heeft keuze uit verschillende soorten NotificatieCategorieën, zoals een vrije notificatie, welkomsbericht, algemeen nieuwsbericht, dossierwijziging (zie ook DOSIS) ..."@nl, "Le bloc de construction Notification est un bloc de construction générique qui informe le citoyen ou l'entreprise d'une action, d'un changement, d'un statut de fichier... avec un service public flamand ou local. Cette communication peut être envoyée via les 2 canaux suivants: passif (= vous verrez un appel une fois connecté à My BurgerProfile) ou actif (= email ou message push). Dans un NotificationBundel, vous pouvez indiquer les canaux sur lesquels vous souhaitez vous renseigner et cela à un ou plusieurs destinataires. Vous pouvez choisir parmi différents types de notificationsCatégories, telles qu'une notification gratuite, un message de bienvenue, une information générale, un changement de fichier (voir également DOSIS) ..."@fr-t-nl, "Der Benachrichtigungsbaustein ist ein generischer Baustein, der den Bürger oder das Unternehmen über eine Aktion, Änderung, Dateistatus... informiert. mit einem flämischen oder lokalen öffentlichen Dienst. Diese Kommunikation kann über die folgenden 2 Kanäle gesendet werden: passiv (= Sie sehen einen Anruf, sobald Sie bei My BurgerProfile angemeldet sind) oder aktiv (= E-Mail oder Push-Nachricht). In einem NotificationBundel können Sie einem oder mehreren Empfängern angeben, über welche Kanäle Sie sich erkundigen möchten. Sie können aus verschiedenen Arten von Benachrichtigungen wählenKategorien, wie eine kostenlose Benachrichtigung, Willkommensnachricht, allgemeine Nachrichten, Dateiwechsel (siehe auch DOSIS) ..."@de-t-nl, "The Notification Building Block is a generic building block that informs the citizen or company about an action, change, file status... with a Flemish or local public service. This communication can be sent via the following 2 channels: passive (= you will see a call once logged in to My BurgerProfile) or active (= email or a push message). In one NotificationBundel you can indicate which channels you want to inquire about and this to one or more recipients. You can choose from different types of NotificationCategories, such as a free notification, welcome message, general news item, file change (see also DOSIS) ..."@en-t-nl;
    <http://www.w3.org/ns/dcat#version> "V1";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeEstablishmentUnit/2256180804>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg/2022/868/oj>;
    <http://purl.org/dc/terms/rights> <http://data.gov.be/.well-known/genid/e32d7fc3e84f4f2093cf4aca98a697811541-46b6e6e4e0f4766b>;
    <http://www.w3.org/ns/dcat#keyword> "DOSIS"@nl, "Notificatie"@nl, "Doorverwijzing"@nl, "Mijn burgerProfiel"@nl, "pushbericht"@nl, "notificatiebundel"@nl, "passief"@nl, "actief"@nl, "email"@nl, "Mijn burgerprofiel"@nl;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/SOCI>;
    <http://www.w3.org/ns/dcat#landingPage> <https://prod.notificaties.vlaanderen.be/>;
    <http://www.w3.org/ns/dcat#endpointURL> <https://prod.notificaties.vlaanderen.be/swagger/index.html?urls.primaryName=Notificatie%20all>;
    <http://www.w3.org/ns/dcat#endpointDescription> <https://prod.notificaties.vlaanderen.be/wat-is-notificatie>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b279611_b279610_b279609_df_12_70988;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337388/>.
_:b279611_b279610_b279609_df_12_70988 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "agentschap Digitaal Vlaanderen"@nl;
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "agentschap Digitaal Vlaanderen"@nl;
    <http://www.w3.org/2006/vcard/ns#hasURL> <https://www.vlaanderen.be/digitaal-vlaanderen>;
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:digitaal.vlaanderen@vlaanderen.be>;
    <http://www.w3.org/2006/vcard/ns#hasTelephone> <tel:+3292761500>
}
