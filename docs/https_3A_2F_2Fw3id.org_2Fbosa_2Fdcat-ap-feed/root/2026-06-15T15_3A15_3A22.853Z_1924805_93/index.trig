    <http://www.w3.org/ns/dcat#servesDataset> <https://geodata.wallonie.be/id/9a8322bd-f53a-4f99-ad9e-753b45bdee85>, <https://geodata.wallonie.be/id/e65a7ee0-622d-44de-a1e7-411f661786ff>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b280025_b280024_b280023_df_12_71177;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337387/>.
_:b280025_b280024_b280023_df_12_71177 a <http://www.w3.org/2006/vcard/ns#Kind>;
