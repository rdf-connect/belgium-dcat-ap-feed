    <http://www.w3.org/ns/dcat#servesDataset> <https://geodata.wallonie.be/id/155eb3df-d68b-4d45-93fb-2cb1aca110a6>, <https://geodata.wallonie.be/id/37abcf36-e6a5-4ec7-b894-1c7e2dcad02b>, <https://geodata.wallonie.be/id/3b6e9057-e807-448b-a32b-2733785ea91e>, <https://geodata.wallonie.be/id/565d385b-0e4f-4bc9-8dda-98e3a22bdb44>, <https://geodata.wallonie.be/id/56b0ce31-2829-4fbe-a880-129d7e941f69>, <https://geodata.wallonie.be/id/571a70c1-6c14-4eae-8405-ddcf0af5b46f>, <https://geodata.wallonie.be/id/5adcf746-bc5a-4115-8997-b8f86001431e>, <https://geodata.wallonie.be/id/5afd1756-d338-477f-918d-5f407921b584>, <https://geodata.wallonie.be/id/5e5f77a1-fca2-413f-a05b-1ab52fd3c695>, <https://geodata.wallonie.be/id/61cd40a5-e3d3-496d-a166-ffe45b25f3c4>, <https://geodata.wallonie.be/id/70e65493-8677-4539-b683-3bcbc46a975b>, <https://geodata.wallonie.be/id/80794b5d-76b9-4e3c-83e2-fb30c0c2739b>, <https://geodata.wallonie.be/id/abaa9b74-6651-4358-b3d0-56e1cfa3083f>, <https://geodata.wallonie.be/id/b19e23e3-f6e3-44ba-af20-7cdf1b25c09a>, <https://geodata.wallonie.be/id/c90d5c3d-4e73-4311-86ea-28ab923d4c58>, <https://geodata.wallonie.be/id/d24f9e78-af7a-4450-b819-a80baba637c9>, <https://geodata.wallonie.be/id/d52095c0-d33c-44b9-a593-6e861c079997>, <https://geodata.wallonie.be/id/d5dbc4f9-cda7-4cb2-9142-c8780c6349ca>, <https://geodata.wallonie.be/id/e1590f8f-7df5-4914-b2e8-e8ed44274929>, <https://geodata.wallonie.be/id/fb1ce343-8c00-45c7-8826-c5e99a483463>, <https://geodata.wallonie.be/id/fc46abd5-7893-42dd-b2a4-7e7a47eea715>;
