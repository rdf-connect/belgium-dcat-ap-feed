    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg/2022/868/oj>;
    <http://www.w3.org/ns/dcat#keyword> "KSZ"@nl, "DSL"@nl, "VSB"@nl, "DGPH"@nl, "Sociale Zekerheid"@nl, "IRISCARE"@nl, "MAGDA"@nl, "NIC AVIQ"@nl;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/HEAL>;
