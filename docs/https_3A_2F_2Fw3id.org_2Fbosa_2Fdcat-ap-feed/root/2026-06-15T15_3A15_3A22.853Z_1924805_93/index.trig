<../../../index.trig> <https://w3id.org/tree#member> <#76ba89137399c1d8745322b159908bd6>.
<#76ba89137399c1d8745322b159908bd6> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://metadata.vlaanderen.be/srv/resources/services/01ac38d5-e210-4738-855b-4e59e757c501>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:38:10.229Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#76ba89137399c1d8745322b159908bd6> {
<https://metadata.vlaanderen.be/srv/resources/services/01ac38d5-e210-4738-855b-4e59e757c501> a <http://www.w3.org/ns/dcat#DataService>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/NLD>, <http://data.gov.be/.well-known/genid/e32d7fc3e84f4f2093cf4aca98a697811328-46b6e6e4e0f3ebdd>;
    <http://purl.org/dc/terms/identifier> "01ac38d5-e210-4738-855b-4e59e757c501";
    <http://purl.org/dc/terms/title> "DOSIS - GeavanceerdZoekenDossier"@nl, "DOSIS - AdvancedSearchDossier"@fr-t-nl, "DOSIS - Erweiterte SucheDossier"@de-t-nl, "DOSIS - AdvancedSearchDossier"@en-t-nl;
    <http://purl.org/dc/terms/description> "DOSIS is een generieke bouwsteen dat de burger of onderneming op ieder moment een minimum status-overzicht geeft van zijn lopende dossiers bij een Vlaamse of lokale overheidsdienst. Van daaruit voorziet DOSIS de mogelijkheid om door te klikken naar het eigenlijke elektronische dossier op een digitaal loket van de bevoegde overheidsdienst. Via het Dossier_Search endpoint kan een dossierbeheerder binnen de eigen informatiebron een lijst van dossierstatussen opzoeken voor burgers en ondernemers via verschillende zoekmogelijkheden."@nl, "DOSIS est un bloc de construction générique qui donne au citoyen ou à l'entreprise à tout moment une vue d'ensemble minimale de ses dossiers actuels auprès d'un service gouvernemental flamand ou local. De là, DOSIS offre la possibilité de cliquer sur le fichier électronique réel sur un compteur numérique de l'administration publique compétente. Via le point de terminaison Dossier_Search, un gestionnaire de fichiers peut rechercher une liste de statuts de fichiers pour les citoyens et les entrepreneurs dans leur propre source d'information via diverses options de recherche."@fr-t-nl, "DOSIS ist ein allgemeiner Baustein, der dem Bürger oder Unternehmen jederzeit einen Mindeststatusüberblick über seine aktuellen Dateien bei einem flämischen oder kommunalen Dienst gibt. Von dort aus bietet DOSIS die Möglichkeit, sich auf einem digitalen Zähler der zuständigen öffentlichen Verwaltung in die eigentliche elektronische Akte durchzuklicken. Über den Endpunkt Dossier_Search kann ein Dateimanager eine Liste der Dateizustände für Bürger und Unternehmer innerhalb der eigenen Informationsquelle über verschiedene Suchoptionen abrufen."@de-t-nl, "DOSIS is a generic building block that gives the citizen or company at any time a minimum status overview of his current files at a Flemish or local government service. From there, DOSIS provides the possibility to click through to the actual electronic file on a digital counter of the competent public administration. Via the Dossier_Search endpoint, a file manager can look up a list of file statuses for citizens and entrepreneurs within their own information source via various search options."@en-t-nl;
    <http://www.w3.org/ns/dcat#version> "V1";
    <http://purl.org/dc/terms/publisher> <https://org.belgif.be/id/CbeEstablishmentUnit/2256180804>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg/2022/868/oj>;
    <http://purl.org/dc/terms/rights> <http://data.gov.be/.well-known/genid/e32d7fc3e84f4f2093cf4aca98a697811328-46b6e6e4e0f3ebdf>;
    <http://www.w3.org/ns/dcat#keyword> "DOSIS"@nl, "Dossier"@nl, "Status"@nl, "Dossierbeheerder"@nl, "Notificatie"@nl, "IPDC"@nl, "Dossiernummer"@nl, "Wijzigingsdatum"@nl, "Doorverwijzing"@nl, "Mijn burgerProfiel"@nl, "Vlaio"@nl, "e-loket ondernemers"@nl, "Zoeken"@nl;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/SOCI>;
    <http://www.w3.org/ns/dcat#landingPage> <https://prod.dosis-burgers.vlaanderen.be/>;
    <http://www.w3.org/ns/dcat#endpointURL> <https://prod.dosis-burgers.vlaanderen.be/api/swagger/index#!/Dossier/Dossier_Search>;
    <http://www.w3.org/ns/dcat#endpointDescription> <https://prod.dosis-burgers.vlaanderen.be/api>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b279395_b279394_b279393_df_12_70834;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337388/>.
_:b279395_b279394_b279393_df_12_70834 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "agentschap Digitaal Vlaanderen"@nl;
    <http://www.w3.org/2006/vcard/ns#hasOrganizationName> "agentschap Digitaal Vlaanderen"@nl;
    <http://www.w3.org/2006/vcard/ns#hasURL> <https://www.vlaanderen.be/digitaal-vlaanderen>;
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:digitaal.vlaanderen@vlaanderen.be>;
    <http://www.w3.org/2006/vcard/ns#hasTelephone> <tel:+3292761500>
}
