    <http://purl.org/dc/terms/subject> <https://metadata.vlaanderen.be/id/GDI-Vlaanderen-Vlaamse-Administratieve-Eenheden/Vlaams%20Gewest>, <https://metadata.vlaanderen.be/id/GDI-Vlaanderen-Vlaamse-Administratieve-Eenheden/OostVlaanderen>, <https://metadata.vlaanderen.be/id/GDI-Vlaanderen-Vlaamse-Administratieve-Eenheden/Limburg>, <https://metadata.vlaanderen.be/id/GDI-Vlaanderen-Vlaamse-Administratieve-Eenheden/Antwerpen>, <https://metadata.vlaanderen.be/id/GDI-Vlaanderen-Vlaamse-Administratieve-Eenheden/WestVlaanderen>, <https://metadata.vlaanderen.be/id/GDI-Vlaanderen-Vlaamse-Administratieve-Eenheden/VlaamsBrabant>, <https://metadata.vlaanderen.be/id/GDI-Vlaanderen-Service-Types/OGCWFS>;
    <http://www.w3.org/ns/dcat#landingPage> <https://www.vlaanderen.be/DataCatalogRecord/b8428212-da72-4091-bdfe-7d127f95ed88>;
    <http://www.w3.org/ns/dcat#endpointURL> <https://geoservices.vlaamsbrabant.be/FSW/MapServer/WFSServer>;
    <http://www.w3.org/ns/dcat#endpointDescription> <https://geoservices.vlaamsbrabant.be/FSW/MapServer/WFSServer?>;
    <http://www.w3.org/ns/dcat#servesDataset> <https://metadata.vlaanderen.be/srv/resources/datasets/a1862892-9db3-4f28-a12a-d269ee32797a>;
    <http://www.w3.org/ns/dcat#contactPoint> _:b279491_b279490_b279489_df_12_70905;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337388/>.
_:b279491_b279490_b279489_df_12_70904 a <http://www.w3.org/ns/adms#Identifier>;
    <http://www.w3.org/2004/02/skos/core#notation> "https://metadata.vlaanderen.be/srv/resources/services/8640ba98-0b89-3e4d-b666-47c171d160e2".
_:b279491_b279490_b279489_df_12_70905 a <http://www.w3.org/2006/vcard/ns#Kind>;
    <http://www.w3.org/2006/vcard/ns#fn> "Provincie Vlaams-Brabant"@nl, "Ireen Librecht"@nl;
    <http://www.w3.org/2006/vcard/ns#hasURL> <https://www.vlaamsbrabant.be>;
    <http://www.w3.org/2006/vcard/ns#hasEmail> <mailto:gis@vlaamsbrabant.be>
}
