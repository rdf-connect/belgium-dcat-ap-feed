    <http://www.w3.org/ns/dcat#servesDataset> <https://geodata.wallonie.be/id/173e4f86-a4c0-4ee1-aee1-6b0b2e477f97>, <https://geodata.wallonie.be/id/3c0de4ca-e9d2-43da-923f-d0ecb3b0a6d3>, <https://geodata.wallonie.be/id/401a1ac7-7222-4cf8-a7bb-f68090614056>, <https://geodata.wallonie.be/id/46ab1786-de7b-4e5d-83ef-9c6310208638>, <https://geodata.wallonie.be/id/594af8f3-6dff-43f1-befb-fe450c93e676>, <https://geodata.wallonie.be/id/735761d2-2e9c-4f07-b0c8-f4151d51c19f>, <https://geodata.wallonie.be/id/91f9ebb0-9bea-48b4-8572-da17450913b6>, <https://geodata.wallonie.be/id/a5dbe105-67df-48e5-af34-5e54b2a620c4>, <https://geodata.wallonie.be/id/ad520048-5b21-4cb1-a55e-da9df2769c28>, <https://geodata.wallonie.be/id/be29163c-30b5-497c-a4b0-acc2f9de0899>, <https://geodata.wallonie.be/id/c90878ba-eb80-467e-a410-2ade159cd7b3>, <https://geodata.wallonie.be/id/d4020d9d-9adc-4640-a19e-646aea07c3e3>, <https://geodata.wallonie.be/id/d9458451-dfdd-485d-9b4a-dc9f03c51381>, <https://geodata.wallonie.be/id/fcfee86f-e782-486b-9e3b-a6b0421fd08b>;
