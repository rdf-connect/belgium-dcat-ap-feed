    <http://www.w3.org/ns/dcat#keyword> "OGC:OGC-API-Features"@nl, "gebouw"@nl, "gebouweenheid"@nl, "identificatie"@nl, "levensloop"@nl, "geometrie"@nl, "actueel"@nl, "volledig"@nl, "kwaliteit"@nl, "authentieke bron"@nl, "integratie"@nl;
    <http://purl.org/dc/terms/subject> <http://inspire.ec.europa.eu/metadata-codelist/SpatialDataServiceCategory/infoFeatureAccessService>;
