<https://metadata.omgeving.vlaanderen.be/srv/resources/distributions/eb9978ec-159c-34cb-9926-a9e972ea5dab> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/identifier> "eb9978ec-159c-34cb-9926-a9e972ea5dab";
    <http://purl.org/dc/terms/title> "DSI - SHACL encodering van het DSI applicatieprofiel"@nl;
    <http://purl.org/dc/terms/description> "Dit is de SHACL encodering van het DSI applicatieprofiel. Het DSI applicatieprofiel specifieert de RDF termen (klassen en properties) en bijhorende constraints die gebruikt worden voor het beschrijven van de verschillende entiteiten in het DSI domein model. Het maakt hierbij zoveel mogelijk gebruik van bestaande termen (klassen en properties) uit bestaande vocabularia en een minimale set van nieuwe termen gedefinieerd in het digitale stedenbouwundige informatie vocabularium."@nl;
    <http://purl.org/dc/terms/conformsTo> <https://data.vlaanderen.be/id/concept/dataserviceprotocol/WWW:DOWNLOAD-1.0-http--download>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/HTML>;
    <http://www.w3.org/ns/dcat#accessURL> <https://metadata.vlaanderen.be/srv/dut/catalog.search#/metadata/4e49d1dd-3392-55b4-85ea-e608d0937512>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://data.dsi.omgeving.vlaanderen.be/id/ontology/dsi-ap-constraints>;
    <http://purl.org/dc/terms/license> <http://data.vlaanderen.be/id/licentie/modellicentie-gratis-hergebruik/v1.0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>;
    <http://www.w3.org/2011/content#characterEncoding> "UTF-8"
}
