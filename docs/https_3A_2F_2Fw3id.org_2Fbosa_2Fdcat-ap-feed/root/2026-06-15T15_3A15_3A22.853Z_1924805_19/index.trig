<../../../index.trig> <https://w3id.org/tree#member> <#04d3eaacd45300edc2327f0c0c7cb214>.
<#04d3eaacd45300edc2327f0c0c7cb214> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://data.aeronomie.be/dataset/201db25b-eaf7-4ccc-a93e-b9c60ba37ebc/resource/3d77c222-8465-4f12-92c8-bc7393b07454>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:33:00.392Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#04d3eaacd45300edc2327f0c0c7cb214> {
<https://data.aeronomie.be/dataset/201db25b-eaf7-4ccc-a93e-b9c60ba37ebc/resource/3d77c222-8465-4f12-92c8-bc7393b07454> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/title> "Program files (MATLAB 2022a)"@en;
    <http://purl.org/dc/terms/description> "The main program is driver_restoration.m : Driver routine for mass spectrum restoration examples.\r\n\r\nRoutines for setting up the problem:\r\n\r\n* create_ion_spectrum.m : This routine creates an ion spectrum (ion beam profile) with the prescribed peak parameters, for ion peaks with given intensities and positions.\r\n* ion_beam.m : This routine creates a double Gaussian ion beam with the prescribed parameters (or a Gaussian one).\r\n* electron_cascade.m : This routine creates a double Gaussian electron cascade shape with broadening due to misalignment between the DFMS mass analysis direction and the LEDA detector arrays, with the prescribed parameters.\r\n* double_gaussian.m : This routine creates a double Gaussian with the prescribed parameters.\r\n* double_gaussian_area.m : This routine computes the integral of a double Gaussian with the prescribed parameters.\r\n* create_Gpgc.m : This routine creates a synthetic position-dependent gain. The domain consists of the whole range of pixels (or subpixels). The gain is taken to be at a constant value between 0 and 1,  except in a specified interval where it has a lower value (still between 0 and 1). The width of the transitions between the low and high position-dependent gain values can be specified.\r\n* create_LEDA_electron_spectrum.m : This routine creates a synthetic LEDA electron spectrum for a given set of incoming ions, with the prescribed ion peak parameters and electron cascade properties, and with the position-dependent MCP gain.\r\n* create_ideal_electron_spectrum.m : This routine creates a synthetic electron spectrum for a given ion spectrum, with the prescribed electron cascade properties, and assuming perfect MCP gain.\r\n\r\nRoutines for solving the problem\r\n\r\n* compute_ion_spectrum_from_LEDA_electron_spectrum.m : This routine computes the ion spectrum incident on the MCP from the electron spectrum recorded by the LEDA, knowing the electron cascade properties and the position-dependent MCP gain.\r\n* restore_LEDA_electron_spectrum.m : This routine restores a LEDA electron spectrum to eliminate the effects of the position-dependent MCP gain.\r\n"@en;
    <http://purl.org/dc/terms/issued> "2024-07-12T08:30:15.554904"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2026-04-03T08:04:47.566023"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/ZIP>;
    <http://www.w3.org/ns/dcat#compressFormat> <https://www.iana.org/assignments/media-types/application/zip>;
    <http://www.w3.org/ns/dcat#accessURL> <https://data.aeronomie.be/dataset/201db25b-eaf7-4ccc-a93e-b9c60ba37ebc>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://data.aeronomie.be/dataset/201db25b-eaf7-4ccc-a93e-b9c60ba37ebc/resource/3d77c222-8465-4f12-92c8-bc7393b07454/download/matlab_routines.zip>;
    <http://purl.org/dc/terms/license> <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>;
    <http://www.w3.org/ns/dcat#byteSize> "11827"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>
}
