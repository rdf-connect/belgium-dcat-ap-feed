<https://data.aeronomie.be/dataset/c5be77bb-d1de-401d-9861-5c13a4eabfbc/resource/1db435d8-a1d0-475f-92bf-d9b648e97397> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/title> "Reports (auxillary)"@en;
    <http://purl.org/dc/terms/description> "Collection of SPENVIS reports in HTML format generated when performing the exercise and running the following models:\r\n\r\n* Orbit generator [SAPRE](https://www.spenvis.oma.be/help/models/sapre_earth.html), `spenvis_sap.html`\r\n* Trapped proton and electron fluxes [TREP](https://www.spenvis.oma.be/help/models/trep.html), `spenvis_trp.html`, `spenvis_epeakfl.html` (integral peak electron fluxes) and `spenvis_ppeakfl.html` (integral peak proton fluxes)\r\n* Solar particle mission fluences [SEP](https://www.spenvis.oma.be/help/models/sep.html), `spenvis_sep.html`\r\n* Ionizing dose for simple geometries [SHIELDOSE](https://www.spenvis.oma.be/help/models/dose.html), `spenvis_s2p.html`\r\n"@en;
    <http://purl.org/dc/terms/issued> "2025-06-11T07:31:10.838456"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2025-06-12T10:57:23.997996"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/HTML>;
    <http://www.w3.org/ns/dcat#compressFormat> <https://www.iana.org/assignments/media-types/application/zip>;
    <http://www.w3.org/ns/dcat#accessURL> <https://data.aeronomie.be/dataset/c5be77bb-d1de-401d-9861-5c13a4eabfbc>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://data.aeronomie.be/dataset/c5be77bb-d1de-401d-9861-5c13a4eabfbc/resource/1db435d8-a1d0-475f-92bf-d9b648e97397/download/reports.zip>;
    <http://purl.org/dc/terms/license> <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>;
    <http://www.w3.org/ns/dcat#byteSize> "22390"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>
}
<../../../index.trig> <https://w3id.org/tree#member> <#5ac22b4fcd69f85e16875357f18f626e>.
