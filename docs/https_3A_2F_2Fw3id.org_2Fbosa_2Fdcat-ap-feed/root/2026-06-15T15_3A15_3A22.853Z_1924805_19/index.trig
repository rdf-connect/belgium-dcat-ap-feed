    <https://www.w3.org/ns/activitystreams#object> <https://data.aeronomie.be/dataset/26265617-8175-4a73-b219-4d837b7a6adc/resource/df6a6c35-d9ee-4217-9c57-50e2e6ca41c3>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:33:01.817Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#85939a69201af98f25543cc0736a7151> {
<https://data.aeronomie.be/dataset/26265617-8175-4a73-b219-4d837b7a6adc/resource/df6a6c35-d9ee-4217-9c57-50e2e6ca41c3> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/title> "SOIR Data in VOtable format"@en;
    <http://purl.org/dc/terms/description> "VOtables (.xml files) for each molecule detected by SOIR and for each orbit where SOIR was operating.\r\n\r\nThe density \"n_\", logarithm of the density \"log_n_\" and volume mixing ratio \"vmr_\" are provided for \r\ndifferent smoothing by a moving average with windows varying from +/-0.1 to +/- 1 scale height (by step of 0.1). \r\n\r\nFor species with only upper limits (H2S, HOCl, H2CO, O3, NH3, HCN, N2O, NO2, NO, HO2): \r\nthe files contains three fields: altitude, upper limit and error.\r\n\r\nThe corresponding uncertainties on the vertical profiles are the variables starting with \"err_\"\r\n\r\nThe files also contains the vertical profile of pressure \"p\" and temperature \"t\". For aerosols, see the older version w23.00. \r\n\r\nThe data concerning the geometry of the measurements: solar longitude, and local time, \r\nlatitude, longitude, and Julian date corresponding to the profile are also provided in the same files."@en;
    <http://purl.org/dc/terms/issued> "2024-04-25T11:27:09.930420"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2024-06-19T07:04:59.616682"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/GZIP>;
    <http://www.w3.org/ns/dcat#accessURL> <https://data.aeronomie.be/dataset/26265617-8175-4a73-b219-4d837b7a6adc>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://data.aeronomie.be/dataset/26265617-8175-4a73-b219-4d837b7a6adc/resource/df6a6c35-d9ee-4217-9c57-50e2e6ca41c3/download/vespa_soir_w24p00.ta..gz>;
    <http://purl.org/dc/terms/license> <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>;
    <http://www.w3.org/ns/dcat#byteSize> "50056695"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>
}
