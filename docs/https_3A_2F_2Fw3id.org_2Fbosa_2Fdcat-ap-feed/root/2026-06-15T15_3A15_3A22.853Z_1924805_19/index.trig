    <http://purl.org/dc/terms/title> "Maido (Reunion Island) 2017-2019 PTR-Quad-MS VOC database"@en;
    <http://purl.org/dc/terms/description> "This two-year dataset of volatile organic compound concentrations has been recorded with a high-sensitivity Proton Transfer Reaction Mass Spectrometer (hs-PTR-MS, Ionicon Analytik GmbH, Austria) at the Maïdo Observatory (21.4°S, 55.1°E, 2160 m a.s.l.) at Reunion Island in the framework of the OCTAVE campaign.\r\nThe hs-PTR-MS instrument was run in multiple ion detection mode using H3O+ source ions and a dwell time of 10 s for every VOC-related product ion, resulting in a total cycle time of ~2.7 minutes. \r\n\r\nDetails on instrument calibration can be found in Verreyken et al. Atm. Chem. Phys., 20, 14821- 14845, 2020 (https://doi.org/10.5194/acp-20-14821-2020)."@en;
    <http://purl.org/dc/terms/issued> "2024-09-11T12:55:43.833581"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2025-06-30T07:01:04.375017"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#mediaType> <https://www.iana.org/assignments/media-types/text/csv>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/CSV>;
    <http://www.w3.org/ns/dcat#accessURL> <https://data.aeronomie.be/dataset/40a2694f-e3e1-463d-8d9a-798c7023a04d>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://data.aeronomie.be/dataset/40a2694f-e3e1-463d-8d9a-798c7023a04d/resource/97515c1c-b892-438e-8e8c-7c882626f9a1/download/hs-ptr-ms_maido_v2.csv>;
    <http://purl.org/dc/terms/license> <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>;
    <http://www.w3.org/ns/dcat#byteSize> "288676203"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>
}
