<#1b1716abcb4b23cfd77c8a799ecb8cb0> {
<https://data.aeronomie.be/dataset/2e496190-27cc-40fa-8e6d-778fef252837/resource/497c30a7-7351-4636-8f8c-2902da8e80c1> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/title> "Input data"@en;
    <http://purl.org/dc/terms/description> "Input data in folder “data”  \r\nFirstly,  Positioning_info - stripped.txt and Temperatures_info_full - stripped.txt : Text files with the position and attitude information and with the temperature information.  \r\nSecondly, data_peaks/CMxxx_LEDA_A_peak_info_ALL.txt, data_peaks/CMxxx_LEDA_B_peak_info_ALL.txt with xxx = 013 to 069 : \tText files with the peak information per commanded mass-over-charge.  \r\n"@en;
    <http://purl.org/dc/terms/issued> "2024-07-12T07:55:01.133250"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2026-04-03T07:25:29.118702"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
