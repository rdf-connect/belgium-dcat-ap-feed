<../../../index.trig> <https://w3id.org/tree#member> <#68d01cf63e8a93fc4d580169637698af>.
<#68d01cf63e8a93fc4d580169637698af> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://data.aeronomie.be/dataset/a52a70e0-7f43-467c-9dc5-14b273685103/resource/e1aaf85e-b4e6-435e-95f3-d4acde191909>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:33:00.166Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#68d01cf63e8a93fc4d580169637698af> {
<https://data.aeronomie.be/dataset/a52a70e0-7f43-467c-9dc5-14b273685103/resource/e1aaf85e-b4e6-435e-95f3-d4acde191909> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/title> "VOC concentration profiles"@en;
    <http://purl.org/dc/terms/description> "The dataset contains vertical profile concentration gradients of (O)VOC related ion masses for the 2022, 2023, and 2024 campaigns. To measure a profile concentration gradient, air was sequentially sampled from 7 inlet points distributed along the vertical gradient of the forest canopy. Air was characterised at each inlet point for 5 minutes before switching to the next. Consequently, a single profile measurement took 35 minutes. These profiles were not performed continuously and as a result, the reporting time is irregular in the database. Data is provided under csv file format and information on the instrumental setup, as well as all variables reported, is detailed in the header."@en;
    <http://purl.org/dc/terms/issued> "2025-07-25T06:10:13.678828"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2025-10-13T12:01:03.984186"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#mediaType> <https://www.iana.org/assignments/media-types/text/csv>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/CSV>;
    <http://www.w3.org/ns/dcat#accessURL> <https://data.aeronomie.be/dataset/a52a70e0-7f43-467c-9dc5-14b273685103>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://data.aeronomie.be/dataset/a52a70e0-7f43-467c-9dc5-14b273685103/resource/e1aaf85e-b4e6-435e-95f3-d4acde191909/download/be-vie_35min_profile_voc_v20251013.csv>;
    <http://purl.org/dc/terms/license> <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>;
    <http://www.w3.org/ns/dcat#byteSize> "39269001"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>
}
<../../../index.trig> <https://w3id.org/tree#member> <#c8a01b7793a491ef8c96df181ac6503d>.
<#c8a01b7793a491ef8c96df181ac6503d> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://data.aeronomie.be/dataset/a52a70e0-7f43-467c-9dc5-14b273685103/resource/8b299917-63e7-4f7e-bd25-523e8c436936>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:33:00.170Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#c8a01b7793a491ef8c96df181ac6503d> {
<https://data.aeronomie.be/dataset/a52a70e0-7f43-467c-9dc5-14b273685103/resource/8b299917-63e7-4f7e-bd25-523e8c436936> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/title> "Ozone concentration profiles"@en;
    <http://purl.org/dc/terms/description> "The dataset contains vertical profile concentration gradients of ozone for the 2022, 2023, and 2024 campaigns. To measure a profile concentration gradient, air was sequentially sampled from 7 inlet points distributed along the vertical gradient of the forest canopy. Air was characterised at each inlet point for 5 minutes before switching to the next. Consequently, a single profile measurement took 35 minutes. These profiles were not performed continuously and as a result, the reporting time is irregular in the database. Data is provided under csv file format and information on the instrumental setup, as well as all variables reported, is detailed in the header."@en;
    <http://purl.org/dc/terms/issued> "2025-07-25T06:10:02.101683"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2025-08-08T10:11:24.846372"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#mediaType> <https://www.iana.org/assignments/media-types/text/csv>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/CSV>;
    <http://www.w3.org/ns/dcat#accessURL> <https://data.aeronomie.be/dataset/a52a70e0-7f43-467c-9dc5-14b273685103>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://data.aeronomie.be/dataset/a52a70e0-7f43-467c-9dc5-14b273685103/resource/8b299917-63e7-4f7e-bd25-523e8c436936/download/be-vie_35min_profile_ozone_v20250723.csv>;
    <http://purl.org/dc/terms/license> <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>;
    <http://www.w3.org/ns/dcat#byteSize> "1070274"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>
}
