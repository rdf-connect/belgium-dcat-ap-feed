<#1e43503a1611f1b21105a0766c63a3e0> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://data.aeronomie.be/dataset/6b86e128-6dd7-4197-8d4b-e712c10a3fbc/resource/7a4d4c7e-d407-481d-984c-6e4da5a4a926>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:33:01.452Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#1e43503a1611f1b21105a0766c63a3e0> {
<https://data.aeronomie.be/dataset/6b86e128-6dd7-4197-8d4b-e712c10a3fbc/resource/7a4d4c7e-d407-481d-984c-6e4da5a4a926> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/title> "Plots (auxillary)"@en;
    <http://purl.org/dc/terms/description> "Collection of graphical representations generated when performing the exercise and running the following SPENVIS models:\r\n\r\n* Orbit generator [SAPRE](https://www.spenvis.oma.be/help/models/sapre_earth.html)\r\n    * `orbit_par.png`, Orbit parameters as a function of time\r\n    * `orbit_map.png`, World map of the orbit\r\n    * `orbit_time.png`, Time plot of the altitude\r\n    * `orbit_globe.png`, 3D-View of the orbit\r\n* Trapped proton and electron fluxes [TREP](https://www.spenvis.oma.be/help/models/trep.html)\r\n    * `fluxp_spec.png`, Averaged spectra of trapped protons\r\n    * `fluxe_spec.png`, Averaged spectra of trapped electrons\r\n    * `fluxp_map.png`, World map of the trapped protons\r\n    * `fluxe_map.png`, World map of the trapped electrons\r\n* Solar particle mission fluences [SEP](https://www.spenvis.oma.be/help/models/sep.html)\r\n    * `fluxs_spec.png`, Solar proton fluence spectra\r\n    * `sep_time.png`, Attenuation factor as a function of orbital time\r\n* Ionizing dose for simple geometries [SHIELDOSE](https://www.spenvis.oma.be/help/models/dose.html)\r\n    * `sd2_dose.png`, Dose as a function of shielding thickness\r\n"@en;
    <http://purl.org/dc/terms/issued> "2025-06-13T12:49:43.921976"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2025-06-13T13:25:10.277935"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/PNG>;
    <http://www.w3.org/ns/dcat#compressFormat> <https://www.iana.org/assignments/media-types/application/zip>;
    <http://www.w3.org/ns/dcat#accessURL> <https://data.aeronomie.be/dataset/6b86e128-6dd7-4197-8d4b-e712c10a3fbc>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://data.aeronomie.be/dataset/6b86e128-6dd7-4197-8d4b-e712c10a3fbc/resource/7a4d4c7e-d407-481d-984c-6e4da5a4a926/download/plots.zip>;
    <http://purl.org/dc/terms/license> <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>;
