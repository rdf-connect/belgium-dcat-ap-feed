<https://data.aeronomie.be/dataset/010d0ba1-5dec-42e0-b2a2-e99810fb8ae4/resource/d88ee201-243a-4183-809f-f28cdfcdb789> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/title> "Instructions"@en;
    <http://purl.org/dc/terms/description> "Student instructions for this exercise.  The exercise is divided in two parts:\r\n\r\n* Part a: _Calculate the total dose an astronaut would have received during the private human spaceflight mission Axiom-1_\r\n* Part b: _Calculate the total dose an astronaut would have received during one year mission for the same orbit as Axiom-1_\r\n\r\nThe document includes worksheets to be filled during the exercise.  The exercise requires internet access, a valid SPENVIS account, and the mission trajectory file."@en;
    <http://purl.org/dc/terms/issued> "2025-06-13T12:36:30.349067"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2025-06-13T13:07:03.192801"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#mediaType> <https://www.iana.org/assignments/media-types/application/pdf>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/PDF>;
    <http://www.w3.org/ns/dcat#accessURL> <https://data.aeronomie.be/dataset/010d0ba1-5dec-42e0-b2a2-e99810fb8ae4>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://data.aeronomie.be/dataset/010d0ba1-5dec-42e0-b2a2-e99810fb8ae4/resource/d88ee201-243a-4183-809f-f28cdfcdb789/download/exercise_2_axiom1_mission.pdf>;
    <http://purl.org/dc/terms/license> <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>;
    <http://www.w3.org/ns/dcat#byteSize> "828406"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>
}
