<#1a624e0d24ee3e44c732267298745bb2> {
<https://data.aeronomie.be/dataset/57b72ff6-af37-42ca-83e7-2e4e4bfdb41c/resource/81df6904-9733-4178-b012-5353d0257a95> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/title> "buildBigXY21"@en;
    <http://purl.org/dc/terms/description> "This routine builds the input X state vector that generated any LTS case and the output Y measurement vector.  \r\nFor the logical array \"loks\" of considered cases, X contains 35 elements  \r\nX=[A(loks,1:npcOz) CAE(loks,:) Aair(loks,:) REF(loks) SIG(loks) SZA(loks) SAA(loks) ALB(loks)];\r\n = 20 ozone cooeff + 5 aerosol number log-density coeff + 5 air number log-density coeff \r\n   + effective radius + sigma (dist. width) + sza + saa+ albedo"@en;
    <http://purl.org/dc/terms/issued> "2024-04-25T11:27:22.446095"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2024-08-19T09:28:49.813982"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#mediaType> <https://www.iana.org/assignments/media-types/text/x-objcsrc>;
