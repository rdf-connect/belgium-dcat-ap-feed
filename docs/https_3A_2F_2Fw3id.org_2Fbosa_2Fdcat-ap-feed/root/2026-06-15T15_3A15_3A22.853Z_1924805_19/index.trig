<https://data.aeronomie.be/dataset/c2606305-afb4-4a64-9ec3-8b81aa275115/resource/9b511fad-3648-40ff-b9be-7bc28e59982f> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/title> "Instructions"@en;
    <http://purl.org/dc/terms/description> "Student instructions for this exercise.  The exercise is divided in two parts:\r\n\r\n* Part a: _Calculate the total dose an astronaut would have received during the private human spaceflight mission Fram2_\r\n* Part b: _Calculate the total dose an astronaut would have received during one year mission for the same orbit as Fram2_\r\n\r\nThe document includes worksheets to be filled during the exercise.  The exercise requires internet access, a valid SPENVIS account, and the mission trajectory file."@en;
    <http://purl.org/dc/terms/issued> "2025-06-13T12:55:34.440130"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2025-06-13T13:11:42.291362"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#mediaType> <https://www.iana.org/assignments/media-types/application/pdf>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/PDF>;
    <http://www.w3.org/ns/dcat#accessURL> <https://data.aeronomie.be/dataset/c2606305-afb4-4a64-9ec3-8b81aa275115>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://data.aeronomie.be/dataset/c2606305-afb4-4a64-9ec3-8b81aa275115/resource/9b511fad-3648-40ff-b9be-7bc28e59982f/download/exercise_4_fram2_mission.pdf>;
    <http://purl.org/dc/terms/license> <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>;
    <http://www.w3.org/ns/dcat#byteSize> "893852"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>
}
