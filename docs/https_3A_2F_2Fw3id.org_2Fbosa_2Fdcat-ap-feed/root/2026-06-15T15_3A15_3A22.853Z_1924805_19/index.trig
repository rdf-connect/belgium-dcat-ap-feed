<#effd5abe5709f338a80080e8f5577155> {
<https://data.aeronomie.be/dataset/6b86e128-6dd7-4197-8d4b-e712c10a3fbc/resource/bf73b09b-4e2a-44ac-afce-34703091bf90> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/title> "Trajectory file"@en;
    <http://purl.org/dc/terms/description> "Mission trajectory file to be used during the exercise.  The file is formatted according the [SPENVIS specifications](https://www.spenvis.oma.be/help/models/sapre_upl.html). It includes a sequence of epochs and positions.  The epoch (_year_, _month_, _day_, _hour_, _minute_, _second_) is expressed in Coordinated Universal Time (UTC).  The position is provided as Cartesian coordinates (_x_, _y_, _z_) in a Geocentric Equatorial Inertial (GEI) system and expressed in kilometer (km)."@en;
    <http://purl.org/dc/terms/issued> "2025-06-13T12:47:41.009324"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2025-06-13T13:10:40.033218"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/TXT>;
    <http://www.w3.org/ns/dcat#accessURL> <https://data.aeronomie.be/dataset/6b86e128-6dd7-4197-8d4b-e712c10a3fbc>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://data.aeronomie.be/dataset/6b86e128-6dd7-4197-8d4b-e712c10a3fbc/resource/bf73b09b-4e2a-44ac-afce-34703091bf90/download/polarisdawn_mission.trj>;
    <http://purl.org/dc/terms/license> <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>;
    <http://www.w3.org/ns/dcat#byteSize> "405923"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>
}
