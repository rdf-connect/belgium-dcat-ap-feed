<#70d7ef0168878d674e8681fe7ed4dd02> {
<https://data.aeronomie.be/dataset/7501cf53-8258-4a83-979b-5d399ad58db3/resource/95339a33-b43a-4b74-9376-527a16355d75> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/title> "Compressed CSV files"@en;
    <http://purl.org/dc/terms/description> "More than 5000 files, whose name indicates the year, month, date, and time of the measurement, and diffraction order.  \r\n\r\nEach file contains 9 columns:  \r\n- 1st Column: Altitude above areoid [km]  \r\n- 2nd Column: Water vapor volume mixing ratio [ppm]  \r\n- 3rd Column: Error in water vapor mixing ratio [ppm]  \r\n- 4th Column: Water vapor number density [1/cm3]  \r\n- 5th Column: Error in water vapor number density [1/cm3]  \r\n- 6th Column: Solar Longitude [degree]  \r\n- 7th Column: Latitude [degree]  \r\n- 8th Column: Longitude [degree]  \r\n- 9th Column: Local time [hrs]  "@en;
    <http://purl.org/dc/terms/issued> "2024-04-25T11:25:41.520553"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2024-07-02T11:24:17.050309"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
