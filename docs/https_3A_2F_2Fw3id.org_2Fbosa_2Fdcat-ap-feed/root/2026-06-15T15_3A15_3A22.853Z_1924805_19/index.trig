<#2b190dbe93e89e7e7c8a0ea35da408f3> {
<https://data.aeronomie.be/dataset/6b86e128-6dd7-4197-8d4b-e712c10a3fbc/resource/8577e329-7777-4128-aad4-0cfb9879195c> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/title> "Instructions"@en;
    <http://purl.org/dc/terms/description> "Student instructions for this exercise.  The exercise is divided in two parts:\r\n\r\n* Part a: _Calculate the total dose an astronaut would have received during the private human spaceflight mission Polaris Dawn_\r\n* Part b: _Calculate the total dose an astronaut would have received during one year mission for the same orbit as Polaris Dawn_\r\n\r\nThe document includes worksheets to be filled during the exercise.  The exercise requires internet access, a valid SPENVIS account, and the mission trajectory file."@en;
    <http://purl.org/dc/terms/issued> "2025-06-13T12:47:09.821824"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2025-06-13T13:10:14.298451"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#mediaType> <https://www.iana.org/assignments/media-types/application/pdf>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/PDF>;
    <http://www.w3.org/ns/dcat#accessURL> <https://data.aeronomie.be/dataset/6b86e128-6dd7-4197-8d4b-e712c10a3fbc>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://data.aeronomie.be/dataset/6b86e128-6dd7-4197-8d4b-e712c10a3fbc/resource/8577e329-7777-4128-aad4-0cfb9879195c/download/exercise_3_polarisdawn_mission.pdf>;
    <http://purl.org/dc/terms/license> <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>;
    <http://www.w3.org/ns/dcat#byteSize> "867891"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>
}
