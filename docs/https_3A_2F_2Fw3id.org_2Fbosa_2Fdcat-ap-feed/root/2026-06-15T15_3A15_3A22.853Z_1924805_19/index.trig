<../../../index.trig> <https://w3id.org/tree#member> <#1d7573cedd99ead5be52742f97c66c7e>.
<#1d7573cedd99ead5be52742f97c66c7e> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://data.aeronomie.be/dataset/8bb0a4f2-5ea6-4fef-b47e-bdbb4baf8206/resource/77393fb9-2621-4cd7-a9c7-4b883ed9dbe2>;
    <https://www.w3.org/ns/activitystreams#published> "2026-06-15T15:33:00.062Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#1d7573cedd99ead5be52742f97c66c7e> {
<https://data.aeronomie.be/dataset/8bb0a4f2-5ea6-4fef-b47e-bdbb4baf8206/resource/77393fb9-2621-4cd7-a9c7-4b883ed9dbe2> a <http://www.w3.org/ns/dcat#Distribution>;
    <http://purl.org/dc/terms/title> "Program files (MATLAB 2022a)"@en;
    <http://purl.org/dc/terms/description> "Software pack associated with the publication\r\n\r\nThis software pack folder contains:\r\n\r\nFiles\r\n\r\n* enable_source.m : adds the Source subfolder to the MatLab path\r\n\r\n* run_Geminids_double_exponential.m : Driver to perform the computations described in the paper\r\n\r\n* run_Geminids_double_exponential_fast.m : Driver to perform the computations described in the paper (faster, less precise, useful for checking)\r\n\r\nSubfolder Data:\r\n\r\n* contains all data files used in the paper (and some more) in .csv format\r\n\r\nSubfolder Source:\r\n\r\n* methods_shower_model.m : Main routine implementing the different methods\r\n\r\n* expl_optimization.m : Routine for searching a global minimum by random search and repeatedly finding a local minimum using BFGS-optimization\r\n\r\n* lmin_optimization.m : Idem but now collecting information about all the local minima encountered during the process\r\n\r\n* BFGS_optimization.m : Broyden–Fletcher–Goldfarb–Shanno minimization algorithm\r\n\r\nSubfolder Output\r\n\r\n* contains a subfolder for each run (name including the date and time of the run) with all output files: txt files with computational results, pdf figures and MatLab .fig figure files.\r\n"@en;
    <http://purl.org/dc/terms/issued> "2025-08-21T06:19:02.309329"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2026-02-05T06:44:17.639616"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/format> <http://publications.europa.eu/resource/authority/file-type/ZIP>;
    <http://www.w3.org/ns/dcat#compressFormat> <https://www.iana.org/assignments/media-types/application/zip>;
    <http://www.w3.org/ns/dcat#accessURL> <https://data.aeronomie.be/dataset/8bb0a4f2-5ea6-4fef-b47e-bdbb4baf8206>;
    <http://www.w3.org/ns/dcat#downloadURL> <https://data.aeronomie.be/dataset/8bb0a4f2-5ea6-4fef-b47e-bdbb4baf8206/resource/77393fb9-2621-4cd7-a9c7-4b883ed9dbe2/download/softwarepack_v1i1.zip>;
    <http://purl.org/dc/terms/license> <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0>;
    <http://data.europa.eu/r5r/availability> <http://publications.europa.eu/resource/authority/planned-availability/AVAILABLE>;
    <http://www.w3.org/ns/dcat#byteSize> "161056"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>
}
